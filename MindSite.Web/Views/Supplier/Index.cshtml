@model MindSite.Entities.Usuario
@{
    ViewData["Title"] = "Home Fornecedor";
    Layout = "_LayoutSupplier";
}

<div class="container mx-auto px-6 py-10">

    @* Boas vindas *@
    <div class="flex flex-wrap items-center justify-between gap-6 mb-10">
        <div>
            <h1 class="font-inria text-4xl font-bold" style="color:var(--text)">
                Olá, @(Model?.NomeCompleto ?? "Fornecedor")
            </h1>
            <p class="text-base mt-1" style="color:var(--text-muted)">
                Bem-vindo ao painel de Fornecedor MindSite.
                @if (Model?.Status == UserStatus.Pendente)
                {
                    <span class="badge badge-amber ml-2">Aprovação Pendente</span>
                }
            </p>
        </div>
        <a asp-controller="Account" asp-action="Perfil" class="btn-ghost flex items-center gap-2 text-sm">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
            Meu Perfil
        </a>
    </div>

    @if (Model?.Status == UserStatus.Pendente)
    {
        <div class="ms-card p-6 mb-8 border-l-4 flex items-start gap-4" style="border-left-color:var(--brown)">
            <svg class="w-8 h-8 flex-shrink-0 mt-0.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brown)" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 16h-1v-4h-1m1-4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"/>
            </svg>
            <div>
                <p class="font-bold text-base" style="color:var(--text)">Conta em análise</p>
                <p class="text-sm mt-1" style="color:var(--text-muted)">Sua solicitação foi recebida e está sendo analisada pela equipe MindSite. Você será notificado assim que for aprovado.</p>
            </div>
        </div>
    }

    @* Cards de métricas do fornecedor *@
    <div class="grid grid-cols-1 sm:grid-cols-2 gap-6 mb-10">
        <div class="ms-card p-6 flex items-center justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--text-muted)">Disponíveis para aceitar</p>
                <p class="text-4xl font-bold font-inria" style="color:var(--brown)">@(ViewBag.Pendentes ?? 0)</p>
            </div>
            <div class="p-3 rounded-xl opacity-20" style="background:var(--brown)">
                <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2m-6 9l2 2 4-4"/></svg>
            </div>
        </div>
        <div class="ms-card p-6 flex items-center justify-between">
            <div>
                <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--text-muted)">Em andamento</p>
                <p class="text-4xl font-bold font-inria" style="color:var(--brown)">@(ViewBag.EmAndamento ?? 0)</p>
            </div>
            <div class="p-3 rounded-xl opacity-20" style="background:var(--brown)">
                <svg class="w-8 h-8 text-white" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
            </div>
        </div>
    </div>

    @* Grade de ações rápidas de navegação *@
    <h2 class="font-inria text-2xl font-bold mb-6" style="color:var(--text)">Ações Rápidas</h2>
    <div class="grid grid-cols-1 sm:grid-cols-3 gap-5">
        <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="disponiveis"
           class="ms-card p-6 flex flex-col gap-3 hover:shadow-xl hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:var(--bg2)">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brown)" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/></svg>
            </div>
            <p class="font-bold text-base" style="color:var(--text)">Ver Serviços Disponíveis</p>
            <p class="text-xs" style="color:var(--text-muted)">Aceite novos projetos de clientes</p>
        </a>
        <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="meus"
           class="ms-card p-6 flex flex-col gap-3 hover:shadow-xl hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:var(--bg2)">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brown)" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 4h2a2 2 0 012 2v14a2 2 0 01-2 2H6a2 2 0 01-2-2V6a2 2 0 012-2h2"/></svg>
            </div>
            <p class="font-bold text-base" style="color:var(--text)">Meus Projetos</p>
            <p class="text-xs" style="color:var(--text-muted)">Acompanhe os projetos em andamento</p>
        </a>
        <a asp-controller="Supplier" asp-action="Chat"
           class="ms-card p-6 flex flex-col gap-3 hover:shadow-xl hover:-translate-y-1 transition-all">
            <div class="w-12 h-12 rounded-xl flex items-center justify-center" style="background:var(--bg2)">
                <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brown)" aria-hidden="true"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
            </div>
            <p class="font-bold text-base" style="color:var(--text)">Mensagens</p>
            <p class="text-xs" style="color:var(--text-muted)">Comunique-se com seus clientes</p>
        </a>
    </div>
</div>
