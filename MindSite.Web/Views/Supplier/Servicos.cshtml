<div class="container mx-auto px-6 py-10">
    <div class="flex flex-wrap items-center justify-between gap-4 mb-8">
        <div>
            <h1 class="font-inria text-4xl font-bold" style="color:var(--text)">
                @(filtro == "meus" ? "Meus Projetos" : "Serviços Disponíveis")
            </h1>
            <p class="text-sm mt-1" style="color:var(--text-muted)">
                @(filtro == "meus" ? "Projetos que você está atendendo" : "Solicitações abertas para proposta")
            </p>
        </div>
        <div class="flex gap-2">
            <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="disponiveis"
               class="px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all"
               style="@(filtro == "disponiveis" ? "background:var(--brown);color:#fff;" : "background:var(--bg2);color:var(--text)")">
                Disponíveis
            </a>
            <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="meus"
               class="px-4 py-2 rounded-xl text-xs font-bold uppercase tracking-wider transition-all"
               style="@(filtro == "meus" ? "background:var(--brown);color:#fff;" : "background:var(--bg2);color:var(--text)")">
                Meus Projetos
            </a>
        </div>
    </div>

    @if (!Model.Any())
    {
        <div class="ms-card p-16 text-center">
            <svg class="w-16 h-16 mx-auto mb-4 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--text-muted)" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 5H7a2 2 0 00-2 2v12a2 2 0 002 2h10a2 2 0 002-2V7a2 2 0 00-2-2h-2M9 5a2 2 0 002 2h2a2 2 0 002-2M9 5a2 2 0 012-2h2a2 2 0 012 2"/>
            </svg>
            <p class="text-lg font-medium" style="color:var(--text-muted)">
                @(filtro == "meus" ? "Nenhum projeto em andamento" : "Nenhum serviço disponível no momento")
            </p>
        </div>
    }
    else
    {
        <div class="flex flex-col gap-4">
            @foreach (var s in Model)
            {
                var (badgeClass, label) = s.Status switch {
                    ServicoStatus.Ativo                  => ("badge-green", "Ativo"),
                    ServicoStatus.AguardandoPropostas    => ("badge-blue",  "Aguardando propostas"),
                    ServicoStatus.MudancaSolicitada      => ("badge-blue",  "Mudança Solicitada"),
                    ServicoStatus.Concluido              => ("badge-green", "Concluído"),
                    ServicoStatus.AguardandoPagamentoFinal => ("badge-amber","Aguardando pgto. final"),
                    _                                    => ("badge-red",   s.Status.ToString())
                };
                bool jaEnviouProposta = s.Propostas.Any(p => p.FornecedorId == userId);
                bool naoSabe = s.PrazoCliente == null || s.PrazoCliente == MindSite.Enums.PrazoTipo.NaoSei;
                int diasSug  = s.PrazoCliente switch {
                    MindSite.Enums.PrazoTipo.Meses1a3    => 45,
                    MindSite.Enums.PrazoTipo.Ate6Meses   => 120,
                    MindSite.Enums.PrazoTipo.Ate1Ano     => 270,
                    MindSite.Enums.PrazoTipo.MaisDeUmAno => 400,
                    MindSite.Enums.PrazoTipo.DataEspecifica => s.DataPrazoCliente.HasValue
                        ? (int)(s.DataPrazoCliente.Value.Date - DateTime.Today).TotalDays
                        : 30,
                    _ => 30
                };
                string orcStr = s.OrcamentoCliente.HasValue
                    ? s.OrcamentoCliente.Value.ToString("F2", System.Globalization.CultureInfo.InvariantCulture)
                    : "";

                <div class="ms-card p-6">
                    <div class="flex flex-wrap items-start justify-between gap-4">
                        <div class="flex-1">
                            <div class="flex items-center gap-3 flex-wrap mb-2">
                                <h3 class="font-bold text-lg" style="color:var(--text)">
                                    @(string.IsNullOrEmpty(s.NomeProjeto) ? tipoNome[s.Tipo] : s.NomeProjeto)
                                </h3>
                                <span class="badge badge-amber text-[10px]">@tipoNome[s.Tipo]</span>
                                <span class="badge @badgeClass">@label</span>
                                @if (filtro == "disponiveis")
                                {
                                    <span class="badge badge-amber text-[10px]">@s.Propostas.Count/3 propostas</span>
                                }
                            </div>
                            <div class="flex flex-wrap gap-4 text-xs mt-1" style="color:var(--text-muted)">
                                <span>Solicitado em @s.CriadoEm.ToLocalTime().ToString("dd/MM/yyyy")</span>
                                @if (filtro == "disponiveis")
                                {
                                    @if (s.OrcamentoCliente.HasValue)
                                    {
                                        <span class="font-semibold" style="color:var(--brown)">Orçamento: R$ @s.OrcamentoCliente.Value.ToString("N2")</span>
                                    }
                                    else
                                    {
                                        <span>Orçamento: a definir</span>
                                    }
                                }
                                @if (filtro == "meus")
                                {
                                    <span>Cliente: @(s.Cliente?.NomeCompleto ?? "—")</span>
                                    @if (s.Valor.HasValue) { <span>R$ @s.Valor.Value.ToString("N2")</span> }
                                    @if (s.DataEntrega.HasValue) { <span>Entrega: @s.DataEntrega.Value.ToString("dd/MM/yyyy")</span> }
                                    @if (s.Status == ServicoStatus.Ativo && !s.PagamentoInicialFeito)
                                    {
                                        <span class="badge badge-red text-[10px]">Aguardando confirmação de pagamento inicial</span>
                                    }
                                }
                            </div>
                            @if (!string.IsNullOrEmpty(s.Observacoes) && filtro == "meus")
                            {
                                <p class="text-xs mt-2 italic" style="color:var(--text-muted)">@s.Observacoes</p>
                            }
                        </div>
                        <div class="flex flex-wrap gap-2 w-full sm:w-auto border-t sm:border-t-0 pt-3 sm:pt-0 mt-2 sm:mt-0" style="border-color:var(--border)">
                            <a asp-controller="Supplier" asp-action="DetalheServico" asp-route-id="@s.Id"
                               class="btn-ghost text-xs px-3 py-1.5">Ver detalhes</a>
                            @if (filtro == "disponiveis")
                            {
                                @if (!jaEnviouProposta)
                                {
                                    <button onclick="abrirProposta(@s.Id, @(naoSabe ? "true" : "false"), @diasSug, '@orcStr')" class="btn-primary text-xs px-3 py-1.5">Aceitar fazer</button>
                                }
                                else
                                {
                                    <span class="text-xs px-3 py-1.5 rounded-lg font-medium" style="background:var(--bg2);color:var(--text-muted)">Proposta enviada</span>
                                }
                            }
                            @if (filtro == "meus" && s.ClienteId > 0 && s.PagamentoInicialFeito)
                            {
                                <a asp-controller="Supplier" asp-action="Chat" asp-route-contatoId="@s.ClienteId"
                                   class="btn-secondary text-xs px-3 py-1.5">Chat</a>
                            }
                        </div>
                    </div>

                    @* Avaliação da plataforma (só em "meus" e Concluído) *@
                    @if (filtro == "meus" && s.Status == ServicoStatus.Concluido)
                    {
                        bool avSistForn = s.AvaliacoesSistema.Any(a => a.UsuarioId == userId);
                        var  avSistObj  = s.AvaliacoesSistema.FirstOrDefault(a => a.UsuarioId == userId);
                        <div class="mt-4 pt-4 flex flex-wrap gap-3 items-center" style="border-top:1px solid var(--border)">
                            @if (!avSistForn)
                            {
                                <button type="button" class="btn-secondary text-xs px-4 py-2"
                                        onclick="abrirSistemaForn(@s.Id)">
                                    ★ Avaliar a Plataforma
                                </button>
                            }
                            else if (avSistObj != null)
                            {
                                <p class="text-xs" style="color:var(--text-muted)">
                                    <span class="font-semibold" style="color:var(--text)">Plataforma avaliada:</span>
                                    <strong style="color:var(--brown)">@(new string('★', avSistObj.Estrelas))@(new string('☆', 5 - avSistObj.Estrelas))</strong>
                                </p>
                            }
                        </div>
                    }
                </div>
            }
        </div>
    }

    @* Paginação *@
    @{ int srvPage = ViewBag.Page ?? 1; int srvTotal = ViewBag.TotalPages ?? 1; string srvFiltro = ViewBag.Filtro ?? "disponiveis"; }
    @if (srvTotal > 1)
    {
        <div class="flex items-center justify-center gap-2 mt-6 flex-wrap">
            @if (srvPage > 1)
            {
                <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="@srvFiltro" asp-route-page="@(srvPage - 1)"
                   class="px-3 py-2 rounded-xl text-sm" style="background:var(--surface);color:var(--text)">← Anterior</a>
            }
            @for (int p = Math.Max(1, srvPage - 2); p <= Math.Min(srvTotal, srvPage + 2); p++)
            {
                <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="@srvFiltro" asp-route-page="@p"
                   class="px-3 py-2 rounded-xl text-sm font-bold"
                   style="@(p == srvPage ? "background:var(--brown);color:#fff;" : "background:var(--surface);color:var(--text)")">@p</a>
            }
            @if (srvPage < srvTotal)
            {
                <a asp-controller="Supplier" asp-action="Servicos" asp-route-filtro="@srvFiltro" asp-route-page="@(srvPage + 1)"
                   class="px-3 py-2 rounded-xl text-sm" style="background:var(--surface);color:var(--text)">Próxima →</a>
            }
        </div>
    }
</div>

@section Scripts {
@if (TempData["Erro"] != null){<script>showToast(@Json.Serialize(TempData["Erro"]!.ToString()),'erro');</script>}
<script>
let _propostaIdPendente = null;
let _clienteNaoSabe   = true;
let _diasSugeridos    = 30;
let _orcamentoServico = '';

// Abre o modal do contrato do fornecedor para aceitar e enviar proposta
function abrirProposta(id, naoSabe, dias, orcamento) {
    _propostaIdPendente = id;
    _clienteNaoSabe = (naoSabe === true || naoSabe === 'true');
    _diasSugeridos  = parseInt(dias) || 30;
    _orcamentoServico = orcamento || '';
    document.getElementById('checkContratoFornecedor').checked = false;
    const fornDataField = document.getElementById('contratoFornecedorData');
    const hoje = new Date().toISOString().split('T')[0];
    if (fornDataField) { fornDataField.max = hoje; if (!fornDataField.value) fornDataField.value = hoje; }
    const fornCpfField = document.getElementById('contratoFornecedorCPF');
    if (fornCpfField && fornCpfField.value) mascararCpfCnpj(fornCpfField);
    verificarCamposFornecedor();
    openModal('modalContratoFornecedor');
}

// Remove caracteres inválidos do campo de nome no contrato do fornecedor
function filtrarNome(el) {
    const pos = el.selectionStart;
    const cleaned = el.value.replace(/[^a-zA-ZÀ-ÿ\s''-]/g, '');
    if (cleaned !== el.value) { el.value = cleaned; el.setSelectionRange(pos - 1, pos - 1); }
}

// Aplica máscara de CPF ao campo durante digitação
function mascararCpfCnpj(el) {
    const d = el.value.replace(/\D/g, '').slice(0, 11);
    const n = d.length;
    let m = '';
    if      (n <= 3)  m = d;
    else if (n <= 6)  m = d.slice(0,3) + '.' + d.slice(3);
    else if (n <= 9)  m = d.slice(0,3) + '.' + d.slice(3,6) + '.' + d.slice(6);
    else              m = d.slice(0,3) + '.' + d.slice(3,6) + '.' + d.slice(6,9) + '-' + d.slice(9);
    el.value = m;
}

// Habilita o botão de aceitar contrato quando todos os campos obrigatórios estão preenchidos
function verificarCamposFornecedor() {
    const nome  = document.getElementById('contratoFornecedorNome')?.value.trim();
    const cpf   = document.getElementById('contratoFornecedorCPF')?.value.trim();
    const data  = document.getElementById('contratoFornecedorData')?.value.trim();
    const check = document.getElementById('checkContratoFornecedor')?.checked;
    const nomeValido = nome  && nome.split(/\s+/).filter(w => w.length > 0).length >= 2;
    const digits     = cpf ? cpf.replace(/\D/g, '') : '';
    const cpfValido  = digits.length === 11;
    document.getElementById('btnAceitarContratoFornecedor').disabled = !(nomeValido && cpfValido && data && check);
}

// Fecha o contrato e abre o modal de envio de proposta com os dados preenchidos
function confirmarContratoFornecedor() {
    closeModal('modalContratoFornecedor');
    if (_propostaIdPendente === null) return;

    document.getElementById('hidPropostaId').value = _propostaIdPendente;
    const msgArea = document.querySelector('#formProposta textarea[name="Mensagem"]');
    if (msgArea) msgArea.value = '';

    // Orçamento — exibir valor ou fallback
    const orcEl  = document.getElementById('propOrcamentoVal');
    const orcHid = document.getElementById('propValor');
    if (_orcamentoServico && parseFloat(_orcamentoServico) > 0) {
        const v = parseFloat(_orcamentoServico);
        orcEl.textContent  = `R$ ${v.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2})}`;
        orcHid.value = _orcamentoServico;
    } else {
        orcEl.textContent = 'A definir';
        orcHid.value = '0';
    }

    // Data de entrega — só mostra se o cliente não definiu prazo
    const propDataSection = document.getElementById('propDataSection');
    const propData        = document.getElementById('propData');
    const amanha = new Date(); amanha.setDate(amanha.getDate() + 1);
    propData.min = amanha.toISOString().split('T')[0];

    if (_clienteNaoSabe) {
        propData.value    = '';
        propData.required = true;
        propDataSection.classList.remove('hidden');
    } else {
        propData.required = false;
        propData.value    = '';
        propDataSection.classList.add('hidden');
    }

    MsVal.limpar(document.getElementById('formProposta'));
    openModal('modalProposta');
}

document.getElementById('formProposta')?.addEventListener('submit', function(e) {
    if (!MsVal.form(this)) e.preventDefault();
});


// Abre o modal de avaliação da plataforma para o fornecedor
function abrirSistemaForn(id) {
    document.getElementById('hidSistemaFornId').value = id;
    document.getElementById('hidEstrelasFornSist').value = '0';
    document.getElementById('btnSubmitFornSist').disabled = true;
    document.querySelectorAll('.star-forn-sist').forEach(b => b.style.color = 'var(--text-muted)');
    openModal('modalAvaliarSistemaForn');
}
function selecionarStarsFornSist(val) {
    document.getElementById('hidEstrelasFornSist').value = val;
    document.getElementById('btnSubmitFornSist').disabled = false;
    document.querySelectorAll('.star-forn-sist').forEach(b => {
        b.style.color = parseInt(b.dataset.val) <= val ? 'var(--brown)' : 'var(--text-muted)';
    });
}
</script>
}
