@model List<MindSite.Entities.Servico>
@{
    ViewData["Title"] = "Serviços";
    Layout = "_LayoutSupplier";
    string filtro = ViewBag.Filtro ?? "disponiveis";
    int userId = (int)(ViewBag.UserId ?? 0);

    var tipoNome = new Dictionary<MindSite.Enums.TipoServico, string> {
        { MindSite.Enums.TipoServico.Ecommerce,         "E-commerce" },
        { MindSite.Enums.TipoServico.Blog,              "Blog" },
        { MindSite.Enums.TipoServico.Designing,         "Web Design" },
        { MindSite.Enums.TipoServico.Marketing,         "Marketing" },
        { MindSite.Enums.TipoServico.SiteInstitucional, "Sites Institucionais" },
        { MindSite.Enums.TipoServico.LandingPage,       "Landing Pages" },
        { MindSite.Enums.TipoServico.OnePage,           "One-Page Sites" },
        { MindSite.Enums.TipoServico.Portfolio,         "Portfólios Digitais" },
        { MindSite.Enums.TipoServico.BlogPortal,        "Blogs e Portais" },
        { MindSite.Enums.TipoServico.PlataformaEAD,     "Plataformas EAD" },
        { MindSite.Enums.TipoServico.LinkBio,           "Links para Bio" },
        { MindSite.Enums.TipoServico.SistemaWeb,        "Sistemas Web" },
        { MindSite.Enums.TipoServico.Agendamento,       "Agendamento" },
        { MindSite.Enums.TipoServico.MultiIdioma,       "Multi-idiomas" },
        { MindSite.Enums.TipoServico.Redesign,          "Redesign" },
        { MindSite.Enums.TipoServico.Manutencao,        "Manutenção" },
        { MindSite.Enums.TipoServico.SEO,               "SEO & Performance" },
        { MindSite.Enums.TipoServico.Migracao,          "Migração" }
    };
}

@* Modal contrato do fornecedor *@
<div id="modalContratoFornecedor" class="modal-overlay hidden fixed inset-0 z-[60] flex items-center justify-center" aria-modal="true" role="dialog" aria-labelledby="contratoFornecedorTitulo">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="modal-box relative ms-card w-full max-w-2xl mx-4 z-10 flex flex-col" style="max-height:90vh">
        <div class="px-8 py-5 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div>
                <h3 id="contratoFornecedorTitulo" class="font-inria font-bold text-xl" style="color:var(--text)">Termo de Compromisso</h3>
                <p class="text-xs mt-0.5" style="color:var(--text-muted)">Leia com atenção antes de prosseguir</p>
            </div>
            <svg class="w-7 h-7 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brown)" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
        </div>

        <div class="flex-1 overflow-y-auto px-8 py-6 text-sm leading-relaxed" style="color:var(--text)">
            <p class="font-bold text-base mb-5" style="color:var(--brown)">CONTRATO FORNECEDOR</p>
            <div class="flex flex-col gap-5">
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Responsabilidades</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>Cumprir prazos;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Entregar conforme escopo;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Manter comunicação profissional;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Respeitar direitos autorais;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Manter sigilo das informações.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Pagamento</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>Liberação parcial conforme política da plataforma;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Pagamento final após aprovação do cliente;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Taxas da plataforma poderão ser descontadas.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Não é permitido</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>Abandonar projetos;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Solicitar pagamentos externos;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Compartilhar dados confidenciais;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Utilizar materiais ilegais.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Cancelamento</p>
                    <p class="mb-2" style="color:var(--text-muted)">O abandono injustificado poderá gerar:</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>bloqueio da conta;</span></li>
                        <li class="flex gap-2"><span>●</span><span>perda de valores;</span></li>
                        <li class="flex gap-2"><span>●</span><span>avaliações negativas;</span></li>
                        <li class="flex gap-2"><span>●</span><span>responsabilização judicial.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Direitos do Projeto</p>
                    <p style="color:var(--text-muted)">Os direitos autorais são transferidos ao cliente após pagamento integral.</p>
                </div>
                <div class="border-t pt-4" style="border-color:var(--border)">
                    <p class="font-semibold mb-3" style="color:var(--text)">Assinatura de Consentimento</p>
                    <div class="flex flex-col gap-3">
                        <div>
                            <label class="text-xs font-bold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Nome</label>
                            <input type="text" id="contratoFornecedorNome" class="ms-input" placeholder="Seu nome completo"
                                   value="@(ViewBag.NomeCompleto ?? "")" maxlength="100"
                                   oninput="filtrarNome(this);verificarCamposFornecedor()"/>
                        </div>
                        <div>
                            <label class="text-xs font-bold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">CPF</label>
                            <input type="text" id="contratoFornecedorCPF" class="ms-input" placeholder="000.000.000-00"
                                   value="@(ViewBag.CPF ?? "")" inputmode="numeric" maxlength="14"
                                   oninput="mascararCpfCnpj(this);verificarCamposFornecedor()"/>
                        </div>
                        <div>
                            <label class="text-xs font-bold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Data</label>
                            <input type="date" id="contratoFornecedorData" class="ms-input" oninput="verificarCamposFornecedor()" readonly/>
                        </div>
                    </div>
                    <label class="flex items-start gap-3 cursor-pointer pt-3 mt-1 border-t" style="border-color:var(--border)">
                        <input type="checkbox" id="checkContratoFornecedor" class="w-5 h-5 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]"
                               onchange="verificarCamposFornecedor()"/>
                        <span class="text-sm" style="color:var(--text)">Li e concordo com todos os termos do contrato acima e me comprometo a cumprir as obrigações descritas na prestação deste serviço.</span>
                    </label>
                </div>
            </div>
        </div>

        <div class="px-8 py-5 border-t flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div class="flex gap-3">
                <button type="button" onclick="closeModal('modalContratoFornecedor')" class="btn-ghost flex-1">Cancelar</button>
                <button type="button" id="btnAceitarContratoFornecedor" disabled
                        onclick="confirmarContratoFornecedor()"
                        class="btn-primary flex-1 disabled:opacity-40 disabled:cursor-not-allowed">
                    Aceitar Contrato
                </button>
            </div>
        </div>
    </div>
</div>

@* Modal submeter proposta *@
<div id="modalProposta" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="modal-box relative ms-card p-8 w-full max-w-md mx-4 z-10">
        <button onclick="closeModal('modalProposta')" class="absolute top-4 right-4" style="color:var(--text-muted)" aria-label="Fechar">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <h3 class="font-inria text-2xl font-bold mb-1" style="color:var(--text)">Aceitar fazer</h3>
        <p class="text-xs mb-5" style="color:var(--text-muted)">Ao confirmar, você se compromete a realizar este projeto pelo orçamento definido.</p>
        <form id="formProposta" asp-controller="Supplier" asp-action="SubmeterProposta" method="post" class="flex flex-col gap-4">
            @Html.AntiForgeryToken()
            <input type="hidden" id="hidPropostaId" name="ServicoId"/>
            <input type="hidden" id="propValor"     name="Valor" value="0"/>

            @* Orçamento (somente leitura) *@
            <div class="rounded-xl px-4 py-3" style="background:var(--bg2)">
                <p class="text-xs font-bold uppercase tracking-wider mb-0.5" style="color:var(--text-muted)">Orçamento do projeto</p>
                <p id="propOrcamentoVal" class="font-semibold text-base" style="color:var(--brown)">—</p>
            </div>

            @* Data de entrega — só visível quando o cliente não definiu prazo *@
            <div id="propDataSection">
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Prazo de entrega *</label>
                <div id="propDataWrap" class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 pointer-events-none" style="color:var(--text-muted)">
                        <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M8 7V3m8 4V3m-9 8h10M5 21h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v12a2 2 0 002 2z"/>
                        </svg>
                    </span>
                    <input id="propData" type="date" name="DataEntrega" class="ms-input pl-10"/>
                </div>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Mensagem ao cliente</label>
                <textarea name="Mensagem" class="ms-textarea" rows="3" placeholder="Apresente sua abordagem para o projeto..."></textarea>
            </div>
            <div class="flex gap-3 mt-2">
                <button type="button" onclick="closeModal('modalProposta')" class="btn-ghost flex-1">Cancelar</button>
                <button type="submit" class="btn-primary flex-1">Aceitar fazer</button>
            </div>
        </form>
    </div>
</div>

@* MODAL AVALIAR PLATAFORMA (fornecedor) *@
<div id="modalAvaliarSistemaForn" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10">
        <button onclick="closeModal('modalAvaliarSistemaForn')" class="absolute top-4 right-4" style="color:var(--text-muted)" aria-label="Fechar">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <h3 class="font-inria text-2xl font-bold mb-1" style="color:var(--text)">Avaliar a Plataforma</h3>
        <p class="text-sm mb-5" style="color:var(--text-muted)">Como foi sua experiência com o MindSite neste projeto?</p>
        <form asp-controller="Supplier" asp-action="AvaliarSistema" method="post" class="flex flex-col gap-4">
            @Html.AntiForgeryToken()
            <input type="hidden" id="hidSistemaFornId" name="ServicoId"/>
            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Estrelas</label>
                <div class="flex gap-2" id="starsFornSist">
                    @for (int i = 1; i <= 5; i++)
                    {
                        <button type="button" data-val="@i" class="star-forn-sist text-3xl transition-colors" style="color:var(--text-muted)" onclick="selecionarStarsFornSist(@i)">★</button>
                    }
                </div>
                <input type="hidden" name="Estrelas" id="hidEstrelasFornSist" value="0"/>
            </div>
            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Comentário (opcional)</label>
                <textarea name="Comentario" class="ms-textarea" rows="3" placeholder="Descreva sua experiência com a plataforma..."></textarea>
            </div>
            <div class="flex gap-3">
                <button type="button" onclick="closeModal('modalAvaliarSistemaForn')" class="btn-ghost flex-1">Cancelar</button>
                <button type="submit" id="btnSubmitFornSist" class="btn-primary flex-1" disabled>Enviar</button>
            </div>
        </form>
    </div>
</div>
