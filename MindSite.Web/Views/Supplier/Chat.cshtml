@model MindSite.ViewModels.ChatViewModel
@{
    ViewData["Title"] = "Chat";
    Layout = "_LayoutSupplier";
    var pinadosIds = Model.ContatosPinados.Select(c => c.Id).ToHashSet();
}

@section Styles {
<style>
#msgBox::-webkit-scrollbar { width:4px; }
#msgBox::-webkit-scrollbar-thumb { background:var(--chat-scrollbar); border-radius:4px; }
#msgBox::-webkit-scrollbar-track { background:transparent; }
</style>
}

@* Modal visualizar mudança *@
<div id="modalVisualizarMudanca" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalVisualizarMudanca')"></div>
    <div class="relative w-full max-w-lg mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Visualizar Mudança</h3>
        </div>
        <div class="px-6 py-5">
            <div id="vmConteudo" class="flex flex-col gap-3 text-sm" style="color:var(--text)">
                <p style="color:var(--text-muted)">Carregando...</p>
            </div>
        </div>
        <input type="hidden" id="vmMudancaId"/>
        <div id="vmAcoes" class="px-6 pb-6 gap-3" style="display:none">
            <button onclick="aceitarMudanca()" class="flex-1 py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:#16a34a">Aceitar</button>
            <button onclick="abrirJustificativa()" class="flex-1 py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:#ef4444;color:#ef4444;background:transparent">Rejeitar</button>
        </div>
    </div>
</div>

@* Modal justificativa de rejeição *@
<div id="modalJustificativa" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalJustificativa')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Justificativa da Rejeição</h3>
            <p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.65)">Explique ao cliente por que a mudança não pode ser realizada.</p>
        </div>
        <div class="px-6 py-5 flex flex-col gap-3">
            <div id="erroJustificativa" class="hidden rounded-xl px-4 py-3 text-sm" style="background:var(--error-bg);color:#ef4444"></div>
            <textarea id="txtJustificativa" class="ms-textarea w-full" rows="4" placeholder="Descreva o motivo da rejeição..."></textarea>
        </div>
        <div class="px-6 pb-6 flex gap-3">
            <button onclick="closeModal('modalJustificativa')" class="flex-1 py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Cancelar</button>
            <button id="btnEnviarRejeicao" onclick="enviarRejeicao()" class="flex-1 py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:#ef4444">Enviar</button>
        </div>
    </div>
</div>

@* Modal detalhes do serviço (supplier) *@
<div id="supModalServicoInfo" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('supModalServicoInfo')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Detalhes do Serviço</h3>
        </div>
        <div class="px-6 py-5">
            <div id="supSiInfos" class="flex flex-col gap-3 text-sm" style="color:var(--text)"></div>
        </div>
        <div class="px-6 pb-6">
            <button onclick="closeModal('supModalServicoInfo')" class="w-full py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Fechar</button>
        </div>
    </div>
</div>

@* Modal confirmar desistência *@
<div id="supModalDesistir" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('supModalDesistir')"></div>
    <div class="relative w-full max-w-sm mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4 text-center" style="background:var(--brown)">
            <p class="font-bold text-white text-base">Desistir do Serviço</p>
        </div>
        <div class="px-6 py-5 text-center">
            <p class="text-sm" style="color:var(--text-muted)">Tem certeza que deseja desistir deste projeto? O cliente será notificado e reembolsado. Esta ação não pode ser desfeita.</p>
        </div>
        <div class="px-6 pb-6 flex gap-3">
            <button onclick="closeModal('supModalDesistir')" class="flex-1 py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Cancelar</button>
            <form id="formDesistir" method="post" action="/Supplier/DesistirProjeto" class="flex-1">
                @Html.AntiForgeryToken()
                <input type="hidden" id="desistirServicoId" name="id" value="0"/>
                <button type="submit" class="w-full py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:#ef4444">Confirmar</button>
            </form>
        </div>
    </div>
</div>

@* Modal sucesso mudança *@
<div id="modalSucessoMudanca" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalSucessoMudanca')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:#16a34a">
            <h3 class="font-bold text-white text-base flex items-center gap-2">
                ✓ Mudança Aceita
            </h3>
        </div>
        <div class="px-6 py-6 text-center">
            <div class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center text-3xl shadow-inner" style="background:var(--success-bg); color:#16a34a">
                ✓
            </div>
            <p class="text-sm font-medium mb-1" style="color:var(--text)">Proposta aceita com sucesso!</p>
            <p class="text-xs" style="color:var(--text-muted)">O administrador do sistema será notificado para realizar o processamento dos novos valores.</p>
        </div>
        <div class="px-6 pb-6 flex">
            <button onclick="closeModal('modalSucessoMudanca')" class="flex-1 py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:var(--brown)">
                Entendido
            </button>
        </div>
    </div>
</div>

@* Modal erro arquivo/geral *@
<div id="modalErroArquivo" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalErroArquivo')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:#ef4444">
            <h3 class="font-bold text-white text-base flex items-center gap-2">
                ✕ Ops! Algo deu errado
            </h3>
        </div>
        <div class="px-6 py-6 text-center">
            <div class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center text-2xl font-bold shadow-inner" style="background:var(--error-bg); color:#ef4444">
                ✕
            </div>
            <p id="txtErroArquivo" class="text-sm font-medium" style="color:var(--text)">
                Erro ao processar a requisição.
            </p>
        </div>
        <div class="px-6 pb-6 flex">
            <button onclick="closeModal('modalErroArquivo')" class="flex-1 py-2.5 rounded-xl font-bold border-2 transition hover:opacity-80" style="border-color:#ef4444; color:#ef4444; background:transparent">
                Fechar
            </button>
        </div>
    </div>
</div>

@* Modal ver contratos/termos *@
<div id="supModalVerContratos" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeModal('supModalVerContratos')"></div>
    <div class="modal-box relative ms-card w-full max-w-2xl mx-4 z-10 flex flex-col" style="max-height:90vh">
        <div class="px-6 py-4 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div>
                <h3 class="font-inria font-bold text-lg" style="color:var(--text)">Contratos &amp; Termos</h3>
                <p class="text-xs mt-0.5" style="color:var(--text-muted)">Documentos assinados e termos da plataforma</p>
            </div>
            <button onclick="closeModal('supModalVerContratos')" style="color:var(--text-muted)" aria-label="Fechar">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex border-b flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <button id="supVcTabFornecedor" onclick="supMudarAbaContrato('fornecedor')" class="flex-1 text-xs font-bold uppercase tracking-wider px-3 py-3 border-b-2 transition-colors" style="border-color:var(--brown);color:var(--brown)">Contrato Fornecedor</button>
            <button id="supVcTabCliente" onclick="supMudarAbaContrato('cliente')" class="flex-1 text-xs font-bold uppercase tracking-wider px-3 py-3 border-b-2 border-transparent transition-colors" style="color:var(--text-muted)">Contrato Cliente</button>
            <button id="supVcTabTermos" onclick="supMudarAbaContrato('termos')" class="flex-1 text-xs font-bold uppercase tracking-wider px-3 py-3 border-b-2 border-transparent transition-colors" style="color:var(--text-muted)">Termos da Plataforma</button>
        </div>
        <div class="flex-1 overflow-y-auto px-6 py-6 text-sm leading-relaxed" style="color:var(--text)">
            @{
                string supFornNome = Model.UsuarioAtual.NomeCompleto;
                string supFornCPF  = Model.UsuarioAtual.CPF ?? "—";
                string supFornData = Model.UsuarioAtual.AceitouContratoFornecedorEm?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—";
                string supCliNome  = Model.ContatoSelecionado?.NomeCompleto ?? "—";
                string supCliCPF   = Model.ContatoSelecionado?.CPF ?? "—";
                string supCliData  = Model.ContatoSelecionado?.AceitouContratoClienteEm?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—";
            }
            @* Aba contrato fornecedor *@
            <div id="supVcAbaFornecedor">
                <p class="font-bold text-base mb-5" style="color:var(--brown)">CONTRATO FORNECEDOR</p>
                <div class="flex flex-col gap-4">
                    <div><p class="font-semibold mb-1">Responsabilidades</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● Cumprir prazos;</span></li><li class="flex gap-2"><span>● Entregar conforme escopo;</span></li><li class="flex gap-2"><span>● Manter comunicação profissional;</span></li><li class="flex gap-2"><span>● Respeitar direitos autorais;</span></li><li class="flex gap-2"><span>● Manter sigilo das informações.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Pagamento</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● Liberação parcial conforme política da plataforma;</span></li><li class="flex gap-2"><span>● Pagamento final após aprovação do cliente;</span></li><li class="flex gap-2"><span>● Taxas da plataforma poderão ser descontadas.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Não é permitido</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● Abandonar projetos;</span></li><li class="flex gap-2"><span>● Solicitar pagamentos externos;</span></li><li class="flex gap-2"><span>● Compartilhar dados confidenciais;</span></li><li class="flex gap-2"><span>● Utilizar materiais ilegais.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Cancelamento</p><p class="mb-1" style="color:var(--text-muted)">O abandono injustificado poderá gerar:</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● bloqueio da conta;</span></li><li class="flex gap-2"><span>● perda de valores;</span></li><li class="flex gap-2"><span>● avaliações negativas;</span></li><li class="flex gap-2"><span>● responsabilização judicial.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Direitos do Projeto</p><p style="color:var(--text-muted)">Os direitos autorais são transferidos ao cliente após pagamento integral.</p></div>
                    <div class="border-t pt-4" style="border-color:var(--border)">
                        <p class="font-semibold mb-3">Assinatura de Consentimento</p>
                        <div class="flex flex-col gap-1" style="color:var(--text-muted)">
                            <p><span class="font-semibold" style="color:var(--text)">Nome:</span> @supFornNome</p>
                            <p><span class="font-semibold" style="color:var(--text)">CPF/CNPJ:</span> @supFornCPF</p>
                            <p><span class="font-semibold" style="color:var(--text)">Data:</span> @supFornData</p>
                        </div>
                    </div>
                </div>
            </div>
            @* Aba contrato cliente *@
            <div id="supVcAbaCliente" class="hidden">
                <p class="font-bold text-base mb-5" style="color:var(--brown)">CONTRATO CLIENTE</p>
                <div class="flex flex-col gap-4">
                    <div><p class="font-semibold mb-1">Responsabilidades</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● Enviar informações corretas;</span></li><li class="flex gap-2"><span>● Fornecer materiais necessários;</span></li><li class="flex gap-2"><span>● Responder solicitações no prazo;</span></li><li class="flex gap-2"><span>● Realizar pagamentos conforme combinado.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Pagamento</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● 30% no início do projeto;</span></li><li class="flex gap-2"><span>● 70% após aprovação final;</span></li><li class="flex gap-2"><span>● Taxas bancárias podem ser aplicadas em estornos.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Não é permitido</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● Solicitar conteúdos ilegais;</span></li><li class="flex gap-2"><span>● Tentar negociar fora da plataforma;</span></li><li class="flex gap-2"><span>● Utilizar o sistema de forma abusiva;</span></li><li class="flex gap-2"><span>● Praticar fraudes.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Cancelamento</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>● Antes do início: poderá haver retenção de taxas;</span></li><li class="flex gap-2"><span>● Após início: valores poderão ser proporcionais ao trabalho executado.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Mediação</p><p style="color:var(--text-muted)">A MindSite poderá analisar mensagens, arquivos e entregas em casos de disputa.</p></div>
                    <div class="border-t pt-4" style="border-color:var(--border)">
                        <p class="font-semibold mb-3">Assinatura de Consentimento</p>
                        <div class="flex flex-col gap-1" style="color:var(--text-muted)">
                            <p><span class="font-semibold" style="color:var(--text)">Nome:</span> @supCliNome</p>
                            <p><span class="font-semibold" style="color:var(--text)">CPF/CNPJ:</span> @supCliCPF</p>
                            <p><span class="font-semibold" style="color:var(--text)">Data:</span> @supCliData</p>
                        </div>
                    </div>
                </div>
            </div>
            @* Aba termos da plataforma *@
            <div id="supVcAbaTermos" class="hidden">
                <p class="font-bold text-base mb-5" style="color:var(--brown)">TERMOS DA PLATAFORMA</p>
                <div class="flex flex-col gap-4">
                    <div>
                        <p class="font-semibold mb-2">A MindSite é responsável por</p>
                        <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                            <li class="flex gap-2"><span>● intermediar projetos;</span></li>
                            <li class="flex gap-2"><span>● organizar pagamentos;</span></li>
                            <li class="flex gap-2"><span>● registrar comunicações;</span></li>
                            <li class="flex gap-2"><span>● aplicar políticas antifraude;</span></li>
                            <li class="flex gap-2"><span>● proteger dados conforme LGPD.</span></li>
                        </ul>
                    </div>
                    <div>
                        <p class="font-semibold mb-2">Segurança da Plataforma</p>
                        <p class="mb-2" style="color:var(--text-muted)">Contas poderão ser suspensas em casos de:</p>
                        <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                            <li class="flex gap-2"><span>● fraude;</span></li>
                            <li class="flex gap-2"><span>● inadimplência;</span></li>
                            <li class="flex gap-2"><span>● abuso da plataforma;</span></li>
                            <li class="flex gap-2"><span>● tentativa de burlar taxas;</span></li>
                            <li class="flex gap-2"><span>● atividades ilegais.</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="px-6 py-4 border-t flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <button onclick="closeModal('supModalVerContratos')" class="btn-ghost w-full">Fechar</button>
        </div>
    </div>
</div>

<form id="afToken" class="hidden">@Html.AntiForgeryToken()</form>

<div class="mx-4 md:mx-6 my-4">

    <div class="chat-outer-wrap flex ms-card gap-4 bg-[#F4F2ED] border-none overflow-hidden" style="height:calc(100vh - 112px)">

        @* Conversas *@
        <div class="chat-contacts-panel @((Model.ContatoSelecionado != null || Model.IsGrupoSuporte) ? "hidden md:flex md:w-80 md:min-w-[260px] bg-white rounded-2xl border border-[#6B462C]/15 shadow-sm overflow-hidden" : "flex w-full md:w-80") flex-col flex-shrink-0" style="border-right:1.5px solid color-mix(in srgb, var(--brown) 30%, transparent)">
            @{
                string supMeIni = string.Join("", Model.UsuarioAtual.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
            }
            <div class="p-4 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background:var(--brown);color:#fff">@supMeIni.ToUpper()</div>
                    <div class="min-w-0">
                        <p class="font-bold text-sm truncate" style="color:var(--text)">@Model.UsuarioAtual.NomeCompleto</p>
                        <p class="text-xs" style="color:var(--text-muted)">Minha conta</p>
                    </div>
                </div>
                <div class="relative flex-shrink-0">
                    <button id="filterMenuBtn" class="p-1.5 rounded-lg hover:opacity-70 transition-opacity" style="color:var(--text-muted)" aria-label="Filtrar">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
                        </svg>
                    </button>
                    <div id="filterDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:230px">
                        <div class="px-4 pt-3 pb-2">
                            <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Filtrar por</p>
                        </div>
                        <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70" data-filter="nome" style="color:var(--text)">Nome do Cliente</button>
                        <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70" data-filter="recente" style="color:var(--text)">Conversas Recentes</button>
                    </div>
                </div>
            </div>
            <div class="px-4 py-3 border-b flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                <input type="text" placeholder="Pesquisar conversa..." oninput="filtrarContatos(this.value)"
                       class="ms-input text-sm w-full" style="border-radius:.75rem" aria-label="Buscar conversa"/>
            </div>
            <div class="flex-1 overflow-y-auto">

                @* Suporte MindSite — entrada única do grupo *@
                <div class="px-4 pt-3 pb-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Suporte</p>
                </div>
                <a href="?grupoSuporte=true"
                   class="contact-item flex items-center gap-3 p-4 @(Model.IsGrupoSuporte ? "active" : "")"
                   aria-label="Suporte MindSite">
                    <div class="relative flex-shrink-0 w-10 h-10 rounded-full overflow-hidden flex items-center justify-center"
                         class="ms-suporte-logo">
                        <img src="/img/logo_img.png" alt="MindSite" class="w-9 h-9 object-contain"/>
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline gap-1">
                            <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">Suporte MindSite</span>
                            @if (Model.GrupoUltimaData.HasValue) {
                                <span class="text-[10px] flex-shrink-0" style="color:var(--text-muted)">
                                    @(Model.GrupoUltimaData.Value.Date == DateTime.UtcNow.Date
                                        ? Model.GrupoUltimaData.Value.ToLocalTime().ToString("HH:mm")
                                        : Model.GrupoUltimaData.Value.ToLocalTime().ToString("dd/MM"))
                                </span>
                            }
                        </div>
                        <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">
                            @(Model.GrupoUltimaMensagem != "" ? Model.GrupoUltimaMensagem : "● Equipe de suporte")
                        </p>
                    </div>
                </a>

                @* Meus Clientes *@
                @{
                    var pClients = Model.ContatosPinados.ToList();
                }
                @if (pClients.Any())
                {
                    <div class="mx-4 my-1 border-t" style="border-color:var(--border)"></div>
                    <div class="px-4 py-1">
                        <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Meus Clientes</p>
                    </div>
                    @foreach (var cli in pClients)
                    {
                        string ini = string.Join("", cli.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                        bool act  = cli.Id == Model.ContatoSelecionadoId;
                        var nl    = Model.Conversas.FirstOrDefault(c => c.Contato.Id == cli.Id)?.NaoLidas ?? 0;
                        var ult   = Model.Conversas.FirstOrDefault(c => c.Contato.Id == cli.Id)?.UltimaMensagem ?? "";
                        var qnd   = Model.Conversas.FirstOrDefault(c => c.Contato.Id == cli.Id)?.Quando;
                        <a href="?contatoId=@cli.Id"
                           class="contact-item flex items-center gap-3 p-4 @(act ? "active" : "")"
                           aria-label="Cliente: @cli.NomeCompleto">
                            <div class="relative">
                                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold"
                                     style="background:var(--brown);color:#fff">@ini.ToUpper()</div>
                                @if (cli.IsOnline) { <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2" style="background:#16a34a;border-color:var(--bg)"></span> }
                            </div>
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-baseline">
                                    <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@cli.NomeCompleto</span>
                                    @if (qnd.HasValue) {
                                        <span class="text-[10px] ml-1 flex-shrink-0" style="color:var(--text-muted)">
                                            @(qnd.Value.Date == DateTime.UtcNow.Date ? qnd.Value.ToLocalTime().ToString("HH:mm") : qnd.Value.ToLocalTime().ToString("dd/MM"))
                                        </span>
                                    }
                                </div>
                                <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@ult</p>
                            </div>
                            @if (nl > 0) { <span class="w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center" style="background:var(--brown);color:#fff">@nl</span> }
                        </a>
                    }
                }

                @if (Model.Conversas.Any(c => !pinadosIds.Contains(c.Contato.Id)))
                {
                    <div class="mx-4 my-1 border-t" style="border-color:var(--border)"></div>
                    <div class="px-4 py-1">
                        <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Outras Conversas</p>
                    </div>
                }

                @foreach (var c in Model.Conversas.Where(cv => !pinadosIds.Contains(cv.Contato.Id)))
                {
                    string ini = string.Join("", c.Contato.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                    bool active = c.Contato.Id == Model.ContatoSelecionadoId;
                    <a href="?contatoId=@c.Contato.Id"
                       class="contact-item flex items-center gap-3 p-4 @(active ? "active" : "")"
                       aria-label="Conversa com @c.Contato.NomeCompleto">
                        <div class="relative">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                                 style="background:var(--brown);color:#fff">@ini.ToUpper()</div>
                            @if (c.Contato.IsOnline) { <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2" style="background:#16a34a;border-color:var(--bg)"></span> }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline">
                                <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@c.Contato.NomeCompleto</span>
                                @if (c.Quando.HasValue)
                                {
                                    <span class="text-[10px] ml-1 flex-shrink-0" style="color:var(--text-muted)">
                                        @(c.Quando.Value.Date == DateTime.UtcNow.Date ? c.Quando.Value.ToLocalTime().ToString("HH:mm") : c.Quando.Value.ToLocalTime().ToString("dd/MM"))
                                    </span>
                                }
                            </div>
                            <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@c.UltimaMensagem</p>
                        </div>
                        @if (c.NaoLidas > 0)
                        {
                            <span class="w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center flex-shrink-0"
                                  style="background:var(--brown);color:#fff">@c.NaoLidas</span>
                        }
                    </a>
                }

                @if (!Model.ContatosPinados.Any() && !Model.Conversas.Any())
                {
                    <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma conversa ainda</p>
                }
            </div>
        </div>

        @* Mensagens *@
        <div class="chat-msg-panel @((Model.ContatoSelecionado != null || Model.IsGrupoSuporte) ? "flex" : "hidden md:flex") flex-1 flex flex-col rounded-2xl overflow-hidden border border-[#6B462C]/20 shadow-sm bg-white min-w-0">
            @if (Model.ContatoSelecionado == null && !Model.IsGrupoSuporte)
            {
                <div class="flex-1 flex items-center justify-center flex-col gap-4" style="color:var(--text-muted)">
                    <svg class="w-16 h-16 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    <p class="text-base font-medium">Selecione uma conversa</p>
                </div>
            }
            else if (Model.IsGrupoSuporte)
            {
                <div class="px-4 py-3 border-b flex items-center gap-3" style="border-color:var(--border);background:var(--bg2)">
                    <a href="/Supplier/Chat" class="md:hidden p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0" style="color:var(--brown)" aria-label="Voltar">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    <div class="w-9 h-9 rounded-full overflow-hidden flex-shrink-0 flex items-center justify-center" class="ms-suporte-logo">
                        <img src="/img/logo_img.png" alt="MindSite" class="w-8 h-8 object-contain"/>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-sm" style="color:var(--text)">Suporte MindSite <span class="badge badge-brown text-[9px] ml-1">Grupo</span></p>
                        <p class="text-xs" style="color:var(--text-muted)">Equipe de suporte disponível</p>
                    </div>
                </div>
                <div id="msgBox" class="flex-1 overflow-y-auto p-5 space-y-3" style="background:var(--bg)">
                    @if (!Model.GrupoMensagens.Any()) {
                        <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma mensagem. Envie uma mensagem para o suporte!</p>
                    }
                    @foreach (var gm in Model.GrupoMensagens)
                    {
                        bool isMe = gm.RemetenteId == Model.UsuarioAtual.Id;
                        bool gmIsFile = gm.Conteudo.StartsWith("{\"_t\":\"F\"");
                        bool gmIsQ    = gm.Conteudo.StartsWith("{\"_t\":\"Q\"");
                        string gmUrl = "", gmNome = "", gmQRef = "", gmQMsg = "";
                        if (gmIsFile) {
                            try {
                                using var gdoc = System.Text.Json.JsonDocument.Parse(gm.Conteudo);
                                var gr = gdoc.RootElement;
                                gmUrl  = gr.TryGetProperty("url",  out var gu) ? (gu.GetString() ?? "") : "";
                                gmNome = gr.TryGetProperty("nome", out var gn) ? (gn.GetString() ?? "") : "";
                            } catch { gmIsFile = false; }
                        } else if (gmIsQ) {
                            try {
                                using var qdoc = System.Text.Json.JsonDocument.Parse(gm.Conteudo);
                                var qr = qdoc.RootElement;
                                gmQRef = qr.TryGetProperty("ref", out var qrf) ? (qrf.GetString() ?? "") : "";
                                gmQMsg = qr.TryGetProperty("msg", out var qmv) ? (qmv.GetString() ?? "") : "";
                            } catch { gmIsQ = false; }
                        }
                        string gmCtxData = gmIsFile ? "" : (gmIsQ ? gmQMsg : gm.Conteudo);
                        <div class="flex @(isMe ? "justify-end" : "justify-start") items-end gap-1 msg-animate msg-wrapper group"
                             data-msg-id="@gm.Id" data-is-me="@(isMe ? "true" : "false")"
                             data-conteudo="@gmCtxData" data-is-grupo="true">
                            @if (!isMe) {
                                <div class="w-7 h-7 rounded-full overflow-hidden flex-shrink-0 mr-2 self-start flex items-center justify-center">
                                    <img src="/img/logo_img.png" alt="MindSite" class="w-7 h-7 object-contain"/>
                                </div>
                            }
                            @if (isMe) {
                                <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                </button>
                            }
                            <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1 max-w-xs">
                                @if (!isMe) { <span class="msg-sender-name text-[10px] font-bold" style="color:var(--brown)">@gm.Remetente.NomeCompleto</span> }
                                @if (gmIsQ) {
                                    <div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)">
                                        <span class="text-[10px] truncate block" style="color:var(--text-muted)">@Html.Raw(System.Net.WebUtility.HtmlEncode(gmQRef.Length > 80 ? gmQRef[..80] + "…" : gmQRef))</span>
                                    </div>
                                    <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(gmQMsg).Replace("\n","<br>"))</span>
                                } else if (gmIsFile) {
                                    bool gmImg = new[] { ".png", ".jpg", ".jpeg" }.Contains(System.IO.Path.GetExtension(gmUrl).ToLowerInvariant());
                                    @if (gmImg) {
                                        <img src="@gmUrl" alt="@gmNome" class="max-w-[200px] rounded-lg cursor-pointer" onclick="abrirFileViewer('@gmUrl','@gmNome',@(isMe ? "true" : "false"))" style="max-height:150px;object-fit:cover"/>
                                    } else {
                                        <a href="#" onclick="abrirFileViewer('@gmUrl','@gmNome',@(isMe ? "true" : "false"));return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 @gmNome</a>
                                    }
                                } else {
                                    <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(gm.Conteudo).Replace("\n","<br>"))</span>
                                }
                                <span class="text-[10px] opacity-60 self-end">@gm.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                            @if (!isMe) {
                                <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                </button>
                            }
                        </div>
                    }
                </div>
                <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0">
                    <input type="file" id="fileInputGrupo" class="hidden" accept="image/png,image/jpeg,application/pdf,application/zip,.zip"/>
                    <div id="replyPreview" class="hidden mb-2 flex items-center gap-2 rounded-xl px-3 py-1.5" style="background:var(--brown-subtle)">
                        <div class="w-0.5 self-stretch rounded-full flex-shrink-0" style="background:var(--brown)"></div>
                        <span id="replyText" class="text-xs flex-1 truncate" style="color:var(--text-muted)"></span>
                        <button type="button" onclick="cancelarReply()" class="flex-shrink-0 p-0.5" style="color:var(--text-muted)"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                    </div>
                    <form id="chatForm" class="chat-input-form flex items-center gap-3 bg-[#F4F3EE] rounded-2xl border border-[#6B462C]/20 px-2 py-1.5 focus-within:border-[color:var(--border)]0 focus-within:ring-2 focus-within:ring-[#6B462C]/10 transition-all"
                          onsubmit="enviarGrupoMsg(event)">
                        <button type="button" onclick="document.getElementById('fileInputGrupo').click()"
                                class="chat-attach-btn text-[#8d6945] hover:text-[#4d392a] transition-colors flex-shrink-0 hover:scale-110 active:scale-95 p-2" title="Anexar arquivo">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9l-2 3H5a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                            </svg>
                        </button>
                        <textarea id="msgInput" rows="1" maxlength="4000"
                               class="chat-input-text flex-1 bg-transparent focus:outline-none text-sm text-[#4d392a] placeholder-[#8d6945]/60"
                               placeholder="Escreva sua mensagem..." autocomplete="off" aria-label="Mensagem para suporte"></textarea>
                        <button type="submit"
                                class="chat-send-btn bg-[#6B462C] text-white p-2 rounded-xl hover:bg-[#4d392a] transition-all hover:scale-105 active:scale-95 shadow-sm flex-shrink-0 m-1.5" title="Enviar">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M2.01 21L23 12L2.01 3L2 10l15 2l-15 2z"/>
                            </svg>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="px-4 py-3 border-b flex items-center gap-3" style="border-color:var(--border);background:var(--bg2)">
                    <a href="/Supplier/Chat" class="md:hidden p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0" style="color:var(--brown)" aria-label="Voltar">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                         style="background:@(Model.ContatoSelecionado.Role == UserRole.Admin ? "var(--admin-avatar)" : "var(--brown)");color:#fff">
                        @string.Join("", Model.ContatoSelecionado.NomeCompleto.Split(' ').Take(2).Select(p => p[0])).ToUpper()
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-sm" style="color:var(--text)">
                            @Model.ContatoSelecionado.NomeCompleto
                            @if (Model.ContatoSelecionado.Role == UserRole.Admin)
                            {
                                <span class="badge badge-red text-[9px] ml-1">Suporte</span>
                            }
                        </p>
                        <p class="text-xs" style="@(Model.ContatoSelecionado.IsOnline ? "color:#16a34a" : "color:var(--text-muted)")">
                            @(Model.ContatoSelecionado.IsOnline ? "● Online" : "○ Offline")
                        </p>
                    </div>
                    <div class="relative flex-shrink-0">
                        <button id="supChatMenuBtn" class="p-2 rounded-lg hover:opacity-70 transition-opacity" style="color:var(--text-muted)" aria-label="Opções">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                        </button>
                        <div id="supChatMenuDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:210px">
                            <button onclick="supFalarComSuporte()" class="w-full text-left px-4 py-2.5 text-sm hover:bg-[var(--bg2)] flex items-center gap-2 border-b border-[color:var(--border)]" style="color:var(--text)">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                Falar com suporte
                            </button>
                            <button onclick="supVerServicoInfo()" class="w-full text-left px-4 py-2.5 text-sm hover:bg-[var(--bg2)] flex items-center gap-2 border-b border-[color:var(--border)]" style="color:var(--text)">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                Detalhes do Serviço
                            </button>
                            <button onclick="supVerContratosTermos()" class="w-full text-left px-4 py-2.5 text-sm hover:bg-[var(--bg2)] flex items-center gap-2 border-b border-[color:var(--border)]" style="color:var(--text)">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                Ver contratos/termos
                            </button>
                            <button onclick="supDesistirServico()" class="w-full text-left px-4 py-2.5 text-sm text-red-600 hover:bg-red-100 flex items-center gap-2">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17 16l4-4m0 0l-4-4m4 4H7m6 4v1a3 3 0 01-3 3H6a3 3 0 01-3-3V7a3 3 0 013-3h4a3 3 0 013 3v1"/></svg>
                                Desistir do Serviço
                            </button>
                        </div>
                    </div>
                </div>

                <div id="msgBox" class="flex-1 overflow-y-auto p-5 space-y-3" style="background:var(--bg)">
                    @if (!Model.Mensagens.Any())
                    {
                        <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma mensagem. Diga olá!</p>
                    }
                    @{ DateTime? lastSupDate = null; }
                    @foreach (var m in Model.Mensagens)
                    {
                        var sDate = m.EnviadaEm.ToLocalTime().Date;
                        if (lastSupDate == null || lastSupDate.Value != sDate) {
                            lastSupDate = sDate;
                            string sLabel = sDate == DateTime.Now.Date ? "Hoje" : sDate == DateTime.Now.Date.AddDays(-1) ? "Ontem" : sDate.ToString("dd/MM/yyyy");
                            <div class="flex items-center justify-center my-2">
                                <span class="text-[11px] px-3 py-1 rounded-full" style="background:var(--bg2);color:var(--text-muted)">@sLabel</span>
                            </div>
                        }
                        bool isMe = m.RemetenteId == Model.UsuarioAtual.Id;
                        bool isSpecial = m.Conteudo.StartsWith("{\"_t\":\"");
                        string mType = "", mId = "", mR = "", mJ = "", mV = "", mUrl = "", mNome = "", mQRef = "", mQMsg = "";
                        bool mAceita = false, mRecusada = false;
                        if (isSpecial)
                        {
                            try
                            {
                                using var doc = System.Text.Json.JsonDocument.Parse(m.Conteudo);
                                var root = doc.RootElement;
                                mType    = root.TryGetProperty("_t",  out var t)   ? (t.GetString()   ?? "") : "";
                                mId      = root.TryGetProperty("id",  out var mid) ? mid.GetInt32().ToString() : "";
                                mR       = root.TryGetProperty("r",   out var r)   ? (r.GetString()   ?? "") : "";
                                mJ       = root.TryGetProperty("j",   out var j)   ? (j.GetString()   ?? "") : "";
                                mV       = root.TryGetProperty("v",   out var v)   ? (v.GetString()   ?? "") : "";
                                mAceita  = root.TryGetProperty("aceita",   out var a) && a.GetBoolean();
                                mRecusada = root.TryGetProperty("recusada", out var rc) && rc.GetBoolean();
                                mUrl  = root.TryGetProperty("url",  out var mu)  ? (mu.GetString()  ?? "") : "";
                                mNome = root.TryGetProperty("nome", out var mn)  ? (mn.GetString()  ?? "") : "";
                                mQRef = root.TryGetProperty("ref",  out var qrf) ? (qrf.GetString() ?? "") : "";
                                mQMsg = root.TryGetProperty("msg",  out var qmv) ? (qmv.GetString() ?? "") : "";
                            }
                            catch { isSpecial = false; }
                        }
                        string mCtxData = isSpecial && mType == "F" ? "" : (isSpecial && mType == "Q" ? mQMsg : (!isSpecial ? m.Conteudo : ""));
                        bool mHasMenu = !isSpecial || mType == "F" || mType == "Q";
                        <div class="flex @(isMe ? "justify-end" : "justify-start") items-end gap-1 msg-animate msg-wrapper group"
                             data-msg-id="@m.Id" data-is-me="@(isMe ? "true" : "false")"
                             data-conteudo="@mCtxData" data-is-grupo="false">
                            @if (isMe && mHasMenu) {
                                <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                </button>
                            }
                            @if (isSpecial && mType == "M") {
                                <div class="msg-card msg-card-mudanca flex flex-col gap-2">
                                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--brown)">Solicitação de Mudança</p>
                                    <p class="text-sm" style="color:var(--text)">@mR</p>
                                    <button onclick="abrirVisualizarMudanca('@mId')" class="btn-secondary text-xs px-3 py-1.5 self-start">Visualizar Mudança</button>
                                    <span class="text-[10px] opacity-60 self-end">@m.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            } else if (isSpecial && mType == "R") {
                                <div class="msg-card msg-card-rejeicao flex flex-col gap-2">
                                    <p class="text-xs font-bold uppercase tracking-wider" style="color:#ef4444">@mR</p>
                                    @if (!string.IsNullOrEmpty(mJ)) { <p class="text-sm" style="color:var(--text)">@mJ</p> }
                                    <span class="text-[10px] opacity-60 self-end">@m.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            } else if (isSpecial && mType == "V") {
                                <div class="msg-card msg-card-valor flex flex-col gap-2">
                                    <p class="text-xs font-bold uppercase tracking-wider" style="color:#16a34a">Atualização do Projeto</p>
                                    <p class="text-sm" style="color:var(--text)">@mR</p>
                                    @if (!string.IsNullOrEmpty(mV) && decimal.TryParse(mV, out var vDec) && vDec > 0) { <p class="text-sm font-bold" style="color:#16a34a">+ R$ @mV</p> }
                                    <span class="text-[10px] opacity-60 self-end">@m.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            } else if (isSpecial && mType == "F") {
                                bool mIsImg = new[] { ".png", ".jpg", ".jpeg" }.Contains(System.IO.Path.GetExtension(mUrl).ToLowerInvariant());
                                <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1">
                                    @if (mIsImg) {
                                        <img src="@mUrl" alt="@mNome" class="max-w-[220px] rounded-lg cursor-pointer" onclick="abrirFileViewer('@mUrl','@mNome',@(isMe ? "true" : "false"))" style="max-height:160px;object-fit:cover"/>
                                    } else {
                                        <a href="#" onclick="abrirFileViewer('@mUrl','@mNome',@(isMe ? "true" : "false"));return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 @mNome</a>
                                    }
                                    <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                                        @m.EnviadaEm.ToLocalTime().ToString("HH:mm")
                                        @if (isMe) { <span class="msg-receipt font-bold" style="color:@(m.Lida ? "#16a34a" : "inherit")">@(m.Lida ? "✓✓" : "✓")</span> }
                                    </span>
                                </div>
                            } else if (isSpecial && mType == "Q") {
                                <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1">
                                    <div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)">
                                        <span class="text-[10px] truncate block" style="color:var(--text-muted)">@Html.Raw(System.Net.WebUtility.HtmlEncode(mQRef.Length > 80 ? mQRef[..80] + "…" : mQRef))</span>
                                    </div>
                                    <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(mQMsg).Replace("\n","<br>"))</span>
                                    <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                                        @m.EnviadaEm.ToLocalTime().ToString("HH:mm")
                                        @if (isMe) { <span class="msg-receipt font-bold" style="color:@(m.Lida ? "#16a34a" : "inherit")">@(m.Lida ? "✓✓" : "✓")</span> }
                                    </span>
                                </div>
                            } else {
                                <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1">
                                    <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(m.Conteudo).Replace("\n","<br>"))</span>
                                    <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                                        @m.EnviadaEm.ToLocalTime().ToString("HH:mm")
                                        @if (isMe)
                                        {
                                            <span class="msg-receipt font-bold" style="color:@(m.Lida ? "#16a34a" : "inherit")">@(m.Lida ? "✓✓" : "✓")</span>
                                        }
                                    </span>
                                </div>
                            }
                            @if (!isMe && mHasMenu) {
                                <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                    <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                </button>
                            }
                        </div>
                    }
                </div>

                @if (Model.ChatBloqueado)
                {
                    <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0 flex items-center justify-center gap-2" style="background:var(--bg2)">
                        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--text-muted)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                        <p class="text-sm font-medium" style="color:var(--text-muted)">Esta conversa foi encerrada</p>
                    </div>
                }
                else
                {
                    <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0">
                        <input type="file" id="fileInput" class="hidden" accept="image/png,image/jpeg,application/pdf,application/zip,.zip"/>
                        <div id="replyPreview" class="hidden mb-2 flex items-center gap-2 rounded-xl px-3 py-1.5" style="background:var(--brown-subtle)">
                            <div class="w-0.5 self-stretch rounded-full flex-shrink-0" style="background:var(--brown)"></div>
                            <span id="replyText" class="text-xs flex-1 truncate" style="color:var(--text-muted)"></span>
                            <button type="button" onclick="cancelarReply()" class="flex-shrink-0 p-0.5" style="color:var(--text-muted)"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                        </div>
                        <form id="chatForm" class="chat-input-form flex items-center gap-3 bg-[#F4F3EE] rounded-2xl border border-[#6B462C]/20 px-2 py-1.5 focus-within:border-[color:var(--border)]0 focus-within:ring-2 focus-within:ring-[#6B462C]/10 transition-all"
                              onsubmit="enviarMsg(event)">
                            <button type="button" onclick="document.getElementById('fileInput').click()"
                                    class="chat-attach-btn text-[#8d6945] hover:text-[#4d392a] transition-colors flex-shrink-0 hover:scale-110 active:scale-95 p-2" title="Anexar arquivo">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9l-2 3H5a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                                </svg>
                            </button>
                            <textarea id="msgInput" rows="1" maxlength="4000"
                                   class="chat-input-text flex-1 bg-transparent focus:outline-none text-sm text-[#4d392a] placeholder-[#8d6945]/60"
                                   placeholder="Escreva sua mensagem..." autocomplete="off" aria-label="Mensagem"></textarea>
                            <button type="submit"
                                    class="chat-send-btn bg-[#6B462C] text-white p-2 rounded-xl hover:bg-[#4d392a] transition-all hover:scale-105 active:scale-95 shadow-sm flex-shrink-0 m-1.5" title="Enviar">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M2.01 21L23 12L2.01 3L2 10l15 2l-15 2z"/>
                                </svg>
                            </button>
                        </form>
                    </div>
                }
            }
        </div>
    </div>
</div>

@* Modal visualizador de arquivo *@
<div id="modalFileViewer" class="hidden fixed inset-0 z-[200] flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/85 backdrop-blur-sm" onclick="closeModal('modalFileViewer')"></div>
    <div class="relative z-10 flex flex-col items-center gap-4 w-full max-w-3xl mx-4">
        <div class="flex items-center justify-between w-full px-2">
            <p id="fileViewerNome" class="text-white text-sm font-medium truncate max-w-[70%]"></p>
            <div class="flex items-center gap-3">
                <a id="fileViewerDownload" href="#" download class="hidden text-white text-sm flex items-center gap-1.5 bg-white/20 hover:bg-white/30 px-3 py-1.5 rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    Baixar
                </a>
                <button onclick="closeModal('modalFileViewer')" class="text-white hover:text-gray-300 transition-colors" aria-label="Fechar">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <div id="fileViewerBody" class="w-full flex items-center justify-center"></div>
    </div>
</div>

@* Context menu mensagem *@
<div id="msgContextMenu" class="hidden fixed z-[400] ms-card shadow-xl rounded-xl overflow-hidden py-1" style="min-width:180px">
    <button id="mcCopy" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2.5 transition-opacity" style="color:var(--text)">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Copiar
    </button>
    <button id="mcReply" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2.5 transition-opacity" style="color:var(--text)">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Responder
    </button>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
const ME         = @Model.UsuarioAtual.Id;
const CONTATO_ID = @(Model.ContatoSelecionadoId?.ToString() ?? "0");
const IS_GRUPO   = @(Model.IsGrupoSuporte ? "true" : "false");
const msgBox     = document.getElementById('msgBox');
const msgInput   = document.getElementById('msgInput');
let pendingFile  = null;

function openModal(id)  { document.getElementById(id)?.classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }

// Carrega e exibe os detalhes de uma solicitação de mudança no modal
async function abrirVisualizarMudanca(mudancaId) {
    const el = document.getElementById('vmConteudo');
    if (!el) return;
    el.innerHTML = '<p style="color:var(--text-muted)">Carregando...</p>';
    document.getElementById('vmMudancaId').value = mudancaId;
    const acoes = document.getElementById('vmAcoes');
    if (acoes) acoes.style.display = 'none';
    openModal('modalVisualizarMudanca');
    try {
        const res = await fetch(`/Supplier/GetMudancaInfo?id=${mudancaId}`);
        if (!res.ok) { el.innerHTML = '<p style="color:#ef4444">Mudança não encontrada.</p>'; return; }
        const data = await res.json();
        let campos = [];
        try { campos = JSON.parse(data.descricao || '[]'); } catch(e) {}
        let html = '';
        if (Array.isArray(campos) && campos.length) {
            campos.forEach(c => {
                html += `<div class="rounded-xl p-3" style="background:var(--bg2);border:1px solid var(--border)">
                  <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--text-muted)">${esc(c.campo || '')}</p>
                  ${c.de ? `<p class="text-xs line-through mb-0.5" style="color:var(--text-muted)">${esc(c.de)}</p>` : ''}
                  <p class="text-sm" style="color:var(--text)">${esc(c.para || '')}</p>
                </div>`;
            });
        } else {
            html = `<p class="text-sm" style="color:var(--text)">${esc(data.descricao || '')}</p>`;
        }
        el.innerHTML = html;
        if (!data.aceita && !data.recusada) {
            const acoes = document.getElementById('vmAcoes');
            if (acoes) acoes.style.display = 'flex';
        } else if (data.aceita) {
            el.innerHTML += `<p class="text-xs font-bold mt-2" style="color:#16a34a">✓ Já aceita</p>`;
        } else {
            el.innerHTML += `<p class="text-xs font-bold mt-2" style="color:#ef4444">✗ Já recusada</p>`;
        }
    } catch(e) {
        el.innerHTML = '<p style="color:#ef4444">Erro ao carregar.</p>';
    }
}

// Submete a aceitação da mudança pendente para o servidor
async function aceitarMudanca() {
    const mudancaId = document.getElementById('vmMudancaId').value;
    const token     = document.querySelector('[name=__RequestVerificationToken]')?.value;
    const form = new FormData();
    form.append('mudancaId', mudancaId);
    form.append('aceitar',   'true');
    if (token) form.append('__RequestVerificationToken', token);
    try {
        const res  = await fetch('/Supplier/ResponderMudanca', { method: 'POST', body: form });
        const data = await res.json();
        if (data.ok) {
            closeModal('modalVisualizarMudanca');
            // MODIFICADO: Substituído alert por modal customizado de sucesso
            openModal('modalSucessoMudanca');
        }
    } catch(e) { console.error(e); }
}

// Abre o modal de justificativa para rejeição da mudança
function abrirJustificativa() {
    document.getElementById('txtJustificativa').value = '';
    document.getElementById('erroJustificativa')?.classList.add('hidden');
    openModal('modalJustificativa');
}

// Submete a rejeição da mudança com a justificativa informada
async function enviarRejeicao() {
    const justif    = document.getElementById('txtJustificativa').value.trim();
    const erroEl    = document.getElementById('erroJustificativa');
    const mudancaId = document.getElementById('vmMudancaId').value;
    if (!justif) {
        if (erroEl) { erroEl.textContent = 'Informe a justificativa.'; erroEl.classList.remove('hidden'); }
        return;
    }
    const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
    const form  = new FormData();
    form.append('mudancaId', mudancaId);
    form.append('aceitar',   'false');
    form.append('resposta',  justif);
    if (token) form.append('__RequestVerificationToken', token);
    const btn = document.getElementById('btnEnviarRejeicao');
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
    try {
        const res  = await fetch('/Supplier/ResponderMudanca', { method: 'POST', body: form });
        const data = await res.json();
        if (data.ok) {
            closeModal('modalJustificativa');
            closeModal('modalVisualizarMudanca');
        }
    } catch(e) { console.error(e); }
    finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Enviar'; }
    }
}

// Configuração da conexão SignalR para o chat em tempo real
const conn = new signalR.HubConnectionBuilder()
    .withUrl('/chatHub')
    .withAutomaticReconnect()
    .build();

// Recebe e exibe mensagens do canal de suporte em grupo
conn.on('ReceiveGrupoMessage', (msg) => {
    if (!IS_GRUPO || !msgBox) return;
    const isMe = msg.remetenteId === ME;
    const div  = document.createElement('div');
    div.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-1 msg-animate msg-wrapper group`;
    div.setAttribute('data-msg-id', msg.id);
    div.setAttribute('data-is-me', isMe ? 'true' : 'false');
    div.setAttribute('data-is-grupo', 'true');
    let avatar = isMe ? '' : `<div class="w-7 h-7 rounded-full overflow-hidden flex-shrink-0 mr-2 self-start flex items-center justify-center"><img src="/img/logo_img.png" class="w-7 h-7 object-contain"/></div>`;
    let sender = isMe ? '' : `<span class="msg-sender-name text-[10px] font-bold" style="color:var(--brown)">${esc(msg.nomeRemetente)}</span>`;
    let gmContent = '', ctxData = '';
    if (msg.conteudo && msg.conteudo.startsWith('{"_t":"F"')) {
        try {
            const gd = JSON.parse(msg.conteudo);
            const gmImg = /\.(png|jpe?g)$/i.test(gd.url || '');
            gmContent = gmImg
                ? `<img src="${esc(gd.url)}" alt="${esc(gd.nome)}" class="max-w-[200px] rounded-lg cursor-pointer" onclick="abrirFileViewer('${esc(gd.url)}','${esc(gd.nome)}',${isMe})" style="max-height:150px;object-fit:cover">`
                : `<a href="#" onclick="abrirFileViewer('${esc(gd.url)}','${esc(gd.nome)}',${isMe});return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 ${esc(gd.nome)}</a>`;
        } catch(e) { gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`; }
    } else if (msg.conteudo && msg.conteudo.startsWith('{"_t":"Q"')) {
        try {
            const qd = JSON.parse(msg.conteudo);
            ctxData = qd.msg || '';
            gmContent = `<div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)"><span class="text-[10px] truncate block" style="color:var(--text-muted)">${esc((qd.ref||'').slice(0,80))}</span></div><span class="msg-conteudo">${escMsg(qd.msg||'')}</span>`;
        } catch(e) { gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`; ctxData = msg.conteudo; }
    } else {
        ctxData = msg.conteudo || '';
        gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`;
    }
    div.setAttribute('data-conteudo', ctxData);
    const bubble = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1 max-w-xs">${sender}${gmContent}<span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span></div>`;
    div.innerHTML = avatar + (isMe ? mkDotBtn() : '') + bubble + (!isMe ? mkDotBtn() : '');
    msgBox.appendChild(div);
    msgBox.scrollTop = msgBox.scrollHeight;
    atualizarSidebarGrupo(msg.conteudo);
});

// Atualiza a prévia de última mensagem na sidebar do grupo de suporte
function atualizarSidebarGrupo(texto) {
    const item = document.querySelector('.contact-item[href="?grupoSuporte=true"]');
    if (!item) return;
    const prev = item.querySelector('p.text-xs');
    if (prev) prev.textContent = texto;
}

// Envia mensagem ou arquivo para o canal de suporte em grupo
async function enviarGrupoMsg(e) {
    e.preventDefault();
    if (!msgInput) return;
    if (pendingFile) {
        const fd = new FormData();
        fd.append('arquivo', pendingFile);
        pendingFile = null;
        msgInput.value = ''; msgInput.style.height = '';
        document.getElementById('fileInputGrupo').value = '';
        try {
            const res  = await fetch('/Supplier/UploadChatArquivo', { method: 'POST', body: fd });
            const data = await res.json();
            if (!data.ok) { 
                // MODIFICADO: Inserido o texto dinâmico do erro no modal e aberto o modal
                const txtErro = document.getElementById('txtErroArquivo');
                if (txtErro) txtErro.textContent = data.erro || 'Erro ao enviar arquivo.';
                openModal('modalErroArquivo'); 
                return; 
            }
            await conn.invoke('SendGrupoMessage', JSON.stringify({ _t: 'F', url: data.url, nome: data.nome }));
        } catch(er) { 
            console.error(er); 
            // MODIFICADO: Substituído alert genérico por modal de erro
            const txtErro = document.getElementById('txtErroArquivo');
            if (txtErro) txtErro.textContent = 'Erro ao enviar arquivo.';
            openModal('modalErroArquivo');
        }
        return;
    }
    let txt = msgInput.value.trim();
    if (!txt) return;
    if (_replyMsgId) {
        const w = document.querySelector(`.msg-wrapper[data-msg-id="${_replyMsgId}"]`);
        const refText = w?.dataset.conteudo || '';
        txt = JSON.stringify({ _t: 'Q', ref: refText.slice(0,100), refId: _replyMsgId, msg: txt });
        cancelarReply();
    }
    msgInput.value = ''; msgInput.style.height = '';
    try { await conn.invoke('SendGrupoMessage', txt); }
    catch(er) { console.error(er); }
}

// Recebe e exibe mensagens diretas na conversa activa
conn.on('ReceiveMessage', (msg) => {
    const emConv = (msg.remetenteId === CONTATO_ID && msg.destinatarioId === ME)
                || (msg.remetenteId === ME && msg.destinatarioId === CONTATO_ID);
    if (emConv && msgBox) {
        appendMsg(msg);
        if (msg.remetenteId === CONTATO_ID)
            conn.invoke('MarkRead', CONTATO_ID).catch(console.error);
    }
    atualizarSidebar(msg);
});

// Atualiza os recibos de leitura das mensagens enviadas
conn.on('MessagesRead', (leuId) => {
    if (leuId === CONTATO_ID)
        document.querySelectorAll('.msg-receipt').forEach(el => {
            el.textContent = '✓✓'; el.style.color = '#16a34a';
        });
});

conn.on('ConversationCleared', (data) => {
    if (data.contatoId === CONTATO_ID && msgBox) {
        msgBox.innerHTML = '<p class="text-center text-sm py-8" style="color:var(--text-muted)">Esta conversa foi encerrada.</p>';
        const inp = document.getElementById('msgInput');
        if (inp) { inp.disabled = true; inp.placeholder = 'Conversa encerrada.'; }
        const btn = document.querySelector('#chatForm button[type=submit]');
        if (btn) btn.disabled = true;
    }
});

// Escapa caracteres especiais para exibição segura no HTML
function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function escMsg(s) {
    if (!s) return '';
    return esc(s).replace(/\n/g, '<br>');
}

// Monta o HTML de uma bolha de mensagem simples
function buildBubble(isMe, msg, text) {
    return `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1">
        <span class="msg-conteudo">${escMsg(text)}</span>
        <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
          ${msg.enviadaEm}
          ${isMe ? `<span class="msg-receipt font-bold">✓</span>` : ''}
        </span>
      </div>`;
}

// Cria o botão de opções de contexto de uma mensagem
function mkDotBtn() {
    return `<button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>`;
}

// Cria e insere o elemento de mensagem direta na área de chat
function appendMsg(msg) {
    if (!msgBox) return;
    const isMe = msg.remetenteId === ME;
    const div  = document.createElement('div');
    div.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-1 msg-animate msg-wrapper group`;
    div.setAttribute('data-msg-id', msg.id);
    div.setAttribute('data-is-me', isMe ? 'true' : 'false');
    div.setAttribute('data-is-grupo', 'false');
    let inner = '';
    if (msg.conteudo && msg.conteudo.startsWith('{"_t":"')) {
        try {
            const d = JSON.parse(msg.conteudo);
            if (d._t === 'M') {
                inner = `<div class="msg-card msg-card-mudanca flex flex-col gap-2">
                  <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--brown)">Solicitação de Mudança</p>
                  <p class="text-sm" style="color:var(--text)">${esc(d.r || '')}</p>
                  <button onclick="abrirVisualizarMudanca('${d.id}')" class="btn-secondary text-xs px-3 py-1.5 self-start">Visualizar Mudança</button>
                  <span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span>
                </div>`;
            } else if (d._t === 'R') {
                inner = `<div class="msg-card msg-card-rejeicao flex flex-col gap-2">
                  <p class="text-xs font-bold uppercase tracking-wider" style="color:#ef4444">${esc(d.r || 'Solicitação Rejeitada')}</p>
                  ${d.j ? `<p class="text-sm" style="color:var(--text)">${esc(d.j)}</p>` : ''}
                  <span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span>
                </div>`;
            } else if (d._t === 'V') {
                inner = `<div class="msg-card msg-card-valor flex flex-col gap-2">
                  <p class="text-xs font-bold uppercase tracking-wider" style="color:#16a34a">Atualização do Projeto</p>
                  <p class="text-sm" style="color:var(--text)">${esc(d.r || '')}</p>
                  ${d.v && parseFloat(d.v) > 0 ? `<p class="text-sm font-bold" style="color:#16a34a">+ R$ ${esc(d.v)}</p>` : ''}
                  <span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span>
                </div>`;
            } else if (d._t === 'F') {
                const fImg = /\.(png|jpe?g)$/i.test(d.url || '');
                const fContent = fImg
                    ? `<img src="${esc(d.url)}" alt="${esc(d.nome)}" class="max-w-[220px] rounded-lg cursor-pointer" onclick="abrirFileViewer('${esc(d.url)}','${esc(d.nome)}',${isMe})" style="max-height:160px;object-fit:cover">`
                    : `<a href="#" onclick="abrirFileViewer('${esc(d.url)}','${esc(d.nome)}',${isMe});return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 ${esc(d.nome)}</a>`;
                inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1">
                  ${fContent}
                  <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                    ${msg.enviadaEm}
                    ${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}
                  </span>
                </div>`;
            } else {
                inner = buildBubble(isMe, msg, msg.conteudo);
            }
        } catch(e) {
            inner = buildBubble(isMe, msg, msg.conteudo);
        }
    } else {
        inner = buildBubble(isMe, msg, msg.conteudo);
    }
    const isPlainOrQ = !msg.conteudo?.startsWith('{"_t":"') || inner.includes('msg-conteudo');
    const ctxData = msg.conteudo?.startsWith('{"_t":"F"') ? '' : (msg.conteudo?.startsWith('{"_t":"Q"') ? (() => { try { return JSON.parse(msg.conteudo).msg || ''; } catch(e) { return ''; } })() : (msg.conteudo || ''));
    div.setAttribute('data-conteudo', ctxData);
    const hasMenu = isPlainOrQ && !msg.conteudo?.startsWith('{"_t":"M"') && !msg.conteudo?.startsWith('{"_t":"R"') && !msg.conteudo?.startsWith('{"_t":"V"');
    div.innerHTML = (isMe && hasMenu ? mkDotBtn() : '') + inner + (!isMe && hasMenu ? mkDotBtn() : '');
    msgBox.appendChild(div);
    msgBox.scrollTop = msgBox.scrollHeight;
}

// Atualiza a prévia de última mensagem na sidebar de conversas diretas
function atualizarSidebar(msg) {
    const outroId = msg.remetenteId === ME ? msg.destinatarioId : msg.remetenteId;
    const item    = document.querySelector(`.contact-item[href*="contatoId=${outroId}"]`);
    if (!item) return;
    const prev = item.querySelector('p.text-xs, .text-xs.truncate');
    if (!prev) return;
    let preview = msg.conteudo;
    if (preview && preview.startsWith('{"_t":"F"')) preview = '📎 Arquivo';
    else if (preview && preview.startsWith('{"_t":"'))  preview = '📋 Atualização';
    prev.textContent = preview;
}

// Envia mensagem ou arquivo na conversa direta com o contato selecionado
async function enviarMsg(e) {
    e.preventDefault();
    if (!msgInput || !CONTATO_ID) return;
    if (pendingFile) {
        const fd = new FormData();
        fd.append('arquivo', pendingFile);
        pendingFile = null;
        msgInput.value = ''; msgInput.style.height = '';
        document.getElementById('fileInput').value = '';
        try {
            const res  = await fetch('/Supplier/UploadChatArquivo', { method: 'POST', body: fd });
            const data = await res.json();
            if (!data.ok) { 
                // MODIFICADO: Inserido o texto dinâmico do erro no modal e aberto o modal
                const txtErro = document.getElementById('txtErroArquivo');
                if (txtErro) txtErro.textContent = data.erro || 'Erro ao enviar arquivo.';
                openModal('modalErroArquivo'); 
                return; 
            }
            await conn.invoke('SendMessage', CONTATO_ID, JSON.stringify({ _t: 'F', url: data.url, nome: data.nome }));
        } catch(er) { 
            console.error(er); 
            // MODIFICADO: Substituído alert por modal de erro
            const txtErro = document.getElementById('txtErroArquivo');
            if (txtErro) txtErro.textContent = 'Erro ao enviar arquivo.';
            openModal('modalErroArquivo');
        }
        return;
    }
    let txt = msgInput.value.trim();
    if (!txt) return;
    if (_replyMsgId) {
        const w = document.querySelector(`.msg-wrapper[data-msg-id="${_replyMsgId}"]`);
        const refText = w?.dataset.conteudo || '';
        txt = JSON.stringify({ _t: 'Q', ref: refText.slice(0,100), refId: _replyMsgId, msg: txt });
        cancelarReply();
    }
    msgInput.value = ''; msgInput.style.height = '';
    try { await conn.invoke('SendMessage', CONTATO_ID, txt); }
    catch(er) { console.error(er); }
}

let supFilterMode = 'nome';
const supSearchInput = document.querySelector('input[aria-label="Buscar conversa"]');

document.querySelectorAll('.filter-opt').forEach(btn => {
    btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        supFilterMode = f;
        document.querySelectorAll('.filter-opt').forEach(b => { b.style.fontWeight = ''; b.style.color = 'var(--text)'; });
        btn.style.fontWeight = 'bold'; btn.style.color = 'var(--brown)';
        document.getElementById('filterDropdown')?.classList.add('hidden');
        if (supSearchInput) { supSearchInput.value = ''; supSearchInput.placeholder = f === 'nome' ? 'Buscar por nome...' : 'Pesquisar conversa...'; if (f !== 'recente') supSearchInput.focus(); }
        filtrarContatos('');
    });
});

// Filtra a lista de contatos pelo nome digitado na busca
function filtrarContatos(q) {
    const lq = q.toLowerCase().trim();
    document.querySelectorAll('.contact-item').forEach(el => {
        if (!lq) { el.style.display = ''; return; }
        const nome = (el.querySelector('.contact-name')?.textContent || '').toLowerCase();
        el.style.display = nome.includes(lq) ? '' : 'none';
    });
}

conn.start().then(() => {
    if (!IS_GRUPO && CONTATO_ID) {
        conn.invoke('MarkRead', CONTATO_ID).catch(console.error);
        conn.invoke('SetChatActive', CONTATO_ID).catch(console.error);
    } else if (IS_GRUPO) {
        conn.invoke('SetGrupoSuporteActive').catch(console.error);
    }
}).catch(console.error);

msgInput?.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); IS_GRUPO ? enviarGrupoMsg(e) : enviarMsg(e); }
});
msgInput?.addEventListener('input', function(e) {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 112) + 'px';
    if (e.inputType === 'insertText') {
        const pos = this.selectionStart;
        const val = this.value;
        const last = val[pos - 1] || '';
        const prev = pos >= 2 ? val[pos - 2] : null;
        if ((prev === null || prev === '\n') && last && last !== last.toUpperCase()) {
            this.value = val.slice(0, pos - 1) + last.toUpperCase() + val.slice(pos);
            this.setSelectionRange(pos, pos);
        }
    }
});

if (msgBox) msgBox.scrollTop = msgBox.scrollHeight;

// Inicializa dropdowns de menu do chat
function setupDrop(btnId, dropId) {
    const btn = document.getElementById(btnId);
    const drop = document.getElementById(dropId);
    if (!btn || !drop) return;
    btn.addEventListener('click', e => { e.stopPropagation(); drop.classList.toggle('hidden'); });
    document.addEventListener('click', () => drop.classList.add('hidden'));
}
setupDrop('filterMenuBtn',     'filterDropdown');
setupDrop('supChatMenuBtn',    'supChatMenuDropdown');

// Redireciona para a conversa com o suporte MindSite
function supFalarComSuporte() {
    document.getElementById('supChatMenuDropdown')?.classList.add('hidden');
    window.location.href = '/Supplier/Chat?grupoSuporte=true';
}

// Busca e exibe os detalhes do serviço ativo do cliente selecionado
async function supVerServicoInfo() {
    if (!CONTATO_ID) return;
    document.getElementById('supChatMenuDropdown')?.classList.add('hidden');
    openModal('supModalServicoInfo');
    const siInfos = document.getElementById('supSiInfos');
    if (siInfos) siInfos.innerHTML = '<p class="text-sm text-center py-4" style="color:var(--text-muted)">Carregando...</p>';
    try {
        const res = await fetch(`/Supplier/GetServicoAtivoDetalhes?clienteId=${CONTATO_ID}`);
        const d = await res.json();
        if (!d.ok) {
            if (siInfos) siInfos.innerHTML = '<p class="text-sm text-center py-4" style="color:#ef4444">Nenhum serviço ativo encontrado.</p>';
            return;
        }
        let rows = '';
        if (d.nome)    rows += `<div class="flex gap-2"><span style="color:var(--text-muted);min-width:80px">Nome</span><span style="color:var(--text);font-weight:600">${esc(d.nome)}</span></div>`;
        if (d.tipo)    rows += `<div class="flex gap-2"><span style="color:var(--text-muted);min-width:80px">Tipo</span><span style="color:var(--text)">${esc(d.tipo)}</span></div>`;
        if (d.status)  rows += `<div class="flex gap-2"><span style="color:var(--text-muted);min-width:80px">Status</span><span style="color:var(--text)">${esc(d.status)}</span></div>`;
        if (d.valor)   rows += `<div class="flex gap-2"><span style="color:var(--text-muted);min-width:80px">Valor</span><span style="color:var(--text)">R$ ${esc(d.valor)}</span></div>`;
        if (d.entrega) rows += `<div class="flex gap-2"><span style="color:var(--text-muted);min-width:80px">Entrega</span><span style="color:var(--text)">${esc(d.entrega)}</span></div>`;
        if (d.obs)     rows += `<div class="flex flex-col gap-1"><span style="color:var(--text-muted)">Observações</span><span style="color:var(--text)">${esc(d.obs)}</span></div>`;
        if (siInfos) siInfos.innerHTML = rows || '<p style="color:var(--text-muted)">—</p>';
    } catch(e) {
        if (siInfos) siInfos.innerHTML = '<p class="text-sm text-center py-4" style="color:#ef4444">Erro ao carregar.</p>';
    }
}

// Captura arquivo selecionado e armazena para envio junto com a próxima mensagem
