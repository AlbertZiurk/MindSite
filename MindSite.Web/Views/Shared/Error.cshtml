@{
    ViewData["Title"] = "Erro";
    Layout = "_Layout";
}
<div class="min-h-[60vh] flex items-center justify-center">
    <div class="text-center px-6">
        <p class="text-8xl font-inria font-bold mb-4" style="color:var(--brown)">Oops</p>
        <h1 class="text-2xl font-bold mb-3" style="color:var(--text)">Algo deu errado</h1>
        <p class="mb-8" style="color:var(--text-muted)">Ocorreu um erro inesperado. Tente novamente.</p>
        <a asp-controller="Home" asp-action="Index" class="btn-primary px-8 py-3">Voltar ao início</a>
    </div>
</div>
