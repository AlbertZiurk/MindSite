<!DOCTYPE html>
<html lang="pt-br" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MindSite</title>
    
    <script src="https://cdn.tailwindcss.com"></script>

    @* Links da Fonte *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inria+Serif:wght@400;700&display=swap" rel="stylesheet">

    @* Links para as icons *@
    <link rel="apple-touch-icon" sizes="180x180" href="~/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicons/favicon-16x16.png">
    <link rel="manifest" href="~/favicons/site.webmanifest">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'inria': ['"Inria Serif"', 'serif'],
                        'serif': ['Merriweather', 'serif'],
                        'sans': ['Poppins', 'sans-serif']
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col font-sans bg-[#F4F3EE]">

    @{
        // Pegamos o Controller e Action atuais do ASP.NET
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header class="bg-[#E3DBCE] sticky top-0 z-50 shadow-md">
        <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
            
            <a class="flex items-center gap-1 text-4xl font-inria text-[#6B462C]" asp-controller="Home" asp-action="Index">
                Mind<img src="~/img/logo_img.png" alt="Logo_MindSite" class="h-14 w-auto" />Site
            </a>

            <div class="flex items-center gap-8">
                <ul id="nav-menu" class="flex flex-row items-center space-x-6 text-[#4d392a] font-medium text-sm">
                    <li>
                        <a asp-controller="Admin" asp-action="Index" 
                           class="nav-link hover:text-[#623f25] transition-all px-1 py-1 @(currentController == "Admin" && currentAction == "Index" ? "font-[1000] text-[15px] border-b-2 border-[#623f25]" : "")">
                            Home
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="Chat" 
                           class="nav-link hover:text-[#623f25] transition-all px-1 py-1 @(currentController == "Admin" && currentAction == "Chat" ? "font-[1000] text-[15px] border-b-2 border-[#623f25]" : "")">
                            Chat
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="Usuarios" 
                           class="nav-link hover:text-[#623f25] transition-all px-1 py-1 @(currentController == "Admin" && currentAction == "Usuarios" ? "font-[1000] text-[15px] border-b-2 border-[#623f25]" : "")">
                            Usuários
                        </a>
                    </li>
                </ul>

                <div class="flex items-center gap-5">
                    @* SVG de Notificação *@
                    <button class="relative text-[#6B462C] hover:scale-110 transition-transform p-1" title="Notificações">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span class="absolute top-1 right-1 h-2 w-2 bg-red-500 rounded-full border border-[#E3DBCE]"></span>
                    </button>

                    <a asp-controller="Account" asp-action="ProfileAdmin" class="flex flex-col items-center group select-none" title="Painel Admin">
                        <div class="bg-[#6B462C] p-1.5 rounded-full text-[#F4F3EE] shadow-sm group-hover:bg-[#4d392a] group-hover:scale-105 transition-all duration-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <span class="text-[12px] font-bold text-[#4d392a] mt-[5px] group-hover:text-[#623f25] group-hover:scale-105 uppercase mt-0.5 tracking-wider font-sans transition-all duration-200 origin-top">Admin</span>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    @* Área de conteúdo principal limpa para evitar interferências no design do chat ou tabelas *@
    <main class="flex-1 w-full box-border">
        @RenderBody()
    </main>

    @await RenderSectionAsync("Scripts", required: false)

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const currentPath = window.location.pathname.toLowerCase();
        const navLinks = document.querySelectorAll(".nav-link");

        navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            if (!href) return;

            const targetPath = href.toLowerCase();

            // Limpa qualquer estilo ativo residual por segurança
            link.classList.remove("font-[1000]", "text-[15px]", "border-b-2", "border-[#623f25]");

            // Validação inteligente da rota ativa
            // Destaca se o path for idêntico ou se for a raiz da área (/Admin) mapeando para Home
            if (currentPath === targetPath || 
               (targetPath === '/admin/index' && currentPath === '/admin') || 
               (targetPath === '/admin/index' && currentPath === '/admin/')) {
                
                link.classList.add("font-[1000]", "text-[15px]", "border-b-2", "border-[#623f25]");
            }
        });
    });
</script>
</body>
</html>