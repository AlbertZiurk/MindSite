<!DOCTYPE html>
<html lang="pt-br" class="scroll-smooth">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MindSite</title>
    
    <script src="https://cdn.tailwindcss.com"></script>

    @* Links da Fonte *@
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inria+Serif:wght@400;700&display=swap" rel="stylesheet">

    @* Links para as icons *@
    <link rel="apple-touch-icon" sizes="180x180" href="~/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="~/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="~/favicons/favicon-16x16.png">
    <link rel="manifest" href="~/favicons/site.webmanifest">
    <link href="https://fonts.googleapis.com/css2?family=Merriweather:wght@700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'inria': ['"Inria Serif"', 'serif'],
                        'serif': ['Merriweather', 'serif'],
                        'sans': ['Poppins', 'sans-serif']
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen flex flex-col font-sans bg-[#F4F3EE]">

    @{
        // Pegamos o Controller e Action atuais do ASP.NET
        var currentController = ViewContext.RouteData.Values["Controller"]?.ToString();
        var currentAction = ViewContext.RouteData.Values["Action"]?.ToString();
    }

    <header class="bg-[#E3DBCE] sticky top-0 z-50 shadow-md">
        <nav class="container mx-auto px-6 py-4 flex items-center justify-between">
            
            <a class="flex items-center gap-1 text-4xl font-inria text-[#6B462C]" asp-controller="Home" asp-action="Index">
                Mind<img src="~/img/logo_img.png" alt="Logo_MindSite" class="h-14 w-auto" />Site
            </a>

            <div class="flex items-center gap-8">
                <ul id="nav-menu" class="flex flex-row items-center space-x-6 text-[#4d392a] font-medium text-sm">
                    <li>
                        <a asp-controller="Admin" asp-action="Index" 
                           class="nav-link hover:text-[#623f25] transition-all px-1 py-1 @(currentController == "Admin" && currentAction == "Index" ? "font-[1000] text-[15px] border-b-2 border-[#623f25]" : "")">
                            Home
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="Chat" 
                           class="nav-link hover:text-[#623f25] transition-all px-1 py-1 @(currentController == "Admin" && currentAction == "Chat" ? "font-[1000] text-[15px] border-b-2 border-[#623f25]" : "")">
                            Chat
                        </a>
                    </li>
                    <li>
                        <a asp-controller="Admin" asp-action="Usuarios" 
                           class="nav-link hover:text-[#623f25] transition-all px-1 py-1 @(currentController == "Admin" && currentAction == "Usuarios" ? "font-[1000] text-[15px] border-b-2 border-[#623f25]" : "")">
                            Usuários
                        </a>
                    </li>
                </ul>

                <div class="flex items-center gap-5">
                    @* SVG de Notificação *@
                    <button class="relative text-[#6B462C] hover:scale-110 transition-transform p-1" title="Notificações">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                        </svg>
                        <span class="absolute top-1 right-1 h-2 w-2 bg-red-500 rounded-full border border-[#E3DBCE]"></span>
                    </button>

                    <a asp-controller="Account" asp-action="ProfileAdmin" class="flex flex-col items-center group select-none" title="Painel Admin">
                        <div class="bg-[#6B462C] p-1.5 rounded-full text-[#F4F3EE] shadow-sm group-hover:bg-[#4d392a] group-hover:scale-105 transition-all duration-200">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
                            </svg>
                        </div>
                        <span class="text-[12px] font-bold text-[#4d392a] mt-[5px] group-hover:text-[#623f25] group-hover:scale-105 uppercase mt-0.5 tracking-wider font-sans transition-all duration-200 origin-top">Admin</span>
                    </a>
                </div>
            </div>
        </nav>
    </header>

    @* Área de conteúdo principal limpa para evitar interferências no design do chat ou tabelas *@
    <main class="flex-1 w-full box-border">
        @RenderBody()
    </main>

    <footer class="bg-[#E3DBCE] border-t border-[#6B462C]/15 pt-10 pb-6 flex-shrink-0">
        <div class="container mx-auto px-6">

            @* Colunas de informação *@
            <div class="grid grid-cols-1 md:grid-cols-3 gap-[200px] text-[#4d392a] font-sans text-sm mb-4">

                @* Coluna 1 - Sobre *@
                <div>
                    <h4 class="text-[#6B462C] font-bold uppercase tracking-widest text-xs">Sobre</h4>
                    <p class="leading-relaxed mt-4 text-[#4d392a]/75">
                        Conectamos clientes e fornecedores de web design com tecnologia, agilidade e qualidade.
                    </p>
                </div>

                @* Coluna 2 - Links *@
                <div class="flex flex-col items-center mt-2">
                    <a asp-controller="Home" asp-action="Index" class="flex items-center gap-1 text-3xl font-inria text-[#6B462C]">
                        Mind<img src="~/img/logo_img.png" alt="Logo MindSite" class="h-12 w-auto" />Site
                    </a>
                    <p class="text-[#4d392a]/60 text-xs mt-2 tracking-widest uppercase font-sans">O futuro do Web Design chegou</p>
                </div>

                @* Coluna 3 - Contato *@
                <div class="md:text-right">
                    <h4 class="text-[#6B462C] font-bold uppercase tracking-widest text-xs mb-4">Contato</h4>
                    <ul class="space-y-2 text-[#4d392a]/75">
                        <li class="flex items-center md:justify-end gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#6B462C]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/>
                            </svg>
                            <span>contato@mindsite.com.br</span>
                        </li>
                        <li class="flex items-center md:justify-end gap-2">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 text-[#6B462C]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/>
                            </svg>
                            <span>(11) 9795-6304</span>
                        </li>
                        <div class="flex md:justify-end gap-4 mt-4">

                            <a href="https://wa.me/5511XXXXXXXXX" target="_blank" class="text-[#6B462C] hover:text-[#25D366] transition duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347z"/>
                                    <path d="M12.004 0C5.374 0 0 5.373 0 12.004c0 2.117.554 4.102 1.522 5.831L.057 23.997l6.304-1.654A11.954 11.954 0 0012.004 24C18.63 24 24 18.627 24 12.004 24 5.374 18.627 0 12.004 0zm0 21.898a9.893 9.893 0 01-5.034-1.371l-.361-.214-3.741.981 1-3.641-.235-.374A9.865 9.865 0 012.102 12c0-5.465 4.444-9.898 9.902-9.898 5.465 0 9.899 4.44 9.899 9.904 0 5.458-4.44 9.892-9.899 9.892z"/>
                                </svg>
                            </a>

                            <a href="https://instagram.com/mindsite" target="_blank" class="text-[#6B462C] hover:text-pink-500 transition duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M12 2.163c3.204 0 3.584.012 4.85.07 3.252.148 4.771 1.691 4.919 4.919.058 1.265.069 1.645.069 4.849 0 3.205-.012 3.584-.069 4.849-.149 3.225-1.664 4.771-4.919 4.919-1.266.058-1.644.07-4.85.07-3.204 0-3.584-.012-4.849-.07-3.26-.149-4.771-1.699-4.919-4.92-.058-1.265-.07-1.644-.07-4.849 0-3.204.013-3.583.07-4.849.149-3.227 1.664-4.771 4.919-4.919 1.266-.057 1.645-.069 4.849-.069zm0-2.163c-3.259 0-3.667.014-4.947.072-4.358.2-6.78 2.618-6.98 6.98-.059 1.281-.073 1.689-.073 4.948 0 3.259.014 3.668.072 4.948.2 4.358 2.618 6.78 6.98 6.98 1.281.058 1.689.072 4.948.072 3.259 0 3.668-.014 4.948-.072 4.354-.2 6.782-2.618 6.979-6.98.059-1.28.073-1.689.073-4.948 0-3.259-.014-3.667-.072-4.947-.196-4.354-2.617-6.78-6.979-6.98-1.281-.059-1.69-.073-4.949-.073zm0 5.838a6.162 6.162 0 100 12.324 6.162 6.162 0 000-12.324zM12 16a4 4 0 110-8 4 4 0 010 8zm6.406-11.845a1.44 1.44 0 100 2.881 1.44 1.44 0 000-2.881z"/>
                                </svg>
                            </a>

                            <a href="https://facebook.com/mindsite" target="_blank" class="text-[#6B462C] hover:text-blue-600 transition duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M24 12.073C24 5.405 18.627 0 12 0S0 5.405 0 12.073C0 18.1 4.388 23.094 10.125 24v-8.437H7.078v-3.49h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.49h-2.796V24C19.612 23.094 24 18.1 24 12.073z"/>
                                </svg>
                            </a>

                            <a href="https://linkedin.com/company/mindsite" target="_blank" class="text-[#6B462C] hover:text-blue-500 transition duration-300">
                                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5" fill="currentColor" viewBox="0 0 24 24">
                                    <path d="M20.447 20.452h-3.554v-5.569c0-1.328-.027-3.037-1.852-3.037-1.853 0-2.136 1.445-2.136 2.939v5.667H9.351V9h3.414v1.561h.046c.477-.9 1.637-1.85 3.37-1.85 3.601 0 4.267 2.37 4.267 5.455v6.286zM5.337 7.433a2.062 2.062 0 01-2.063-2.065 2.064 2.064 0 112.063 2.065zm1.782 13.019H3.555V9h3.564v11.452zM22.225 0H1.771C.792 0 0 .774 0 1.729v20.542C0 23.227.792 24 1.771 24h20.451C23.2 24 24 23.227 24 22.271V1.729C24 .774 23.2 0 22.222 0h.003z"/>
                                </svg>
                            </a>

                        </div>
                    </ul>
                </div>
            </div>

            <div class="w-full h-px bg-[#6B462C]/10 mt-2 mb-6"></div>

            <p class="text-center text-[#4d392a]/50 text-xs tracking-wide">
                &copy; 2026 <span class="text-[#6B462C] font-semibold">MindSite.Web</span> — Todos os direitos reservados.
            </p>

        </div>
    </footer>

    @await RenderSectionAsync("Scripts", required: false)

<script>
    document.addEventListener("DOMContentLoaded", () => {
        const currentPath = window.location.pathname.toLowerCase();
        const navLinks = document.querySelectorAll(".nav-link");

        navLinks.forEach((link) => {
            const href = link.getAttribute("href");
            if (!href) return;

            const targetPath = href.toLowerCase();

            // Limpa qualquer estilo ativo residual por segurança
            link.classList.remove("font-[1000]", "text-[15px]", "border-b-2", "border-[#623f25]");

            // Validação inteligente da rota ativa
            // Destaca se o path for idêntico ou se for a raiz da área (/Admin) mapeando para Home
            if (currentPath === targetPath || 
               (targetPath === '/admin/index' && currentPath === '/admin') || 
               (targetPath === '/admin/index' && currentPath === '/admin/')) {
                
                link.classList.add("font-[1000]", "text-[15px]", "border-b-2", "border-[#623f25]");
            }
        });
    });
</script>
</body>
</html>