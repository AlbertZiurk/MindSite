        </a>

        <div class="flex items-center gap-3 md:gap-8">
            <ul class="hidden md:flex items-center gap-6 text-sm font-medium" style="color:var(--text)">
                <li><a href="/#home"     class="nav-link hover:opacity-70 transition-opacity px-1 py-1">Home</a></li>
                <li><a href="/#sobrenos" class="nav-link hover:opacity-70 transition-opacity px-1 py-1">Sobre nós</a></li>
                <li><a href="/#servicos" class="nav-link hover:opacity-70 transition-opacity px-1 py-1">Serviços</a></li>
