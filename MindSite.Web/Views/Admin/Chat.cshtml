    </button>
    <button id="mcReply" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2.5 transition-opacity" style="color:var(--text)">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Responder
    </button>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
const ME            = @Model.UsuarioAtual.Id;
const CONTATO_ID    = @(Model.ContatoSelecionadoId?.ToString() ?? "0");
const IS_GRUPO      = @(Model.IsGrupoSuporte ? "true" : "false");
const THREAD_USER_ID = @(Model.GrupoThreadUserId?.ToString() ?? "0");
const msgBox        = document.getElementById('msgBox');
const msgInput      = document.getElementById('msgInput');
let pendingFile     = null;

function openModal(id)  { document.getElementById(id)?.classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }

// Configuração da conexão SignalR para o chat em tempo real
const conn = new signalR.HubConnectionBuilder()
    .withUrl('/chatHub')
    .withAutomaticReconnect()
    .build();

// Recebe e exibe mensagens do canal de suporte em grupo
conn.on('ReceiveGrupoMessage', (msg) => {
    if (!IS_GRUPO || !THREAD_USER_ID || !msgBox) return;
    if (msg.threadUserId !== THREAD_USER_ID) return;
    const isMe = msg.remetenteId === ME;
    const div  = document.createElement('div');
    div.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-1 msg-animate msg-wrapper group`;
    div.setAttribute('data-msg-id', msg.id);
    div.setAttribute('data-is-me', isMe ? 'true' : 'false');
    div.setAttribute('data-is-grupo', 'true');
    let gmContent = '', ctxData = '';
    if (msg.conteudo && msg.conteudo.startsWith('{"_t":"F"')) {
        try {
            const gd = JSON.parse(msg.conteudo);
            const gmImg = /\.(png|jpe?g)$/i.test(gd.url || '');
            gmContent = gmImg
                ? `<img src="${esc(gd.url)}" alt="${esc(gd.nome)}" class="max-w-[200px] rounded-lg cursor-pointer" onclick="abrirFileViewer('${esc(gd.url)}','${esc(gd.nome)}',${isMe})" style="max-height:150px;object-fit:cover">`
                : `<a href="#" onclick="abrirFileViewer('${esc(gd.url)}','${esc(gd.nome)}',${isMe});return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 ${esc(gd.nome)}</a>`;
        } catch(e) { gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`; ctxData = msg.conteudo; }
    } else if (msg.conteudo && msg.conteudo.startsWith('{"_t":"Q"')) {
        try {
            const qd = JSON.parse(msg.conteudo);
            ctxData = qd.msg || '';
            gmContent = `<div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)"><span class="text-[10px] truncate block" style="color:var(--text-muted)">${esc((qd.ref||'').slice(0,80))}</span></div><span class="msg-conteudo">${escMsg(qd.msg||'')}</span>`;
        } catch(e) { gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`; ctxData = msg.conteudo; }
    } else {
        ctxData = msg.conteudo || '';
        gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`;
    }
    div.setAttribute('data-conteudo', ctxData);
    const dotBtn = `<button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>`;
    const senderName = !isMe ? `<span class="msg-sender-name text-[10px] font-bold" style="color:var(--brown)">${esc(msg.nomeRemetente)}</span>` : '';
    const bubble = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1 max-w-xs">${senderName}${gmContent}<span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span></div>`;
    if (!isMe) {
        const ini = (msg.nomeRemetente || '?').split(' ').slice(0,2).map(p => p[0]).join('').toUpperCase();
        div.innerHTML = `<div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mr-2 self-start" style="background:var(--brown);color:#fff">${ini}</div>${bubble}${dotBtn}`;
    } else {
        div.innerHTML = `${dotBtn}${bubble}`;
    }
    msgBox.appendChild(div);
    msgBox.scrollTop = msgBox.scrollHeight;
    atualizarSidebarGrupo(msg.conteudo);
});

// Atualiza a prévia de última mensagem na sidebar do suporte
function atualizarSidebarGrupo(texto) {
    const item = document.querySelector('.contact-item[href="?grupoSuporte=true"]');
    if (!item) return;
    const prev = item.querySelector('p.text-xs');
    if (prev) prev.textContent = texto;
}

// Envia mensagem ou arquivo para a thread de suporte do usuário selecionado
async function enviarGrupoMsgAdmin(e) {
    e.preventDefault();
    if (!msgInput || !THREAD_USER_ID) return;
    if (pendingFile) {
        const fd = new FormData();
        fd.append('arquivo', pendingFile);
        pendingFile = null;
        msgInput.value = ''; msgInput.style.height = '';
        document.getElementById('fileInputGrupo').value = '';
        try {
            const res  = await fetch('/Admin/UploadChatArquivo', { method: 'POST', body: fd });
            const data = await res.json();
            if (!data.ok) { 
                // MODIFICADO: Substituído alert por injeção de texto e abertura do modalErroArquivo
                const txtErro = document.getElementById('txtErroArquivo');
                if (txtErro) txtErro.textContent = data.erro || 'Erro ao enviar arquivo.';
                openModal('modalErroArquivo');
                return; 
            }
            await conn.invoke('SendGrupoMessageAdmin', THREAD_USER_ID, JSON.stringify({ _t: 'F', url: data.url, nome: data.nome }));
        } catch(er) { 
            console.error(er); 
            // MODIFICADO: Substituído alert genérico por modal de erro
            const txtErro = document.getElementById('txtErroArquivo');
            if (txtErro) txtErro.textContent = 'Erro ao enviar arquivo.';
            openModal('modalErroArquivo');
        }
        return;
    }
    let txt = msgInput.value.trim();
    if (!txt) return;
    msgInput.value = ''; msgInput.style.height = '';
    if (_replyMsgId) {
        const w = document.querySelector(`.msg-wrapper[data-msg-id="${_replyMsgId}"]`);
        const refText = w?.dataset.conteudo || '';
        txt = JSON.stringify({ _t: 'Q', ref: refText.slice(0,100), refId: _replyMsgId, msg: txt });
        cancelarReply();
    }
    try { await conn.invoke('SendGrupoMessageAdmin', THREAD_USER_ID, txt); }
    catch(er) { console.error(er); }
}

// Recebe e exibe mensagens diretas entre admin e contato selecionado
conn.on('ReceiveMessage', (msg) => {
    const emConv = (msg.remetenteId === CONTATO_ID && msg.destinatarioId === ME)
                || (msg.remetenteId === ME && msg.destinatarioId === CONTATO_ID);
    if (emConv && msgBox) {
        appendMsg(msg);
        if (msg.remetenteId === CONTATO_ID)
            conn.invoke('MarkRead', CONTATO_ID).catch(console.error);
    }
    atualizarSidebar(msg);
});

// Atualiza os recibos de leitura das mensagens enviadas
conn.on('MessagesRead', (leuId) => {
    if (leuId === CONTATO_ID)
        document.querySelectorAll('.msg-receipt').forEach(el => {
            el.textContent = '✓✓'; el.style.color = '#16a34a';
        });
});

// Cria e insere o elemento de mensagem direta na área de chat
function appendMsg(msg) {
    if (!msgBox) return;
    const isMe = msg.remetenteId === ME;
    const div  = document.createElement('div');
    div.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-1 msg-animate msg-wrapper group`;
    div.setAttribute('data-msg-id', msg.id);
    div.setAttribute('data-is-me', isMe ? 'true' : 'false');
    div.setAttribute('data-is-grupo', 'false');
    const dotBtn = `<button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>`;
    let inner = '', ctxData = '';
    if (msg.conteudo && msg.conteudo.startsWith('{"_t":"')) {
        try {
            const d = JSON.parse(msg.conteudo);
            if (d._t === 'F') {
                const fImg = /\.(png|jpe?g)$/i.test(d.url || '');
                const fContent = fImg
                    ? `<img src="${esc(d.url)}" alt="${esc(d.nome)}" class="max-w-[220px] rounded-lg cursor-pointer" onclick="abrirFileViewer('${esc(d.url)}','${esc(d.nome)}',${isMe})" style="max-height:160px;object-fit:cover">`
                    : `<a href="#" onclick="abrirFileViewer('${esc(d.url)}','${esc(d.nome)}',${isMe});return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 ${esc(d.nome)}</a>`;
                inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1">${fContent}<span class="text-[10px] opacity-60 self-end flex items-center gap-1">${msg.enviadaEm}${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}</span></div>`;
            } else if (d._t === 'Q') {
                ctxData = d.msg || '';
                inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1"><div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)"><span class="text-[10px] truncate block" style="color:var(--text-muted)">${esc((d.ref||'').slice(0,80))}</span></div><span class="msg-conteudo">${escMsg(d.msg||'')}</span><span class="text-[10px] opacity-60 self-end flex items-center gap-1">${msg.enviadaEm}${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}</span></div>`;
            } else {
                ctxData = msg.conteudo;
                inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1"><span class="msg-conteudo">${escMsg(msg.conteudo)}</span><span class="text-[10px] opacity-60 self-end flex items-center gap-1">${msg.enviadaEm}${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}</span></div>`;
            }
        } catch(e) {
            ctxData = msg.conteudo;
            inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1"><span class="msg-conteudo">${escMsg(msg.conteudo)}</span><span class="text-[10px] opacity-60 self-end flex items-center gap-1">${msg.enviadaEm}${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}</span></div>`;
        }
    } else {
        ctxData = msg.conteudo || '';
        inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1"><span class="msg-conteudo">${escMsg(msg.conteudo)}</span><span class="text-[10px] opacity-60 self-end flex items-center gap-1">${msg.enviadaEm}${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}</span></div>`;
    }
    div.setAttribute('data-conteudo', ctxData);
    div.innerHTML = isMe ? `${dotBtn}${inner}` : `${inner}${dotBtn}`;
    msgBox.appendChild(div);
    msgBox.scrollTop = msgBox.scrollHeight;
}

// Atualiza a prévia de última mensagem na sidebar de conversas diretas
function atualizarSidebar(msg) {
    const outroId = msg.remetenteId === ME ? msg.destinatarioId : msg.remetenteId;
    const item    = document.querySelector(`.contact-item[href*="contatoId=${outroId}"]`);
    if (!item) return;
    const prev = item.querySelector('p.text-xs, .text-xs.truncate');
    if (!prev) return;
    let preview = msg.conteudo;
    if (preview && preview.startsWith('{"_t":"F"')) preview = '📎 Arquivo';
    else if (preview && preview.startsWith('{"_t":"'))  preview = '📋 Atualização';
    prev.textContent = preview;
}

// Envia mensagem ou arquivo na conversa direta com o contato selecionado
async function enviarMsg(e) {
    e.preventDefault();
    if (!msgInput || !CONTATO_ID) return;
    if (pendingFile) {
        const fd = new FormData();
        fd.append('arquivo', pendingFile);
        pendingFile = null;
        msgInput.value = ''; msgInput.style.height = '';
        document.getElementById('fileInput').value = '';
        try {
            const res  = await fetch('/Admin/UploadChatArquivo', { method: 'POST', body: fd });
            const data = await res.json();
            if (!data.ok) { 
                // MODIFICADO: Substituído alert por injeção de texto e abertura do modalErroArquivo
                const txtErro = document.getElementById('txtErroArquivo');
                if (txtErro) txtErro.textContent = data.erro || 'Erro ao enviar arquivo.';
                openModal('modalErroArquivo');
                return; 
            }
            await conn.invoke('SendMessage', CONTATO_ID, JSON.stringify({ _t: 'F', url: data.url, nome: data.nome }));
        } catch(er) { 
            console.error(er); 
            // MODIFICADO: Substituído alert por modal de erro
            const txtErro = document.getElementById('txtErroArquivo');
            if (txtErro) txtErro.textContent = 'Erro ao enviar arquivo.';
            openModal('modalErroArquivo');
        }
        return;
    }
    let txt = msgInput.value.trim();
    if (!txt) return;
    msgInput.value = ''; msgInput.style.height = '';
    if (_replyMsgId) {
        const w = document.querySelector(`.msg-wrapper[data-msg-id="${_replyMsgId}"]`);
        const refText = w?.dataset.conteudo || '';
        txt = JSON.stringify({ _t: 'Q', ref: refText.slice(0,100), refId: _replyMsgId, msg: txt });
        cancelarReply();
    }
    try { await conn.invoke('SendMessage', CONTATO_ID, txt); }
    catch(er) { console.error(er); }
}

function esc(s) {
    if (!s) return '';
    return s.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function escMsg(s) {
    if (!s) return '';
    return esc(s).replace(/\n/g, '<br>');
}

let adminFilterMode = 'nome';
const adminSearchInput = document.querySelector('input[aria-label="Buscar conversa"]');

document.querySelectorAll('.filter-opt').forEach(btn => {
    btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        adminFilterMode = f;
        document.querySelectorAll('.filter-opt').forEach(b => { b.style.fontWeight = ''; b.style.color = 'var(--text)'; });
        btn.style.fontWeight = 'bold'; btn.style.color = 'var(--brown)';
        document.getElementById('filterDropdown')?.classList.add('hidden');
        if (adminSearchInput) { adminSearchInput.value = ''; adminSearchInput.placeholder = f === 'nome' ? 'Buscar por nome...' : 'Pesquisar conversa...'; if (f !== 'recente') adminSearchInput.focus(); }
        filtrarContatos('');
    });
});

// Filtra a lista de contatos pelo texto digitado na busca
function filtrarContatos(q) {
    const lq = q.toLowerCase().trim();
    document.querySelectorAll('.contact-item').forEach(el => {
        if (!lq) { el.style.display = ''; return; }
        const nome = (el.querySelector('.contact-name')?.textContent || '').toLowerCase();
        el.style.display = nome.includes(lq) ? '' : 'none';
    });
}

conn.start().then(() => {
    if (!IS_GRUPO && CONTATO_ID) {
        conn.invoke('MarkRead', CONTATO_ID).catch(console.error);
        conn.invoke('SetChatActive', CONTATO_ID).catch(console.error);
    } else if (IS_GRUPO) {
        conn.invoke('SetGrupoSuporteActive').catch(console.error);
    }
}).catch(console.error);

msgInput?.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); if (IS_GRUPO && THREAD_USER_ID) enviarGrupoMsgAdmin(e); else enviarMsg(e); }
});
msgInput?.addEventListener('input', function(e) {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 112) + 'px';
    if (e.inputType === 'insertText') {
        const pos = this.selectionStart;
        const val = this.value;
        const last = val[pos - 1] || '';
        const prev = pos >= 2 ? val[pos - 2] : null;
        if ((prev === null || prev === '\n') && last && last !== last.toUpperCase()) {
            this.value = val.slice(0, pos - 1) + last.toUpperCase() + val.slice(pos);
            this.setSelectionRange(pos, pos);
        }
    }
});

if (msgBox) msgBox.scrollTop = msgBox.scrollHeight;

// Inicializa dropdowns de menu do chat
function setupDrop(btnId, dropId) {
    const btn = document.getElementById(btnId);
    const drop = document.getElementById(dropId);
    if (!btn || !drop) return;
    btn.addEventListener('click', e => { e.stopPropagation(); drop.classList.toggle('hidden'); });
    document.addEventListener('click', () => drop.classList.add('hidden'));
}
setupDrop('filterMenuBtn', 'filterDropdown');
setupDrop('threadMenuBtn', 'threadMenuDropdown');
setupDrop('chatMenuBtn',   'chatMenuDropdown');

document.querySelectorAll('.filter-opt').forEach(btn => {
    btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        const inp = document.querySelector('input[aria-label="Buscar conversa"]');
        if (f === 'nome') { filtrarContatos(''); if (inp) inp.value = ''; }
        else { filtrarContatos(''); if (inp) inp.value = ''; }
    });
});

// Captura arquivo selecionado e armazena para envio junto com a próxima mensagem
document.getElementById('fileInput')?.addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    pendingFile = file;
    if (msgInput) { msgInput.value = `📎 ${file.name}`; msgInput.focus(); }
});
document.getElementById('fileInputGrupo')?.addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    pendingFile = file;
    if (msgInput) { msgInput.value = `📎 ${file.name}`; msgInput.focus(); }
});

// Busca e exibe detalhes do serviço ativo do usuário selecionado
async function adminVerServicoInfo(usuarioId) {
    document.getElementById('chatMenuDropdown')?.classList.add('hidden');
    document.getElementById('threadMenuDropdown')?.classList.add('hidden');
    openModal('adminModalServicoInfo');
    const siInfos = document.getElementById('adminSiInfos');
    if (siInfos) siInfos.innerHTML = '<p class="text-sm text-center py-4" style="color:var(--text-muted)">Carregando...</p>';
    try {
        const res = await fetch(`/Admin/GetServicoAtivoDetalhesAdmin?usuarioId=${usuarioId}`);
        const d = await res.json();
        if (!d.ok) {
            if (siInfos) siInfos.innerHTML = '<p class="text-sm text-center py-4" style="color:#ef4444">Nenhum serviço ativo encontrado.</p>';
            return;
        }
        let rows = '';
        if (d.nome)    rows += `<div class="flex justify-between"><span style="color:var(--text-muted)">Nome:</span><span style="color:var(--text);font-weight:600">${esc(d.nome)}</span></div>`;
        if (d.tipo)    rows += `<div class="flex justify-between"><span style="color:var(--text-muted)">Tipo:</span><span style="color:var(--text)">${esc(d.tipo)}</span></div>`;
        if (d.status)  rows += `<div class="flex justify-between"><span style="color:var(--text-muted)">Status:</span><span style="color:var(--text)">${esc(d.status)}</span></div>`;
        if (d.valor)   rows += `<div class="flex justify-between"><span style="color:var(--text-muted)">Valor:</span><span style="color:var(--text)">R$ ${esc(d.valor)}</span></div>`;
        if (d.entrega) rows += `<div class="flex justify-between"><span style="color:var(--text-muted)">Entrega:</span><span style="color:var(--text)">${esc(d.entrega)}</span></div>`;
        if (d.obs)     rows += `<div class="flex flex-col gap-1"><span style="color:var(--text-muted)">Observações:</span><p class="text-xs leading-relaxed" style="color:var(--text)">${esc(d.obs)}</p></div>`;
        if (siInfos) siInfos.innerHTML = rows || '<p style="color:var(--text-muted)">—</p>';
    } catch(e) {
        if (siInfos) siInfos.innerHTML = '<p class="text-sm text-center py-4" style="color:#ef4444">Erro ao carregar.</p>';
    }
}

// Busca e exibe o perfil do usuário no modal lateral
async function verPerfil(id) {
    try {
        const r = await fetch(`/Admin/GetUsuarioApi?id=${id}`);
        if (!r.ok) return;
        const u = await r.json();
        document.getElementById('perfilNome').textContent = u.nomeCompleto;
        const badges = {
            'Fornecedor': 'badge-amber', 'Cliente': 'badge-blue', 'Admin': 'badge-red'
        };
        const statusBadges = {
            'Ativo': 'badge-green', 'Pendente': 'badge-amber',
            'Bloqueado': 'badge-red', 'Inativo': 'badge-amber'
        };
        const row = (label, val) =>
            `<div class="flex justify-between"><span style="color:var(--text-muted)">${label}:</span><span style="color:var(--text)">${val}</span></div>`;
        let html = row('E-mail', esc(u.email))
                 + row('Telefone', esc(u.telefone))
                 + `<div class="flex justify-between"><span style="color:var(--text-muted)">Tipo:</span><span class="badge ${badges[u.role] ?? ''}">${u.role}</span></div>`
                 + `<div class="flex justify-between"><span style="color:var(--text-muted)">Status:</span><span class="badge ${statusBadges[u.status] ?? ''}">${u.status}</span></div>`
                 + row('Cadastro', esc(u.criadoEm));
        if (u.linkedInUrl) html += row('LinkedIn', `<a href="${esc(u.linkedInUrl)}" target="_blank" class="text-blue-500 hover:underline truncate max-w-[200px]">${esc(u.linkedInUrl)}</a>`);
        if (u.whatsAppNumero) html += row('WhatsApp', esc(u.whatsAppNumero));
        if (u.cpf) html += row('CPF', esc(u.cpf));
        if (u.sobreVoce) html += `<div class="flex flex-col gap-1"><span style="color:var(--text-muted)">Sobre:</span><p class="text-xs leading-relaxed" style="color:var(--text)">${esc(u.sobreVoce)}</p></div>`;
        document.getElementById('perfilInfos').innerHTML = html;
        openModal('modalPerfilUsuario');
    } catch(e) { console.error(e); }
}

let _ctxMsgId = 0, _ctxIsMe = false, _ctxIsGrupo = false;
let _replyMsgId = 0;

// Abre o menu de contexto de uma mensagem posicionando-o próximo ao botão clicado
function openMsgMenu(e, btn) {
    e.stopPropagation();
    const w = btn.closest('.msg-wrapper');
    if (!w) return;
    _ctxMsgId   = parseInt(w.dataset.msgId) || 0;
    _ctxIsMe    = w.dataset.isMe === 'true';
    _ctxIsGrupo = w.dataset.isGrupo === 'true';
    const isFile = (w.dataset.conteudo || '') === '' && w.querySelector('img,a[download]');
    document.getElementById('mcCopy')?.classList.toggle('hidden', !!isFile);
    document.getElementById('mcReply')?.classList.toggle('hidden', !!isFile);
    const menu = document.getElementById('msgContextMenu');
    if (!menu) return;
    menu.classList.remove('hidden');
    const rect = btn.getBoundingClientRect();
    let left = rect.left, top = rect.bottom + 4;
    const mw = menu.offsetWidth || 180, mh = menu.offsetHeight || 80;
    if (left + mw > window.innerWidth - 8) left = window.innerWidth - mw - 8;
    if (top + mh > window.innerHeight - 8) top = rect.top - mh - 4;
    menu.style.left = Math.max(8, left) + 'px';
    menu.style.top  = Math.max(8, top)  + 'px';
}

document.addEventListener('click', () => document.getElementById('msgContextMenu')?.classList.add('hidden'));

document.getElementById('mcCopy')?.addEventListener('click', () => {
    const w = document.querySelector(`.msg-wrapper[data-msg-id="${_ctxMsgId}"]`);
    const t = w?.querySelector('.msg-conteudo')?.textContent || w?.dataset.conteudo || '';
    if (t) navigator.clipboard?.writeText(t);
});

document.getElementById('mcReply')?.addEventListener('click', () => {
    const w = document.querySelector(`.msg-wrapper[data-msg-id="${_ctxMsgId}"]`);
    const refText = w?.dataset.conteudo || '';
    const senderEl = w?.querySelector('.msg-sender-name');
    const who = _ctxIsMe ? 'Você' : (senderEl?.textContent || '');
    _replyMsgId = _ctxMsgId;
    const panelId = _ctxIsGrupo ? 'replyPreviewGrupo' : 'replyPreview';
    const textId  = _ctxIsGrupo ? 'replyTextGrupo'   : 'replyText';
    const rt = document.getElementById(textId);
    if (rt) rt.textContent = `${who}: ${refText.slice(0,80)}`;
    document.getElementById(panelId)?.classList.remove('hidden');
    msgInput?.focus();
});

// Cancela o modo de resposta e oculta a prévia de citação
function cancelarReply() {
    _replyMsgId = 0;
    document.getElementById('replyPreview')?.classList.add('hidden');
    document.getElementById('replyPreviewGrupo')?.classList.add('hidden');
    const rt = document.getElementById('replyText');
    if (rt) rt.textContent = '';
    const rtg = document.getElementById('replyTextGrupo');
    if (rtg) rtg.textContent = '';
}

// Abre o visualizador de arquivo em tela cheia com opção de download
function abrirFileViewer(url, nome, isMe) {
    const isImg = /\.(png|jpe?g)$/i.test(url || '');
    const body  = document.getElementById('fileViewerBody');
    const dlBtn = document.getElementById('fileViewerDownload');
    const nomeEl = document.getElementById('fileViewerNome');
    if (nomeEl) nomeEl.textContent = nome;
    if (body) {
        if (isImg) {
            body.innerHTML = `<img src="${url}" alt="${nome}" style="max-width:90vw;max-height:78vh;object-fit:contain;border-radius:0.75rem;box-shadow:0 25px 50px rgba(0,0,0,.5)">`;
        } else {
            body.innerHTML = `<div class="flex flex-col items-center gap-4 py-12">
              <div style="font-size:5rem">📄</div>
              <p class="text-white font-semibold text-lg">${nome}</p>
              <p class="text-white/60 text-sm">PDF — clique em Baixar para abrir</p>
            </div>`;
        }
    }
    if (dlBtn) {
        dlBtn.href     = url;
        dlBtn.download = nome;
        dlBtn.classList.toggle('hidden', isMe === true);
    }
    openModal('modalFileViewer');
}
</script>
}