                    @{ DateTime? lastDirDate = null; }
                    @foreach (var m in Model.Mensagens)
                    {
                        var dDate = m.EnviadaEm.ToLocalTime().Date;
                        if (lastDirDate == null || lastDirDate.Value != dDate) {
                            lastDirDate = dDate;
                            string dLabel = dDate == DateTime.Now.Date ? "Hoje" : dDate == DateTime.Now.Date.AddDays(-1) ? "Ontem" : dDate.ToString("dd/MM/yyyy");
                            <div class="flex items-center justify-center my-2">
