                                    <div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)">
                                        <span class="text-[10px] truncate block" style="color:var(--text-muted)">@Html.Raw(System.Net.WebUtility.HtmlEncode(admQRef.Length > 80 ? admQRef[..80] + "…" : admQRef))</span>
                                    </div>
