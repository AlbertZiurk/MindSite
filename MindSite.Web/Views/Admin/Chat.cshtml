                            </div>
                        }
                        bool isMe = m.RemetenteId == Model.UsuarioAtual.Id;
                        bool admIsFile = m.Conteudo.StartsWith("{\"_t\":\"F\"");
                        bool admIsQ    = m.Conteudo.StartsWith("{\"_t\":\"Q\"");
                        string admMUrl = "", admMNome = "", admQRef = "", admQMsg = "";
                        if (admIsFile) {
                            try {
                                using var admDoc = System.Text.Json.JsonDocument.Parse(m.Conteudo);
                                var admRoot = admDoc.RootElement;
                                admMUrl  = admRoot.TryGetProperty("url",  out var admu) ? (admu.GetString() ?? "") : "";
                                admMNome = admRoot.TryGetProperty("nome", out var admn) ? (admn.GetString() ?? "") : "";
                            } catch { admIsFile = false; }
                        } else if (admIsQ) {
                            try {
                                using var qdoc = System.Text.Json.JsonDocument.Parse(m.Conteudo);
                                var qr = qdoc.RootElement;
                                admQRef = qr.TryGetProperty("ref", out var qrf) ? (qrf.GetString() ?? "") : "";
                                admQMsg = qr.TryGetProperty("msg", out var qmv) ? (qmv.GetString() ?? "") : "";
                            } catch { admIsQ = false; }
                        }
                        string admCtxData = admIsFile ? "" : (admIsQ ? admQMsg : m.Conteudo);
                        bool admHasMenu = !admIsFile || admIsQ || !admIsFile;
                        <div class="flex @(isMe ? "justify-end" : "justify-start") items-end gap-1 msg-animate msg-wrapper group"
                             data-msg-id="@m.Id" data-is-me="@(isMe ? "true" : "false")"
                             data-conteudo="@admCtxData" data-is-grupo="false">
                            @if (isMe) {
