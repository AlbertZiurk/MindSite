@using MindSite.Entities; 
@using MindSite.Enums; 
@using MindSite.Services; 
@using MindSite.Filters; 
@model MindSite.ViewModels.ChatViewModel
@{
    ViewData["Title"] = "Monitor de Chat";
    Layout = "_LayoutAdmin";
    var pinadosIds = Model.ContatosPinados.Select(c => c.Id).ToHashSet();
}

@section Styles {
<style>
#msgBox::-webkit-scrollbar { width:4px; }
#msgBox::-webkit-scrollbar-thumb { background:var(--chat-scrollbar); border-radius:4px; }
#msgBox::-webkit-scrollbar-track { background:transparent; }
</style>
}

@* Modal detalhes do serviço (admin) *@
<div id="adminModalServicoInfo" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('adminModalServicoInfo')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Detalhes do Serviço</h3>
        </div>
        <div class="px-6 py-5">
            <div id="adminSiInfos" class="flex flex-col gap-3 text-sm" style="color:var(--text)"></div>
        </div>
        <div class="px-6 pb-6">
            <button onclick="closeModal('adminModalServicoInfo')" class="w-full py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Fechar</button>
        </div>
    </div>
</div>

<!-- Modal de Erro no Upload de Arquivos -->
<div id="modalErroArquivo" class="fixed inset-0 z-50 hidden flex items-center justify-center bg-black/50 backdrop-blur-sm animate-fade-in">
    <div class="bg-white rounded-xl shadow-2xl max-w-sm w-full mx-4 overflow-hidden border border-gray-100 transform transition-all scale-100">
        <!-- Cabeçalho com tom de Alerta -->
        <div class="bg-red-50 px-6 py-4 border-b border-red-100 flex items-center gap-3">
            <div class="p-2 bg-red-100 text-red-600 rounded-lg">
                <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/>
                </svg>
            </div>
            <h3 class="text-lg font-bold text-red-800">Falha no Arquivo</h3>
        </div>
        
        <!-- Conteúdo Dinâmico -->
        <div class="px-6 py-6 text-center">
            <p id="txtErroArquivo" class="text-sm text-gray-600 font-medium leading-relaxed">
                Ocorreu um erro ao processar o arquivo selecionado.
            </p>
        </div>
        
        <!-- Ação de Fechamento -->
        <div class="bg-gray-50 px-6 py-3 border-t border-gray-100 flex justify-end">
            <button type="button" 
                    onclick="closeModal('modalErroArquivo')" 
                    class="px-4 py-2 bg-gray-800 hover:bg-gray-900 text-white text-xs font-semibold rounded-lg shadow-sm transition-colors focus:outline-none focus:ring-2 focus:ring-offset-2 focus:ring-gray-800">
                Entendido
            </button>
        </div>
    </div>
</div>

<!-- Modal Visualizador de Arquivo/Mídia (Invocado pelo abrirFileViewer) -->
<div id="modalFileViewer" class="fixed inset-0 z-50 hidden flex flex-col bg-black/95 backdrop-blur-md animate-fade-in">
    <!-- Barra de Ferramentas Superior -->
    <div class="flex items-center justify-between px-6 py-4 border-b border-white/10 bg-black/40">
        <div class="flex flex-col max-w-[70%]">
            <span id="fileViewerNome" class="text-white font-medium text-sm truncate">arquivo</span>
            <span class="text-white/40 text-[11px]">Visualização de mídia</span>
        </div>
        <div class="flex items-center gap-3">
            <!-- Botão Download (visível apenas para recebidos) -->
            <a id="fileViewerDownload" href="#" download class="p-2 text-white/80 hover:text-white bg-white/10 hover:bg-white/20 rounded-lg transition-all text-xs flex items-center gap-1 font-medium px-3" title="Baixar arquivo">
                <svg class="w-4 h-4" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/>
                </svg>
                <span>Baixar</span>
            </a>
            <!-- Botão Fechar -->
            <button type="button" onclick="closeModal('modalFileViewer')" class="p-2 text-white/60 hover:text-white bg-white/10 hover:bg-white/20 rounded-lg transition-all" aria-label="Fechar">
                <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24">
                    <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
                </svg>
            </button>
        </div>
    </div>

    <!-- Área de Exibição Central -->
    <div id="fileViewerBody" class="flex-1 flex items-center justify-center p-4 overflow-auto">
        <!-- Gerado dinamicamente via JS (Imagem ou Ícone de documento) -->
    </div>
</div>

@* MODAL PERFIL DE USUÁRIO (inline, sem navegação) *@
<div id="modalPerfilUsuario" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalPerfilUsuario')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2);max-height:85vh">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 id="perfilNome" class="font-bold text-white text-base truncate">...</h3>
        </div>
        <div class="px-6 py-5 overflow-y-auto" style="max-height:60vh">
            <div id="perfilInfos" class="flex flex-col gap-3 text-sm"></div>
        </div>
        <div class="px-6 pb-6">
            <button onclick="closeModal('modalPerfilUsuario')" class="w-full py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Fechar</button>
        </div>
    </div>
</div>

<div class="mx-4 md:mx-6 my-4">

    <div class="chat-outer-wrap flex ms-card gap-4 bg-[#F4F2ED] border-none overflow-hidden" style="height:calc(100vh - 112px)">

        @* Lista de conversas *@
        <div class="chat-contacts-panel @((Model.ContatoSelecionado != null || (Model.IsGrupoSuporte && Model.GrupoThreadUserId.HasValue)) ? "hidden md:flex md:w-80 md:min-w-[260px] bg-white rounded-2xl border border-[#6B462C]/15 shadow-sm overflow-hidden" : "flex w-full md:w-80") flex-col flex-shrink-0" style="border-right:1.5px solid color-mix(in srgb, var(--brown) 30%, transparent)">
            @{
                string meIniSb = string.Join("", Model.UsuarioAtual.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
            }
            <div class="p-4 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                <div class="flex items-center gap-3 min-w-0">
                    <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background:var(--admin-avatar);color:#fff">@meIniSb.ToUpper()</div>
                    <div class="min-w-0">
                        <p class="font-bold text-sm truncate" style="color:var(--text)">@Model.UsuarioAtual.NomeCompleto</p>
                        <p class="text-xs" style="color:var(--text-muted)">Minha conta</p>
                    </div>
                </div>
                <div class="relative flex-shrink-0">
                    <button id="filterMenuBtn" class="p-1.5 rounded-lg hover:opacity-70 transition-opacity" style="color:var(--text-muted)" aria-label="Filtrar">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
                        </svg>
                    </button>
                    <div id="filterDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:230px">
                        <div class="px-4 pt-3 pb-2">
                            <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Filtrar por</p>
                        </div>
                        <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70" data-filter="nome" style="color:var(--text)">Nome do Usuário</button>
                        <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70" data-filter="recente" style="color:var(--text)">Conversas Recentes</button>
                    </div>
                </div>
            </div>
            <div class="px-4 py-3 border-b flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                <input type="text" placeholder="Buscar conversa..." oninput="filtrarContatos(this.value)"
                       class="ms-input text-sm w-full" style="border-radius:.75rem" aria-label="Buscar conversa"/>
            </div>
            <div class="flex-1 overflow-y-auto">

                @* Equipe de Administradores *@
                @if (Model.ContatosPinados.Any())
                {
                    <div class="px-4 pt-3 pb-1">
                        <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Equipe Admin</p>
                    </div>
                    @foreach (var adm in Model.ContatosPinados)
                    {
                        string admIni = string.Join("", adm.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                        bool admActive = adm.Id == Model.ContatoSelecionadoId;
                        var admNaoLidas = Model.Conversas.FirstOrDefault(c => c.Contato.Id == adm.Id)?.NaoLidas ?? 0;
                        <a href="?contatoId=@adm.Id"
                           class="contact-item flex items-center gap-3 p-4 @(admActive ? "active" : "")"
                           aria-label="Chat com @adm.NomeCompleto" aria-current="@(admActive ? "true" : "false")">
                            <div class="relative">
                                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                                     style="background:var(--admin-avatar);color:#fff">@admIni.ToUpper()</div>
                                @if (adm.IsOnline)
                                {
                                    <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2" style="background:#16a34a;border-color:var(--bg)"></span>
                                }
                            </div>
                            <div class="flex-1 min-w-0">
                                <span class="contact-name text-sm font-bold truncate block" style="color:var(--text)">@adm.NomeCompleto</span>
                                <span class="text-[10px]" style="@(adm.IsOnline ? "color:#16a34a" : "color:var(--text-muted)")">
                                    @(adm.IsOnline ? "● Online" : "○ Offline") · Admin
                                </span>
                            </div>
                            @if (admNaoLidas > 0)
                            {
                                <span class="w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center flex-shrink-0"
                                      style="background:var(--brown);color:#fff">@admNaoLidas</span>
                            }
                        </a>
                    }
                }

                @* Suporte MindSite — threads por usuário *@
                <div class="mx-4 my-2 border-t" style="border-color:var(--border)"></div>
                <div class="px-4 pb-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Suporte MindSite</p>
                </div>
                @if (!Model.GrupoThreads.Any())
                {
                    <p class="text-center text-xs py-3 px-4" style="color:var(--text-muted)">Nenhuma conversa de suporte</p>
                }
                @foreach (var t in Model.GrupoThreads)
                {
                    string tIniSb = string.Join("", t.Usuario.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                    string roleClassSb = t.Usuario.Role == UserRole.Fornecedor ? "badge-amber" : "badge-blue";
                    bool threadActive = Model.IsGrupoSuporte && Model.GrupoThreadUserId == t.Usuario.Id;
                    <a href="?grupoSuporte=true&threadUserId=@t.Usuario.Id"
                       class="contact-item flex items-center gap-3 p-4 @(threadActive ? "active" : "")"
                       aria-label="Suporte — @t.Usuario.NomeCompleto">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                             style="background:var(--brown);color:#fff">@tIniSb.ToUpper()</div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline gap-1">
                                <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@t.Usuario.NomeCompleto</span>
                                @if (t.Quando.HasValue) {
                                    <span class="text-[10px] flex-shrink-0" style="color:var(--text-muted)">
                                        @(t.Quando.Value.Date == DateTime.UtcNow.Date
                                            ? t.Quando.Value.ToLocalTime().ToString("HH:mm")
                                            : t.Quando.Value.ToLocalTime().ToString("dd/MM"))
                                    </span>
                                }
                            </div>
                            <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@(t.UltimaMensagem != "" ? t.UltimaMensagem : "● Suporte")</p>
                        </div>
                    </a>
                }

                <div class="mx-4 my-2 border-t" style="border-color:var(--border)"></div>
                <div class="px-4 pb-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Conversas</p>
                </div>

                @if (!Model.Conversas.Where(c => !pinadosIds.Contains(c.Contato.Id)).Any() && !Model.ContatosPinados.Any())
                {
                    <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma conversa ainda</p>
                }
                @foreach (var c in Model.Conversas.Where(cv => !pinadosIds.Contains(cv.Contato.Id)))
                {
                    string ini = string.Join("", c.Contato.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                    bool active = c.Contato.Id == Model.ContatoSelecionadoId;
                    <a href="?contatoId=@c.Contato.Id"
                       class="contact-item flex items-center gap-3 p-4 @(active ? "active" : "")"
                       aria-label="Conversa com @c.Contato.NomeCompleto" aria-current="@(active ? "true" : "false")">
                        <div class="relative">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                                 style="background:var(--brown);color:#fff">@ini.ToUpper()</div>
                            @if (c.Contato.IsOnline)
                            {
                                <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2" style="background:#16a34a;border-color:var(--bg)"></span>
                            }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline">
                                <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@c.Contato.NomeCompleto</span>
                                @if (c.Quando.HasValue)
                                {
                                    <span class="text-[10px] ml-1 flex-shrink-0" style="color:var(--text-muted)">
                                        @(c.Quando.Value.Date == DateTime.UtcNow.Date ? c.Quando.Value.ToLocalTime().ToString("HH:mm") : c.Quando.Value.ToLocalTime().ToString("dd/MM"))
                                    </span>
                                }
                            </div>
                            <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@c.UltimaMensagem</p>
                        </div>
                        @if (c.NaoLidas > 0)
                        {
                            <span class="w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center flex-shrink-0"
                                  style="background:var(--brown);color:#fff" aria-label="@c.NaoLidas não lidas">@c.NaoLidas</span>
                        }
                    </a>
                }
            </div>
        </div>

        @* Área de mensagens *@
        <div class="chat-msg-panel @((Model.ContatoSelecionado != null || Model.IsGrupoSuporte) ? "flex" : "hidden md:flex") flex-1 flex flex-col rounded-2xl overflow-hidden border border-[#6B462C]/20 shadow-sm bg-white min-w-0">
            @if (Model.ContatoSelecionado == null && !Model.IsGrupoSuporte)
            {
                <div class="flex-1 flex items-center justify-center flex-col gap-4" style="color:var(--text-muted)">
                    <svg class="w-16 h-16 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                    </svg>
                    <p class="text-base font-medium">Selecione uma conversa para começar</p>
                </div>
            }
            else if (Model.IsGrupoSuporte && !Model.GrupoThreadUserId.HasValue)
            {
                @* Thread list view *@
                <div class="px-4 py-3 border-b flex items-center gap-3 flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                    <div class="ms-suporte-logo w-9 h-9 rounded-full overflow-hidden flex-shrink-0 flex items-center justify-center">
                        <img src="/img/logo_img.png" alt="MindSite" class="w-8 h-8 object-contain"/>
                    </div>
                    <div class="flex-1 min-w-0">
                        <p class="font-bold text-sm" style="color:var(--text)">Suporte MindSite <span class="badge badge-brown text-[9px] ml-1">Grupo</span></p>
                        <p class="text-xs" style="color:var(--text-muted)">@Model.GrupoThreads.Count conversas abertas</p>
                    </div>
                </div>
                <div class="flex-1 overflow-y-auto">
                    @if (!Model.GrupoThreads.Any())
                    {
                        <div class="flex-1 flex items-center justify-center flex-col gap-4 h-full" style="color:var(--text-muted)">
                            <svg class="w-12 h-12 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/></svg>
                            <p class="text-sm">Nenhuma mensagem de suporte ainda</p>
                        </div>
                    }
                    @foreach (var t in Model.GrupoThreads)
                    {
                        string tIni = string.Join("", t.Usuario.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                        <a href="?grupoSuporte=true&threadUserId=@t.Usuario.Id"
                           class="contact-item flex items-center gap-3 p-4"
                           aria-label="Thread de @t.Usuario.NomeCompleto">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                                 style="background:var(--brown);color:#fff">@tIni.ToUpper()</div>
                            <div class="flex-1 min-w-0">
                                <div class="flex justify-between items-baseline gap-1">
                                    <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@t.Usuario.NomeCompleto</span>
                                    @if (t.Quando.HasValue) {
                                        <span class="text-[10px] flex-shrink-0" style="color:var(--text-muted)">
                                            @(t.Quando.Value.Date == DateTime.UtcNow.Date
                                                ? t.Quando.Value.ToLocalTime().ToString("HH:mm")
                                                : t.Quando.Value.ToLocalTime().ToString("dd/MM"))
                                        </span>
                                    }
                                </div>
                                <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@t.UltimaMensagem</p>
                            </div>
                        </a>
                    }
                </div>
            }
            else if (Model.IsGrupoSuporte && Model.GrupoThreadUserId.HasValue)
            {
                @* Thread conversation view *@
                <div class="px-4 py-3 border-b flex items-center gap-3 flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                    <a href="/Admin/Chat?grupoSuporte=true" class="p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0 md:hidden" style="color:var(--brown)" aria-label="Voltar">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    <a href="/Admin/Chat?grupoSuporte=true" class="p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0 hidden md:flex" style="color:var(--brown)" aria-label="Voltar para threads">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                    @if (Model.GrupoThreadUser != null) {
                        string tIni2 = string.Join("", Model.GrupoThreadUser.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                        <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background:var(--brown);color:#fff">@tIni2.ToUpper()</div>
                        <div class="flex-1 min-w-0">
                            <p class="font-bold text-sm" style="color:var(--text)">@Model.GrupoThreadUser.NomeCompleto <span class="badge @(Model.GrupoThreadUser.Role == UserRole.Fornecedor ? "badge-amber" : "badge-blue") text-[9px] ml-1">@Model.GrupoThreadUser.Role</span></p>
                            <p class="text-xs" style="color:var(--text-muted)">Thread de Suporte</p>
                        </div>
                        <div class="relative flex-shrink-0">
                            <button id="threadMenuBtn" class="p-2 rounded-lg hover:opacity-70 transition-opacity" style="color:var(--text-muted)" aria-label="Opções">
                                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                            </button>
                            <div id="threadMenuDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:210px">
                                <button onclick="adminVerServicoInfo(@Model.GrupoThreadUser.Id)" class="w-full text-left px-4 py-2.5 text-sm hover:bg-[var(--bg2)] flex items-center gap-2" style="color:var(--text)">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                    Detalhes do Serviço
                                </button>
                                <button onclick="verPerfil(@Model.GrupoThreadUser.Id)" class="w-full text-left px-4 py-2.5 text-sm hover:bg-[var(--bg2)] flex items-center gap-2" style="color:var(--text)">
                                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                    Perfil do Usuário
                                </button>
                            </div>
                        </div>
                    }
                </div>
                <div id="msgBox" class="flex-1 overflow-y-auto p-5 space-y-3" style="background:var(--bg)">
                    @if (!Model.GrupoMensagens.Any()) {
                        <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma mensagem nesta thread.</p>
                    }
                    @{ DateTime? lastGrpDate = null; }
                    @foreach (var gm in Model.GrupoMensagens)
                    {
                        var gDate = gm.EnviadaEm.ToLocalTime().Date;
                        if (lastGrpDate == null || lastGrpDate.Value != gDate) {
                            lastGrpDate = gDate;
                            string gLabel = gDate == DateTime.Now.Date ? "Hoje" : gDate == DateTime.Now.Date.AddDays(-1) ? "Ontem" : gDate.ToString("dd/MM/yyyy");
                            <div class="flex items-center justify-center my-2">
                                <span class="text-[11px] px-3 py-1 rounded-full" style="background:var(--bg2);color:var(--text-muted)">@gLabel</span>
                            </div>
                        }
                        bool isMe = gm.RemetenteId == Model.UsuarioAtual.Id;
                        bool isSistema = gm.EhSistema;
                        if (isSistema)
                        {
                            <div class="flex justify-center msg-animate">
                                <div class="rounded-xl px-4 py-2 text-xs text-center max-w-sm" style="background:var(--brown-bg);color:var(--text-muted)">
                                    <span style="color:var(--brown)">⚙</span> @gm.Conteudo
                                    <span class="block mt-0.5 opacity-60">@gm.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                            </div>
                        }
                        else
                        {
                            bool agmIsFile = gm.Conteudo.StartsWith("{\"_t\":\"F\"");
                            bool agmIsQ    = gm.Conteudo.StartsWith("{\"_t\":\"Q\"");
                            string agmUrl = "", agmNome = "", agmQRef = "", agmQMsg = "";
                            if (agmIsFile) {
                                try {
                                    using var agdoc = System.Text.Json.JsonDocument.Parse(gm.Conteudo);
                                    var agr = agdoc.RootElement;
                                    agmUrl  = agr.TryGetProperty("url",  out var agu) ? (agu.GetString() ?? "") : "";
                                    agmNome = agr.TryGetProperty("nome", out var agn) ? (agn.GetString() ?? "") : "";
                                } catch { agmIsFile = false; }
                            } else if (agmIsQ) {
                                try {
                                    using var qdoc = System.Text.Json.JsonDocument.Parse(gm.Conteudo);
                                    var qr = qdoc.RootElement;
                                    agmQRef = qr.TryGetProperty("ref", out var qrf) ? (qrf.GetString() ?? "") : "";
                                    agmQMsg = qr.TryGetProperty("msg", out var qmv) ? (qmv.GetString() ?? "") : "";
                                } catch { agmIsQ = false; }
                            }
                            string agmCtxData = agmIsFile ? "" : (agmIsQ ? agmQMsg : gm.Conteudo);
                            <div class="flex @(isMe ? "justify-end" : "justify-start") items-end gap-1 msg-animate msg-wrapper group"
                                 data-msg-id="@gm.Id" data-is-me="@(isMe ? "true" : "false")"
                                 data-conteudo="@agmCtxData" data-is-grupo="true">
                                @if (!isMe) {
                                    <div class="w-7 h-7 rounded-full flex items-center justify-center text-xs font-bold flex-shrink-0 mr-2 self-start" style="background:var(--brown);color:#fff">
                                        @string.Join("", gm.Remetente.NomeCompleto.Split(' ').Take(2).Select(p => p[0])).ToUpper()
                                    </div>
                                }
                                @if (isMe) {
                                    <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                    </button>
                                }
                                <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1 max-w-xs">
                                    @if (!isMe) { <span class="msg-sender-name text-[10px] font-bold" style="color:var(--brown)">@gm.Remetente.NomeCompleto</span> }
                                    @if (agmIsQ) {
                                        <div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)">
                                            <span class="text-[10px] truncate block" style="color:var(--text-muted)">@Html.Raw(System.Net.WebUtility.HtmlEncode(agmQRef.Length > 80 ? agmQRef[..80] + "…" : agmQRef))</span>
                                        </div>
                                        <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(agmQMsg).Replace("\n","<br>"))</span>
                                    } else if (agmIsFile) {
                                        bool agmImg = new[] { ".png", ".jpg", ".jpeg" }.Contains(System.IO.Path.GetExtension(agmUrl).ToLowerInvariant());
                                        @if (agmImg) {
                                            <img src="@agmUrl" alt="@agmNome" class="max-w-[200px] rounded-lg cursor-pointer" onclick="abrirFileViewer('@agmUrl','@agmNome',@(isMe ? "true" : "false"))" style="max-height:150px;object-fit:cover"/>
                                        } else {
                                            <a href="#" onclick="abrirFileViewer('@agmUrl','@agmNome',@(isMe ? "true" : "false"));return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 @agmNome</a>
                                        }
                                    } else {
                                        <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(gm.Conteudo).Replace("\n","<br>"))</span>
                                    }
                                    <span class="text-[10px] opacity-60 self-end">@gm.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                                </div>
                                @if (!isMe) {
                                    <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                        <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                                    </button>
                                }
                            </div>
                        }
                    }
                </div>
                <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0">
                    <input type="file" id="fileInputGrupo" class="hidden" accept="image/png,image/jpeg,application/pdf"/>
                    <div id="replyPreviewGrupo" class="hidden mb-2 flex items-center gap-2 rounded-xl px-3 py-1.5" style="background:var(--brown-subtle)">
                        <div class="w-0.5 self-stretch rounded-full flex-shrink-0" style="background:var(--brown)"></div>
                        <span id="replyTextGrupo" class="text-xs flex-1 truncate" style="color:var(--text-muted)"></span>
                        <button type="button" onclick="cancelarReply()" class="flex-shrink-0 p-0.5" style="color:var(--text-muted)"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                    </div>
                    <form id="chatForm" class="chat-input-form flex items-center gap-3 bg-[#F4F3EE] rounded-2xl border border-[#6B462C]/20 px-2 py-1.5 focus-within:border-[#6B462C]/50 focus-within:ring-2 focus-within:ring-[#6B462C]/10 transition-all"
                          onsubmit="enviarGrupoMsgAdmin(event)">
                        <button type="button" onclick="document.getElementById('fileInputGrupo').click()"
                                class="chat-attach-btn text-[#8d6945] hover:text-[#4d392a] transition-colors flex-shrink-0 hover:scale-110 active:scale-95 p-2" title="Anexar arquivo">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9l-2 3H5a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                            </svg>
                        </button>
                        <textarea id="msgInput" rows="1" maxlength="4000"
                               class="chat-input-text flex-1 bg-transparent focus:outline-none text-sm text-[#4d392a] placeholder-[#8d6945]/60"
                               placeholder="Escreva sua mensagem..." autocomplete="off" aria-label="Resposta de suporte"></textarea>
                        <button type="submit"
                                class="chat-send-btn bg-[#6B462C] text-white p-2 rounded-xl hover:bg-[#4d392a] transition-all hover:scale-105 active:scale-95 shadow-sm flex-shrink-0 m-1.5" title="Enviar">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M2.01 21L23 12L2.01 3L2 10l15 2l-15 2z"/>
                            </svg>
                        </button>
                    </form>
                </div>
            }
            else
            {
                <div class="px-4 py-3 border-b flex items-center justify-between" style="border-color:var(--border);background:var(--bg2)">
                    <div class="flex items-center gap-3">
                    <a href="/Admin/Chat" class="md:hidden p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0" style="color:var(--brown)" aria-label="Voltar">
                        <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                    </a>
                        <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold"
                             style="background:@(Model.ContatoSelecionado.Role == UserRole.Admin ? "var(--admin-avatar)" : "var(--brown)");color:#fff">
                            @string.Join("", Model.ContatoSelecionado.NomeCompleto.Split(' ').Take(2).Select(p => p[0])).ToUpper()
                        </div>
                        <div>
                            <p class="font-bold text-sm" style="color:var(--text)">
                                @Model.ContatoSelecionado.NomeCompleto
                                @if (Model.ContatoSelecionado.Role == UserRole.Admin)
                                {
                                    <span class="badge badge-red text-[9px] ml-1">Admin</span>
                                }
                            </p>
                            <p class="text-xs" id="statusOnline" style="@(Model.ContatoSelecionado.IsOnline ? "color:#16a34a" : "color:var(--text-muted)")">
                                @(Model.ContatoSelecionado.IsOnline ? "● Online" : "○ Offline")
                            </p>
                        </div>
                    </div>
                    <div class="relative flex-shrink-0">
                        <button id="chatMenuBtn" class="p-2 rounded-lg hover:opacity-70 transition-opacity" style="color:var(--text-muted)" aria-label="Opções">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/></svg>
                        </button>
                        <div id="chatMenuDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:210px">
                            <button onclick="adminVerServicoInfo(@Model.ContatoSelecionado.Id)" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2" style="color:var(--text)">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                Detalhes do Serviço
                            </button>
                            <button onclick="verPerfil(@Model.ContatoSelecionado.Id)" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2" style="color:var(--text)">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                Perfil do Usuário
                            </button>
                        </div>
                    </div>
                </div>

                <div id="msgBox" class="flex-1 overflow-y-auto p-5 space-y-3" style="background:var(--bg)">
