@model MindSite.ViewModels.CadastrarFornecedorViewModel
@{
    ViewData["Title"] = "Cadastrar Fornecedor";
    Layout = "_LayoutAdmin";
}

<div class="container mx-auto px-6 py-8 max-w-lg">
    <div class="mb-6">
        <a asp-controller="Admin" asp-action="Usuarios" asp-route-tipo="Fornecedores"
           class="text-sm hover:underline flex items-center gap-1 mb-4" style="color:var(--text-muted)">
            <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
            Voltar
        </a>
        <h1 class="font-inria text-3xl font-bold" style="color:var(--text)">Cadastrar Fornecedor</h1>
        <p class="text-sm mt-1" style="color:var(--text-muted)">Criar uma nova conta de Fornecedor diretamente</p>
    </div>

    @* Formulário *@
    <div class="ms-card p-8">
        <form asp-controller="Admin" asp-action="CadastrarFornecedor" method="post" class="flex flex-col gap-4">
            @Html.AntiForgeryToken()

            <div asp-validation-summary="ModelOnly" class="text-red-500 text-sm"></div>

            @* Dados da conta *@
            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Nome Completo *</label>
                <input asp-for="NomeCompleto" class="ms-input" placeholder="João da Silva"/>
                <span asp-validation-for="NomeCompleto" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">E-mail *</label>
                <input asp-for="Email" type="email" class="ms-input" placeholder="joao@exemplo.com"/>
                <span asp-validation-for="Email" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Telefone *</label>
                <input asp-for="Telefone" type="tel" class="ms-input" placeholder="(11) 99999-9999"/>
                <span asp-validation-for="Telefone" class="text-red-500 text-xs"></span>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Senha *</label>
                <input asp-for="Senha" type="password" class="ms-input" placeholder="Mínimo 6 caracteres"/>
                <span asp-validation-for="Senha" class="text-red-500 text-xs"></span>
            </div>

            <hr style="border-color:var(--border)"/>

            @* Dados profissionais (opcionais) *@
            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">LinkedIn</label>
                <input asp-for="LinkedInUrl" type="url" class="ms-input" placeholder="https://linkedin.com/in/perfil"/>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">WhatsApp</label>
                <input asp-for="WhatsAppNumero" type="tel" class="ms-input" placeholder="(11) 99999-9999"/>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">CPF</label>
                <input asp-for="CPF" class="ms-input" placeholder="000.000.000-00" maxlength="14"/>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Sobre</label>
                <textarea asp-for="SobreVoce" class="ms-textarea w-full" rows="4"
                          placeholder="Experiência, especialidades, portfólio..."></textarea>
            </div>

            <div class="flex gap-3 mt-2">
                <a asp-controller="Admin" asp-action="Usuarios" asp-route-tipo="Fornecedores"
                   class="btn-ghost flex-1 text-center text-sm">Cancelar</a>
                <button type="submit" class="btn-primary flex-1 text-center text-sm">Cadastrar Fornecedor</button>
            </div>
        </form>
    </div>
</div>
