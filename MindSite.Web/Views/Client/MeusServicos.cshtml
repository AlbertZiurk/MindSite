@* Modal pagamento unificado (stripe + webhook) *@
<div id="modalPix" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10 text-center">
        <button onclick="closeModal('modalPix')" class="absolute top-4 right-4" style="color:var(--text-muted)" aria-label="Fechar">
            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
        </button>
        <h3 class="font-inria text-2xl font-bold mb-2" style="color:var(--text)">Finalizar Pagamento</h3>
        <p id="pixValorTexto" class="text-sm mb-4 font-semibold" style="color:var(--brown)"></p>
        
        <div class="rounded-xl p-4 mb-4 text-left text-sm" style="background:var(--bg2);color:var(--text)">
            <p class="font-semibold mb-2" style="color:var(--brown)">Selecione a forma de pagamento:</p>
            
            <div class="flex flex-col gap-2">
                @* <label class="flex items-center gap-2 cursor-pointer p-1">
                    <input type="radio" name="metodoPagamento" value="pix" checked class="accent-amber-800" />
                    <span>Pix (Aprovação imediata via Stripe)</span>
                </label> *@
                <label class="flex items-center gap-2 cursor-pointer p-1">
                    <input type="radio" name="metodoPagamento" value="card" class="accent-amber-800" />
                    <span>Cartão de Crédito / Débito</span>
                </label>
            </div>
        </div>

        <form asp-controller="Pagamento" asp-action="IniciarCheckout" method="post">
