@model List<MindSite.Entities.Servico>
@{
ViewData["Title"] = "Meus Projetos";
Layout = "_LayoutClient";
var tipoNome = new Dictionary<MindSite.Enums.TipoServico, string> {
{ MindSite.Enums.TipoServico.Ecommerce, "E-commerce" },
{ MindSite.Enums.TipoServico.Blog, "Blog" },
{ MindSite.Enums.TipoServico.Designing, "Web Design" },
{ MindSite.Enums.TipoServico.Marketing, "Marketing" },
{ MindSite.Enums.TipoServico.SiteInstitucional, "Sites Institucionais" },
{ MindSite.Enums.TipoServico.LandingPage, "Landing Pages" },
{ MindSite.Enums.TipoServico.OnePage, "One-Page Sites" },
{ MindSite.Enums.TipoServico.Portfolio, "Portfólios Digitais" },
{ MindSite.Enums.TipoServico.BlogPortal, "Blogs e Portais" },
{ MindSite.Enums.TipoServico.PlataformaEAD, "Plataformas EAD" },
{ MindSite.Enums.TipoServico.LinkBio, "Links para Bio" },
{ MindSite.Enums.TipoServico.SistemaWeb, "Sistemas Web" },
{ MindSite.Enums.TipoServico.Agendamento, "Agendamento" },
{ MindSite.Enums.TipoServico.MultiIdioma, "Multi-idiomas" },
{ MindSite.Enums.TipoServico.Redesign, "Redesign" },
{ MindSite.Enums.TipoServico.Manutencao, "Manutenção" },
{ MindSite.Enums.TipoServico.SEO, "SEO & Performance" },
{ MindSite.Enums.TipoServico.Migracao, "Migração" }
};
int currentUserId = (int)(ViewBag.UserId ?? 0);
// Inject anti-forgery token for proposal choice forms
}

@* Modal concluir *@
<div id="modalConcluir" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center"
aria-modal="true" role="dialog">
<div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
<div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10 text-center">
<svg class="w-14 h-14 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
style="color:var(--brown)" aria-hidden="true">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
</svg>
<h3 class="font-inria text-2xl font-bold mb-2" style="color:var(--text)">Concluir Projeto</h3>
<p class="text-sm mb-6" style="color:var(--text-muted)">Confirma que o projeto foi entregue e você está
satisfeito?</p>
<form id="formConcluir" asp-controller="Client" asp-action="ConcluirServico" method="post">
@Html.AntiForgeryToken()
<input type="hidden" id="hidConcluirId" name="id" />
<div class="flex gap-3">
<button type="button" onclick="closeModal('modalConcluir')" class="btn-ghost flex-1">Cancelar</button>
<button type="submit" class="btn-primary flex-1">Confirmar</button>
</div>
</form>
</div>
</div>

@* Modal solicitar mudança *@
<div id="modalMudanca" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center"
aria-modal="true" role="dialog">
<div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
<div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10">
<button onclick="closeModal('modalMudanca')" class="absolute top-4 right-4" style="color:var(--text-muted)"
aria-label="Fechar">
<svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12" />
</svg>
</button>
<h3 class="font-inria text-2xl font-bold mb-4" style="color:var(--text)">Solicitar Mudança</h3>
<form id="formMudanca" asp-controller="Client" asp-action="SolicitarMudanca" method="post"
class="flex flex-col gap-4">
@Html.AntiForgeryToken()
<input type="hidden" id="hidMudancaId" name="servicoId" />
<div>
<label class="text-xs font-semibold uppercase tracking-wider mb-1 block"
style="color:var(--text-muted)">Descreva o que precisa mudar</label>
<textarea name="descricao" class="ms-textarea" rows="5" required
placeholder="Detalhe a mudança desejada..."></textarea>
</div>
<div class="flex gap-3">
<button type="button" onclick="closeModal('modalMudanca')" class="btn-ghost flex-1">Cancelar</button>
<button type="submit" class="btn-secondary flex-1">Enviar</button>
</div>
</form>
</div>
</div>

@* Modal escolher fornecedor *@
<div id="modalEscolher" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center"
aria-modal="true" role="dialog">
<div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
<div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10 text-center">
<svg class="w-14 h-14 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"
style="color:var(--brown)" aria-hidden="true">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z" />
</svg>
<h3 class="font-inria text-2xl font-bold mb-2" style="color:var(--text)">Confirmar Fornecedor</h3>
<p class="text-sm mb-1" style="color:var(--text-muted)">Você está escolhendo:</p>
<p id="escolherNome" class="font-semibold mb-1" style="color:var(--text)"></p>
<p id="escolherValor" class="text-sm mb-6" style="color:var(--brown)"></p>
<form id="formEscolher" asp-controller="Client" asp-action="EscolherFornecedor" method="post">
<input type="hidden" id="hidEscolherServicoId" name="servicoId" />
<input type="hidden" id="hidEscolherPropostaId" name="propostaId" />
<div class="flex gap-3">
<button type="button" onclick="closeModal('modalEscolher')" class="btn-ghost flex-1">Cancelar</button>
<button type="submit" class="btn-primary flex-1">Confirmar</button>
</div>
</form>
</div>
</div>

@* Modal cancelar projeto *@
<div id="modalCancelar" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center"
aria-modal="true" role="dialog">
<div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
<div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10 text-center">
<svg class="w-14 h-14 mx-auto mb-4" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:#ef4444"
aria-hidden="true">
<path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z" />
</svg>
<h3 class="font-inria text-2xl font-bold mb-2" style="color:var(--text)">Cancelar Projeto</h3>
<p id="avisoCancelar" class="text-sm mb-6" style="color:var(--text-muted)">Tem certeza que deseja cancelar este
projeto? O fornecedor será notificado.</p>
<form id="formCancelar" asp-controller="Client" asp-action="CancelarServico" method="post">
@Html.AntiForgeryToken()
<input type="hidden" id="hidCancelarId" name="id" />
<div class="flex gap-3">
<button type="button" onclick="closeModal('modalCancelar')" class="btn-ghost flex-1">Voltar</button>
<button type="submit" class="btn-danger flex-1">Cancelar Projeto</button>
