// Submete a conclusão do serviço ao servidor
async function executarConcluir() {
    try {
        const siAcoes = document.getElementById('siAcoes');
        let servicoId = siAcoes?.dataset?.servicoId;
        if (!servicoId) {
            const r = await fetch(`/Client/GetServicoAtivoDetalhes?fornecedorId=${CONTATO_ID}`);
            const d = await r.json();
            if (!d.ok || !d.id) { 
                mostrarErroGeral('Nenhum serviço ativo encontrado.'); 
                closeModal('modalConfirm'); 
                return; 
            }
            servicoId = d.id;
        }
        const token = document.querySelector('[name=__RequestVerificationToken]')?.value;
        const form = new FormData();
        form.append('id', servicoId);
        if (token) form.append('__RequestVerificationToken', token);
        const res = await fetch('/Client/ConcluirServicoChatJson', { method: 'POST', body: form });
        const data = await res.json();
        closeModal('modalConfirm');
        closeModal('modalServicoInfo');
        
        if (data.ok) {
            mostrarSucessoMudanca(data.msg || 'Serviço concluído com sucesso!');
        } else {
            mostrarErroGeral(data.erro || 'Erro ao concluir serviço.');
        }
    } catch(e) {
        closeModal('modalConfirm');
        mostrarErroGeral('Erro ao processar a solicitação.');
    }
}

