// Submete a solicitação de mudança preenchida pelo cliente
async function enviarMudancaChat() {
    const novas  = document.getElementById('mcNovasInstrucoes').value.trim();
    const erroEl = document.getElementById('erroMudancaChat');
    if (!novas) {
        if (erroEl) { erroEl.textContent = 'Novas Instruções é obrigatório.'; erroEl.classList.remove('hidden'); }
        return;
    }
    const servicoId    = document.getElementById('mcServicoId').value;
    const fornecedorId = document.getElementById('mcFornecedorId').value;
    const nomeProjeto  = document.getElementById('mcNomeProjeto').value;
    const observacoes  = document.getElementById('mcObservacoes').value;
    const token        = document.querySelector('#formMudancaChat [name=__RequestVerificationToken]')?.value;

    const form = new FormData();
    form.append('servicoId',            servicoId);
    form.append('fornecedorId',         fornecedorId);
    form.append('nomeProjeto',          nomeProjeto);
    form.append('observacoes',          observacoes);
    form.append('novasInstrucoes',      novas);
    if (token) form.append('__RequestVerificationToken', token);

    const btn = document.querySelector('#formMudancaChat .btn-secondary');
    if (btn) { btn.disabled = true; btn.textContent = 'Enviando...'; }
    try {
        const res  = await fetch('/Client/SolicitarMudancaChat', { method: 'POST', body: form });
        const data = await res.json();
        if (data.ok) {
            closeModal('modalMudancaChat');
        } else {
            if (erroEl) { erroEl.textContent = data.erro || 'Erro ao enviar.'; erroEl.classList.remove('hidden'); }
        }
    } catch(e) {
        if (erroEl) { erroEl.textContent = 'Erro de comunicação.'; erroEl.classList.remove('hidden'); }
    } finally {
        if (btn) { btn.disabled = false; btn.textContent = 'Salvar Alterações'; }
    }
}

// Carrega e exibe os detalhes de uma mudança que o cliente enviou
async function abrirVerMudanca(mudancaId) {
    const el = document.getElementById('verMudancaConteudo');
    if (!el) return;
    el.innerHTML = '<p class="text-sm" style="color:var(--text-muted)">Carregando...</p>';
    openModal('modalVerMudanca');
    try {
        const res = await fetch(`/Client/GetMudancaInfo?id=${mudancaId}`);
        if (!res.ok) { el.innerHTML = '<p class="text-sm" style="color:#ef4444">Mudança não encontrada.</p>'; return; }
        const data = await res.json();
        let campos = [];
        try { campos = JSON.parse(data.descricao || '[]'); } catch(e) {}
        let html = '';
        if (Array.isArray(campos) && campos.length) {
            campos.forEach(c => {
                html += `<div class="rounded-xl p-3" style="background:var(--bg2);border:1px solid var(--border)">
                  <p class="text-xs font-bold uppercase tracking-wider mb-1" style="color:var(--text-muted)">${esc(c.campo || '')}</p>
                  ${c.de ? `<p class="text-xs line-through mb-0.5" style="color:var(--text-muted)">${esc(c.de)}</p>` : ''}
                  <p class="text-sm" style="color:var(--text)">${esc(c.para || '')}</p>
                </div>`;
            });
        } else {
            html = `<p class="text-sm" style="color:var(--text)">${esc(data.descricao || '')}</p>`;
        }
        if (data.aceita)   html += `<p class="text-xs font-bold mt-2" style="color:#16a34a">✓ Aceita pelo fornecedor</p>`;
        if (data.recusada) html += `<p class="text-xs font-bold mt-2" style="color:#ef4444">✗ Recusada pelo fornecedor</p>`;
        el.innerHTML = html;
    } catch(e) {
        el.innerHTML = '<p class="text-sm" style="color:#ef4444">Erro ao carregar.</p>';
    }
}

// Configuração da conexão SignalR para o chat em tempo real
const conn = new signalR.HubConnectionBuilder()
    .withUrl('/chatHub')
    .withAutomaticReconnect()
    .build();

// Recebe e exibe mensagens do canal de suporte em grupo
conn.on('ReceiveGrupoMessage', (msg) => {
    if (!IS_GRUPO || !msgBox) return;
    const isMe = msg.remetenteId === ME;
    const div  = document.createElement('div');
    div.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-1 msg-animate msg-wrapper group`;
    div.setAttribute('data-msg-id', msg.id);
    div.setAttribute('data-is-me', isMe ? 'true' : 'false');
    div.setAttribute('data-is-grupo', 'true');
    let avatar = isMe ? '' : `<div class="w-7 h-7 rounded-full overflow-hidden flex-shrink-0 mr-2 self-start flex items-center justify-center"><img src="/img/logo_img.png" class="w-7 h-7 object-contain"/></div>`;
    let sender = isMe ? '' : `<span class="msg-sender-name text-[10px] font-bold" style="color:var(--brown)">${esc(msg.nomeRemetente)}</span>`;
    let gmContent = '', ctxData = '';
    if (msg.conteudo && msg.conteudo.startsWith('{"_t":"F"')) {
        try {
            const gd = JSON.parse(msg.conteudo);
            const gmImg = /\.(png|jpe?g)$/i.test(gd.url || '');
            gmContent = gmImg
                ? `<img src="${esc(gd.url)}" alt="${esc(gd.nome)}" class="max-w-[200px] rounded-lg cursor-pointer" onclick="abrirFileViewer('${esc(gd.url)}','${esc(gd.nome)}',${isMe})" style="max-height:150px;object-fit:cover">`
                : `<a href="#" onclick="abrirFileViewer('${esc(gd.url)}','${esc(gd.nome)}',${isMe});return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 ${esc(gd.nome)}</a>`;
        } catch(e) { gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`; ctxData = msg.conteudo; }
    } else if (msg.conteudo && msg.conteudo.startsWith('{"_t":"Q"')) {
        try {
            const qd = JSON.parse(msg.conteudo);
            ctxData = qd.msg || '';
            gmContent = `<div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)"><span class="text-[10px] truncate block" style="color:var(--text-muted)">${esc((qd.ref||'').slice(0,80))}</span></div><span class="msg-conteudo">${escMsg(qd.msg||'')}</span>`;
        } catch(e) { gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`; ctxData = msg.conteudo; }
    } else {
        ctxData = msg.conteudo || '';
        gmContent = `<span class="msg-conteudo">${escMsg(msg.conteudo)}</span>`;
    }
    div.setAttribute('data-conteudo', ctxData);
    const bubble = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1 max-w-xs">${sender}${gmContent}<span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span></div>`;
    div.innerHTML = avatar + (isMe ? mkDotBtn() : '') + bubble + (!isMe ? mkDotBtn() : '');
    const typing = document.getElementById('typingIndicator');
    if (typing) typing.classList.add('hidden');
    msgBox.appendChild(div);
    msgBox.scrollTop = msgBox.scrollHeight;
    atualizarSidebarGrupo(msg.conteudo);
});

// Atualiza a prévia de última mensagem na sidebar do grupo de suporte
function atualizarSidebarGrupo(texto) {
    const item = document.querySelector('.contact-item[href="?grupoSuporte=true"]');
    if (!item) return;
    const prev = item.querySelector('p.text-xs');
    if (prev) prev.textContent = texto;
}

// Envia mensagem ou arquivo para o canal de suporte em grupo
async function enviarGrupoMsg(e) {
    e.preventDefault();
    if (!msgInput) return;
    if (pendingFile) {
        const fd   = new FormData();
        fd.append('arquivo', pendingFile);
        pendingFile = null;
        msgInput.value = ''; msgInput.style.height = '';
        document.getElementById('fileInputGrupo').value = '';
        try {
            const res  = await fetch('/Client/UploadChatArquivo', { method: 'POST', body: fd });
            const data = await res.json();
            if (!data.ok) { mostrarErroArquivo(data.erro || 'Erro ao enviar arquivo.'); return; }
            await conn.invoke('SendGrupoMessage', JSON.stringify({ _t: 'F', url: data.url, nome: data.nome }));
        } catch(er) { console.error(er); mostrarErroArquivo('Erro ao enviar arquivo.'); }
        return;
    }
    let txt = msgInput.value.trim();
    if (!txt) return;
    if (_replyMsgId) {
        const w = document.querySelector(`.msg-wrapper[data-msg-id="${_replyMsgId}"]`);
        const refText = w?.dataset.conteudo || '';
        txt = JSON.stringify({ _t: 'Q', ref: refText.slice(0,100), refId: _replyMsgId, msg: txt });
        cancelarReply();
    }
    msgInput.value = ''; msgInput.style.height = '';
    try { await conn.invoke('SendGrupoMessage', txt); }
    catch(er) { console.error(er); }
}

// Recebe e exibe mensagens diretas na conversa ativa
conn.on('ReceiveMessage', (msg) => {
    const emConv = (msg.remetenteId === CONTATO_ID && msg.destinatarioId === ME)
                || (msg.remetenteId === ME && msg.destinatarioId === CONTATO_ID);
    if (emConv && msgBox) {
        appendMsg(msg);
        if (msg.remetenteId === CONTATO_ID)
            conn.invoke('MarkRead', CONTATO_ID).catch(console.error);
    }
    atualizarSidebar(msg);
});

// Atualiza os recibos de leitura das mensagens enviadas
conn.on('MessagesRead', (leuId) => {
    if (leuId === CONTATO_ID)
        document.querySelectorAll('.msg-receipt').forEach(el => {
            el.textContent = '✓✓'; el.style.color = '#16a34a';
        });
});

// Desabilita o input ao receber notificação de conversa encerrada
conn.on('ConversationCleared', (data) => {
    if (data.contatoId === CONTATO_ID && msgBox) {
        msgBox.innerHTML = '<p class="text-center text-sm py-8" style="color:var(--text-muted)">Esta conversa foi encerrada.</p>';
        const inp = document.getElementById('msgInput');
        if (inp) { inp.disabled = true; inp.placeholder = 'Conversa encerrada.'; }
        const btn = document.querySelector('#chatForm button[type=submit]');
        if (btn) btn.disabled = true;
    }
});

// Escapa caracteres especiais para exibição segura no HTML
function esc(s) {
    if (!s) return '';
    return String(s).replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;');
}
function escMsg(s) {
    if (!s) return '';
    return esc(s).replace(/\n/g, '<br>');
}

// Monta o HTML de uma bolha de mensagem simples
function buildBubble(isMe, msg, text) {
    return `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1">
        <span class="msg-conteudo">${escMsg(text)}</span>
        <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
          ${msg.enviadaEm}
          ${isMe ? `<span class="msg-receipt font-bold">✓</span>` : ''}
        </span>
      </div>`;
}

// Cria o botão de opções de contexto de uma mensagem
function mkDotBtn() {
    return `<button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções"><svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg></button>`;
}

// Cria e insere o elemento de mensagem direta na área de chat
function appendMsg(msg) {
    if (!msgBox) return;
    const typing = document.getElementById('typingIndicator');
    if (typing) typing.classList.add('hidden');
    const isMe = msg.remetenteId === ME;
    const div  = document.createElement('div');
    div.className = `flex ${isMe ? 'justify-end' : 'justify-start'} items-end gap-1 msg-animate msg-wrapper group`;
    div.setAttribute('data-msg-id', msg.id);
    div.setAttribute('data-is-me', isMe ? 'true' : 'false');
    div.setAttribute('data-is-grupo', 'false');
    let inner = '';
    if (msg.conteudo && msg.conteudo.startsWith('{"_t":"')) {
        try {
            const d = JSON.parse(msg.conteudo);
            if (d._t === 'M') {
                inner = `<div class="msg-card msg-card-mudanca flex flex-col gap-2">
                  <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--brown)">Solicitação de Mudança</p>
                  <p class="text-sm" style="color:var(--text)">${esc(d.r || '')}</p>
                  <button onclick="abrirVerMudanca('${d.id}')" class="btn-secondary text-xs px-3 py-1.5 self-start">Visualizar Mudança</button>
                  <span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span>
                </div>`;
            } else if (d._t === 'R') {
                inner = `<div class="msg-card msg-card-rejeicao flex flex-col gap-2">
                  <p class="text-xs font-bold uppercase tracking-wider" style="color:#ef4444">${esc(d.r || 'Solicitação Rejeitada')}</p>
                  ${d.j ? `<p class="text-sm" style="color:var(--text)">${esc(d.j)}</p>` : ''}
                  <span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span>
                </div>`;
            } else if (d._t === 'V') {
                inner = `<div class="msg-card msg-card-valor flex flex-col gap-2">
                  <p class="text-xs font-bold uppercase tracking-wider" style="color:#16a34a">Atualização do Projeto</p>
                  <p class="text-sm" style="color:var(--text)">${esc(d.r || '')}</p>
                  ${d.v && parseFloat(d.v) > 0 ? `<p class="text-sm font-bold" style="color:#16a34a">+ R$ ${esc(d.v)}</p>` : ''}
                  <span class="text-[10px] opacity-60 self-end">${msg.enviadaEm}</span>
                </div>`;
            } else if (d._t === 'F') {
                const fImg = /\.(png|jpe?g)$/i.test(d.url || '');
                const fContent = fImg
                    ? `<img src="${esc(d.url)}" alt="${esc(d.nome)}" class="max-w-[220px] rounded-lg cursor-pointer" onclick="abrirFileViewer('${esc(d.url)}','${esc(d.nome)}',${isMe})" style="max-height:160px;object-fit:cover">`
                    : `<a href="#" onclick="abrirFileViewer('${esc(d.url)}','${esc(d.nome)}',${isMe});return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 ${esc(d.nome)}</a>`;
                inner = `<div class="${isMe ? 'bubble-sent' : 'bubble-recv'} flex flex-col gap-1">
                  ${fContent}
                  <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                    ${msg.enviadaEm}
                    ${isMe ? '<span class="msg-receipt font-bold">✓</span>' : ''}
                  </span>
                </div>`;
            } else {
                inner = buildBubble(isMe, msg, msg.conteudo);
            }
        } catch(e) {
            inner = buildBubble(isMe, msg, msg.conteudo);
        }
    } else {
        inner = buildBubble(isMe, msg, msg.conteudo);
    }
    const ctxData = msg.conteudo?.startsWith('{"_t":"F"') ? '' : (msg.conteudo?.startsWith('{"_t":"Q"') ? (() => { try { return JSON.parse(msg.conteudo).msg || ''; } catch(e) { return ''; } })() : (msg.conteudo || ''));
    div.setAttribute('data-conteudo', ctxData);
    const hasMenu = !msg.conteudo?.startsWith('{"_t":"M"') && !msg.conteudo?.startsWith('{"_t":"R"') && !msg.conteudo?.startsWith('{"_t":"V"');
    div.innerHTML = (isMe && hasMenu ? mkDotBtn() : '') + inner + (!isMe && hasMenu ? mkDotBtn() : '');
    msgBox.appendChild(div);
    msgBox.scrollTop = msgBox.scrollHeight;
}

// Atualiza a prévia de última mensagem na sidebar de conversas diretas
function atualizarSidebar(msg) {
    const outroId = msg.remetenteId === ME ? msg.destinatarioId : msg.remetenteId;
    const item    = document.querySelector(`.contact-item[href*="contatoId=${outroId}"]`);
    if (!item) return;
    const prev = item.querySelector('p.text-xs, .text-xs.truncate');
    if (!prev) return;
    let preview = msg.conteudo;
    if (preview && preview.startsWith('{"_t":"F"')) preview = '📎 Arquivo';
    else if (preview && preview.startsWith('{"_t":"'))  preview = '📋 Atualização';
    prev.textContent = preview;
}

// Envia mensagem ou arquivo na conversa direta com o contato selecionado
async function enviarMsg(e) {
    e.preventDefault();
    if (!msgInput || !CONTATO_ID) return;
    if (pendingFile) {
        const fd = new FormData();
        fd.append('arquivo', pendingFile);
        pendingFile = null;
        msgInput.value = ''; msgInput.style.height = '';
        document.getElementById('fileInput').value = '';
        try {
            const res  = await fetch('/Client/UploadChatArquivo', { method: 'POST', body: fd });
            const data = await res.json();
            if (!data.ok) { mostrarErroArquivo(data.erro || 'Erro ao enviar arquivo.'); return; }
            await conn.invoke('SendMessage', CONTATO_ID, JSON.stringify({ _t: 'F', url: data.url, nome: data.nome }));
        } catch(er) { console.error(er); mostrarErroArquivo('Erro ao enviar arquivo.'); }
        return;
    }
    let txt = msgInput.value.trim();
    if (!txt) return;
    if (_replyMsgId) {
        const w = document.querySelector(`.msg-wrapper[data-msg-id="${_replyMsgId}"]`);
        const refText = w?.dataset.conteudo || '';
        txt = JSON.stringify({ _t: 'Q', ref: refText.slice(0,100), refId: _replyMsgId, msg: txt });
        cancelarReply();
    }
    msgInput.value = ''; msgInput.style.height = '';
    try { await conn.invoke('SendMessage', CONTATO_ID, txt); }
    catch(er) { console.error(er); }
}

conn.start().then(() => {
    if (!IS_GRUPO && CONTATO_ID) {
        conn.invoke('MarkRead', CONTATO_ID).catch(console.error);
        conn.invoke('SetChatActive', CONTATO_ID).catch(console.error);
    } else if (IS_GRUPO) {
        conn.invoke('SetGrupoSuporteActive').catch(console.error);
    }
}).catch(console.error);

msgInput?.addEventListener('keydown', e => {
    if (e.key === 'Enter' && !e.shiftKey) { e.preventDefault(); IS_GRUPO ? enviarGrupoMsg(e) : enviarMsg(e); }
});
msgInput?.addEventListener('input', function(e) {
    this.style.height = 'auto';
    this.style.height = Math.min(this.scrollHeight, 112) + 'px';
    if (e.inputType === 'insertText') {
        const pos = this.selectionStart;
        const val = this.value;
        const last = val[pos - 1] || '';
        const prev = pos >= 2 ? val[pos - 2] : null;
        if ((prev === null || prev === '\n') && last && last !== last.toUpperCase()) {
            this.value = val.slice(0, pos - 1) + last.toUpperCase() + val.slice(pos);
            this.setSelectionRange(pos, pos);
        }
    }
});

if (msgBox) msgBox.scrollTop = msgBox.scrollHeight;

// Anexar arquivo
document.getElementById('fileInput')?.addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    pendingFile = file;
    if (msgInput) { msgInput.value = `📎 ${file.name}`; msgInput.focus(); }
});
document.getElementById('fileInputGrupo')?.addEventListener('change', function() {
    const file = this.files[0];
    if (!file) return;
    pendingFile = file;
    if (msgInput) { msgInput.value = `📎 ${file.name}`; msgInput.focus(); }
});

// Variáveis de estado do menu de contexto e modo de resposta
let _ctxMsgId = 0, _ctxIsMe = false, _ctxIsGrupo = false;
let _replyMsgId = 0;

// Abre o menu de contexto de uma mensagem posicionando-o próximo ao botão clicado
function openMsgMenu(e, btn) {
    e.stopPropagation();
    const w = btn.closest('.msg-wrapper');
    if (!w) return;
    _ctxMsgId   = parseInt(w.dataset.msgId) || 0;
    _ctxIsMe    = w.dataset.isMe === 'true';
    _ctxIsGrupo = w.dataset.isGrupo === 'true';
    const isFile = (w.dataset.conteudo || '') === '' && w.querySelector('img,a[download]');
    document.getElementById('mcCopy')?.classList.toggle('hidden', !!isFile);
    document.getElementById('mcReply')?.classList.toggle('hidden', !!isFile);
    const menu = document.getElementById('msgContextMenu');
    if (!menu) return;
    menu.classList.remove('hidden');
    const rect = btn.getBoundingClientRect();
    let left = rect.left, top = rect.bottom + 4;
    const mw = menu.offsetWidth || 180, mh = menu.offsetHeight || 80;
    if (left + mw > window.innerWidth - 8) left = window.innerWidth - mw - 8;
    if (top + mh > window.innerHeight - 8) top = rect.top - mh - 4;
    menu.style.left = Math.max(8, left) + 'px';
    menu.style.top  = Math.max(8, top)  + 'px';
}

document.addEventListener('click', () => document.getElementById('msgContextMenu')?.classList.add('hidden'));

document.getElementById('mcCopy')?.addEventListener('click', () => {
    const w = document.querySelector(`.msg-wrapper[data-msg-id="${_ctxMsgId}"]`);
    const t = w?.querySelector('.msg-conteudo')?.textContent || w?.dataset.conteudo || '';
    if (t) navigator.clipboard?.writeText(t);
});

document.getElementById('mcReply')?.addEventListener('click', () => {
    const w = document.querySelector(`.msg-wrapper[data-msg-id="${_ctxMsgId}"]`);
    const refText = w?.dataset.conteudo || '';
    const senderEl = w?.querySelector('.msg-sender-name');
    const who = _ctxIsMe ? 'Você' : (senderEl?.textContent || '');
    _replyMsgId = _ctxMsgId;
    const rt = document.getElementById('replyText');
    if (rt) rt.textContent = `${who}: ${refText.slice(0,80)}`;
    document.getElementById('replyPreview')?.classList.remove('hidden');
    msgInput?.focus();
});

// Cancela o modo de resposta e oculta a prévia de citação
function cancelarReply() {
    _replyMsgId = 0;
    document.getElementById('replyPreview')?.classList.add('hidden');
    const rt = document.getElementById('replyText');
    if (rt) rt.textContent = '';
}

// Abre o visualizador de arquivo em tela cheia com opção de download
function abrirFileViewer(url, nome, isMe) {
    const isImg  = /\.(png|jpe?g)$/i.test(url || '');
    const body   = document.getElementById('fileViewerBody');
    const dlBtn  = document.getElementById('fileViewerDownload');
    const nomeEl = document.getElementById('fileViewerNome');
    if (nomeEl) nomeEl.textContent = nome;
    if (body) {
        if (isImg) {
            body.innerHTML = `<img src="${url}" alt="${nome}" style="max-width:90vw;max-height:78vh;object-fit:contain;border-radius:.75rem;box-shadow:0 25px 50px rgba(0,0,0,.5)">`;
        } else {
            body.innerHTML = `<div class="flex flex-col items-center gap-4 py-12">
              <div style="font-size:5rem">📄</div>
              <p style="color:#fff;font-weight:600;font-size:1.1rem">${nome}</p>
              <p style="color:rgba(255,255,255,.6);font-size:.875rem">PDF — clique em Baixar para abrir</p>
            </div>`;
        }
    }
    if (dlBtn) {
        dlBtn.href     = url;
        dlBtn.download = nome;
        dlBtn.classList.toggle('hidden', isMe === true);
    }
    openModal('modalFileViewer');
}

// Ver Contratos/Termos
function verContratosTermos() {
    document.getElementById('actionDropdown')?.classList.add('hidden');
    mudarAbaContrato('cliente');
    openModal('modalVerContratos');
}



function mudarAbaContrato(aba) {
    const tabs = {
        cliente:    { tab: 'vcTabCliente',    conteudo: 'vcAbaCliente' },
        fornecedor: { tab: 'vcTabFornecedor', conteudo: 'vcAbaFornecedor' },
        termos:     { tab: 'vcTabTermos',     conteudo: 'vcAbaTermos' }
    };
    Object.keys(tabs).forEach(key => {
        const isActive = key === aba;
        document.getElementById(tabs[key].conteudo)?.classList.toggle('hidden', !isActive);
        const tabEl = document.getElementById(tabs[key].tab);
        if (tabEl) {
            tabEl.style.color = isActive ? 'var(--brown)' : 'var(--text-muted)';
            tabEl.style.borderColor = isActive ? 'var(--brown)' : 'transparent';
        }
    });
}

