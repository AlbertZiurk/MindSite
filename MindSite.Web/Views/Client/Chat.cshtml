// Abre o modal de solicitação de mudança com os dados do serviço ativo
async function solicitarMudanca() {
    if (!CONTATO_ID) return;
    document.getElementById('actionDropdown')?.classList.add('hidden');
    const erroEl = document.getElementById('erroMudancaChat');
    if (erroEl) erroEl.classList.add('hidden');
