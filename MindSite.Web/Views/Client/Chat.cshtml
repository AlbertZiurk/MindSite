@{
    ViewData["Title"] = "Atendimento - MindSite";
    Layout = "_LayoutClient";
}

@* Ajuste de altura para compensar o header do _Layout *@
<style>
    .chat-wrapper {
        height: calc(100vh - 80px);
    }

    /* Scrollbar customizada */
    .custom-scrollbar::-webkit-scrollbar { width: 4px; }
    .custom-scrollbar::-webkit-scrollbar-track { background: transparent; }
    .custom-scrollbar::-webkit-scrollbar-thumb { background: #6B462C40; border-radius: 10px; }
    .custom-scrollbar::-webkit-scrollbar-thumb:hover { background: #6B462C80; }

    /* Animação de entrada das mensagens */
    @@keyframes msgIn {
        from { opacity: 0; transform: translateY(8px); }
        to   { opacity: 1; transform: translateY(0); }
    }
    .msg-animate { animation: msgIn 0.25s ease-out forwards; }

    /* Indicador de digitando */
    @@keyframes bounce {
        0%, 80%, 100% { transform: translateY(0); }
        40%           { transform: translateY(-5px); }
    }
    .dot { animation: bounce 1.2s infinite ease-in-out; }
    .dot:nth-child(2) { animation-delay: 0.15s; }
    .dot:nth-child(3) { animation-delay: 0.30s; }

    /* Highlight do contato ativo */
    .contact-item.active {
        background-color: #E3DBCE;
        box-shadow: inset 3px 0 0 #6B462C;
    }
    .contact-item:not(.active):hover {
        background-color: #E3DBCE50;
    }
</style>

<div class="chat-wrapper flex bg-[#F4F3EE] p-4 gap-4 font-sans overflow-hidden">

    <aside class="w-[300px] min-w-[260px] bg-white/60 backdrop-blur-sm rounded-2xl flex flex-col border border-[#6B462C]/15 shadow-sm overflow-hidden">

        <div class="bg-[#E3DBCE] px-5 py-4 flex items-center justify-between border-b border-[#6B462C]/15">
            <div class="flex items-center gap-3">
                <div class="relative">
                    <div class="w-10 h-10 bg-[#6B462C] rounded-full flex items-center justify-center text-[#F4F3EE] shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></span>
                </div>
                <div>
                    <p class="font-bold text-[#4d392a] text-sm leading-tight">Cliente Maria</p>
                    <p class="text-[#8d6945] text-xs">Minha conta</p>
                </div>
            </div>
            
            <div class="relative">
                <button id="filterMenuBtn" class="p-2 text-[#8d6945] hover:text-[#4d392a] hover:bg-[#6B462C]/10 rounded-lg transition-all" title="Filtros">
    @* Ícone de Filtro (Funil) SVG *@
    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
        <path stroke-linecap="round" stroke-linejoin="round" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2.586a1 1 0 01-.293.707l-6.414 6.414a1 1 0 00-.293.707V17l-4 4v-6.586a1 1 0 00-.293-.707L3.293 7.293A1 1 0 013 6.586V4z" />
    </svg>
</button>
                
                @* Minitela de Filtros *@
                <div id="filterDropdown" class="hidden absolute right-0 mt-2 w-48 bg-white border border-[#6B462C]/20 rounded-xl shadow-lg z-50 overflow-hidden msg-animate">
                    <div class="p-2 border-b border-[#6B462C]/10 bg-[#F4F3EE]">
                        <span class="text-[10px] font-bold text-[#8d6945] uppercase tracking-widest px-2">Filtrar por:</span>
                    </div>
                    <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[#E3DBCE] transition-colors">Nome do Fornecedor</button>
                    <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[#E3DBCE] transition-colors">Tipo de Serviço</button>
                    <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[#E3DBCE] transition-colors">Conversas Recentes</button>
                </div>
            </div>
        </div>

        <div class="px-4 py-3 border-b border-[#6B462C]/10">
            <div class="relative">
                <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4 absolute left-3 top-1/2 -translate-y-1/2 text-[#8d6945]" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M21 21l-6-6m2-5a7 7 0 11-14 0 7 7 0 0114 0z" />
                </svg>
                <input type="text" id="searchContacts"
                    class="w-full bg-[#F4F3EE] border border-[#6B462C]/20 rounded-full py-2 pl-9 pr-4 text-sm focus:outline-none focus:ring-2 focus:ring-[#6B462C]/30 text-[#4d392a] placeholder-[#8d6945]/60"
                    placeholder="Pesquisar conversa..." />
            </div>
        </div>

        <p class="text-xs font-semibold text-[#8d6945] uppercase tracking-wider px-5 pt-4 pb-2">Fornecedores</p>

        <div id="contactList" class="flex-1 overflow-y-auto custom-scrollbar px-3 pb-3 space-y-1">
            
            @* 1° Bloco de Chat *@
            <div class="contact-item active flex items-center gap-3 p-3 rounded-xl cursor-pointer transition-all" onclick="selectContact(this, 'Fornecedor Alberto', true)">
                <div class="relative flex-shrink-0">
                    <div class="w-11 h-11 bg-[#6B462C] rounded-full flex items-center justify-center text-[#F4F3EE]">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></span>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                        <h5 class="font-semibold text-[#4d392a] text-sm truncate">Fornecedor Alberto</h5>
                        <span class="text-[10px] text-[#8d6945] flex-shrink-0 ml-1">14:32</span>
                    </div>
                    <p class="text-xs text-[#8d6945] truncate mt-0.5">Tudo pronto para a próxima etapa!</p>
                </div>
            </div>

            @* 2° Bloco de Chat *@
            <div class="contact-item flex items-center gap-3 p-3 rounded-xl cursor-pointer transition-all" onclick="selectContact(this, 'Fornecedor Cláudio', false)">
                <div class="relative flex-shrink-0">
                    <div class="w-11 h-11 bg-[#926A44] rounded-full flex items-center justify-center text-[#F4F3EE]">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-red-400 border-2 border-white rounded-full"></span>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                        <h5 class="font-semibold text-[#4d392a] text-sm truncate">Fornecedor Cláudio</h5>
                        <span class="text-[10px] text-[#8d6945] flex-shrink-0 ml-1">11:05</span>
                    </div>
                    <p class="text-xs text-[#8d6945] truncate mt-0.5">Aguardando retorno do cliente...</p>
                </div>
                <span class="flex-shrink-0 bg-[#6B462C] text-white text-[10px] font-bold rounded-full w-5 h-5 flex items-center justify-center">2</span>
            </div>

            @* 3° Bloco de Chat *@
            <div class="contact-item flex items-center gap-3 p-3 rounded-xl cursor-pointer transition-all" onclick="selectContact(this, 'Fornecedor Marcos', true)">
                <div class="relative flex-shrink-0">
                    <div class="w-11 h-11 bg-[#5c4b3c] rounded-full flex items-center justify-center text-[#F4F3EE]">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                    <span class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-white rounded-full"></span>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex items-center justify-between">
                        <h5 class="font-semibold text-[#4d392a] text-sm truncate">Fornecedor Marcos</h5>
                        <span class="text-[10px] text-[#8d6945] flex-shrink-0 ml-1">Ontem</span>
                    </div>
                    <p class="text-xs text-[#8d6945] truncate mt-0.5">Entrei em contato por e-mail também.</p>
                </div>
            </div>

        </div>
    </aside>

    <main class="flex-1 flex flex-col rounded-2xl overflow-hidden border border-[#6B462C]/20 shadow-sm bg-white">

        <div class="bg-[#E3DBCE] px-6 py-3 flex items-center justify-between border-b border-[#6B462C]/15 flex-shrink-0">
            <div class="flex items-center gap-3">
                <div class="relative">
                    <div class="w-10 h-10 bg-[#6B462C] rounded-full flex items-center justify-center text-[#F4F3EE] shadow">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                        </svg>
                    </div>
                    <span id="statusDot" class="absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-[#E3DBCE] rounded-full"></span>
                </div>
                <div>
                    <h3 id="chatContactName" class="font-bold text-[#4d392a] text-sm leading-tight">Fornecedor Alberto</h3>
                    <span id="chatStatus" class="text-xs text-[#8d6945] italic">Online</span>
                </div>
            </div>

            <div class="flex items-center gap-2">
                
                <div class="relative">
                    <button id="actionMenuBtn" class="p-2 text-[#8d6945] hover:text-[#4d392a] hover:bg-[#6B462C]/10 rounded-lg transition-all" title="Opções">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                        </svg>
                    </button>

                    @* Minitela de Ações de Navegação *@
                    <div id="actionDropdown" class="hidden absolute right-0 mt-2 w-56 bg-white border border-[#6B462C]/20 rounded-xl shadow-lg z-50 overflow-hidden msg-animate">
                        <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[#E3DBCE] flex items-center gap-2 border-b border-[#6B462C]/5">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                            Detalhes do Usuário
                        </button>
                        <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[#E3DBCE] flex items-center gap-2 border-b border-[#6B462C]/5">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M4 4h16v16H4z"/></svg>
                            Solicitar Mudança
                        </button>
                        <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[#E3DBCE] flex items-center gap-2">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                            Detalhes do Serviço
                        </button>
                        <button class="w-full text-left px-4 py-2 text-sm text-green-700 hover:bg-green-200 flex items-center gap-2">
                            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z" />
                            </svg>
                            Concluir o Serviço
                        </button>
                    </div>
                </div>
            </div>
        </div>

        <div id="messagesArea" class="flex-1 overflow-y-auto custom-scrollbar px-6 py-5 space-y-3 bg-[#F4F3EE]/50">

            @* Data da última conversa *@
            <div class="flex items-center gap-3 my-2">
                <div class="flex-1 h-px bg-[#6B462C]/10"></div>
                <span class="text-xs text-[#8d6945] font-medium bg-[#F4F3EE] px-3">Hoje</span>
                <div class="flex-1 h-px bg-[#6B462C]/10"></div>
            </div>

            
            
            @* Ação de "Digitando a mensagem" *@
            <div id="typingIndicator" class="flex items-end gap-2 hidden">
                <div class="w-7 h-7 bg-[#6B462C] rounded-full flex-shrink-0 flex items-center justify-center text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </div>
                <div class="bg-[#E3DBCE] px-4 py-3 rounded-2xl rounded-bl-sm shadow-sm flex items-center gap-1">
                    <span class="dot w-2 h-2 bg-[#8d6945] rounded-full inline-block"></span>
                    <span class="dot w-2 h-2 bg-[#8d6945] rounded-full inline-block"></span>
                    <span class="dot w-2 h-2 bg-[#8d6945] rounded-full inline-block"></span>
                </div>
            </div>

        </div>

        <div class="bg-white px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0">
            <div class="flex items-center gap-3 bg-[#F4F3EE] rounded-2xl border border-[#6B462C]/20 px-4 py-2.5 focus-within:border-[#6B462C]/50 focus-within:ring-2 focus-within:ring-[#6B462C]/10 transition-all">

                <button class="text-[#8d6945] hover:text-[#4d392a] transition-colors flex-shrink-0 hover:scale-110 active:scale-95" title="Anexar arquivo">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9l-2 3H5a2 2 0 00-2 2v2a2 2 0 002 2z" />
                    </svg>
                </button>

                <input
                    type="text"
                    id="msgInput"
                    class="flex-1 bg-transparent focus:outline-none text-sm text-[#4d392a] placeholder-[#8d6945]/60"
                    placeholder="Escreva sua mensagem..."
                    autocomplete="off"
                />

                <button
                    id="sendBtn"
                    onclick="sendMessage()"
                    class="bg-[#6B462C] text-white p-2 rounded-xl hover:bg-[#4d392a] transition-all hover:scale-105 active:scale-95 shadow-sm flex-shrink-0"
                    title="Enviar">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M2.01 21L23 12L2.01 3L2 10l15 2l-15 2z" />
                    </svg>
                </button>
            </div>
        </div>
    </main>
</div>

@section Scripts {
<script>
    const msgInput   = document.getElementById('msgInput');
    const msgArea    = document.getElementById('messagesArea');
    const typing     = document.getElementById('typingIndicator');

    @* Envio de Mensagem *@
    function sendMessage() {
        const text = msgInput.value.trim();
        if (!text) return;

        appendMessage(text, 'sent');
        msgInput.value = '';
        msgInput.focus();

        @* Simula resposta do fornecedor *@
        setTimeout(() => {
            typing.classList.remove('hidden');
            scrollBottom();
        }, 500);

        setTimeout(() => {
            typing.classList.add('hidden');
            const respostas = [
                'Entendido! Vou verificar isso agora.',
                'Certo, pode deixar comigo! 👍',
                'Ótima pergunta, te respondo em breve.',
                'Perfeito! Já estou trabalhando nisso.',
                'Combinado! Te mando uma atualização logo.'
            ];
            const r = respostas[Math.floor(Math.random() * respostas.length)];
            appendMessage(r, 'received');
        }, 2200);
    }

    @* Balão de Mensagem *@
    function appendMessage(text, type) {
        const now = new Date();
        const time = now.getHours().toString().padStart(2,'0') + ':' + now.getMinutes().toString().padStart(2,'0');

        let html = '';
        @* exibe mensagem do Cliente *@
        if (type === 'sent') {
            html = `
            <div class="flex items-end gap-2 justify-end msg-animate">
                <div>
                    <div class="bg-[#6B462C] text-[#F4F3EE] px-4 py-3 rounded-2xl rounded-br-sm max-w-xs shadow-sm text-sm leading-relaxed">${escapeHtml(text)}</div>
                    <span class="text-[10px] text-[#8d6945] mr-1 mt-1 block text-right">${time} ✓✓</span>
                </div>
            </div>`;
        } 
        @* Exibe mensagem do fornecedor *@
        else {
            html = `
            <div class="flex items-end gap-2 msg-animate">
                <div class="w-7 h-7 bg-[#6B462C] rounded-full flex-shrink-0 flex items-center justify-center text-white">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-4 w-4" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                    </svg>
                </div>
                <div>
                    <div class="bg-[#E3DBCE] text-[#4d392a] px-4 py-3 rounded-2xl rounded-bl-sm max-w-xs shadow-sm text-sm leading-relaxed">${escapeHtml(text)}</div>
                    <span class="text-[10px] text-[#8d6945] ml-1 mt-1 block">${time}</span>
                </div>
            </div>`;
        }

        @* Insere antes do typing indicator *@
        typing.insertAdjacentHTML('beforebegin', html);
        scrollBottom();
    }

    @* Scroll automático *@
    function scrollBottom() {
        msgArea.scrollTo({ top: msgArea.scrollHeight, behavior: 'smooth' });
    }

    @* Segurança: escapar HTML *@
    function escapeHtml(text) {
        return text.replace(/&/g,'&amp;').replace(/</g,'&lt;').replace(/>/g,'&gt;').replace(/"/g,'&quot;');
    }

    @* Enter para enviar *@
    msgInput.addEventListener('keydown', (e) => {
        if (e.key === 'Enter' && !e.shiftKey) {
            e.preventDefault();
            sendMessage();
        }
    });

    @* Selecionar contato *@
    function selectContact(el, name, online) {
        document.querySelectorAll('.contact-item').forEach(c => c.classList.remove('active'));
        el.classList.add('active');

        document.getElementById('chatContactName').textContent = name;
        const statusEl   = document.getElementById('chatStatus');
        const statusDot  = document.getElementById('statusDot');

        if (online) {
            statusEl.textContent  = 'Online';
            statusEl.className    = 'text-xs text-[#8d6945] italic font-medium';
            statusDot.className   = 'absolute bottom-0 right-0 w-2.5 h-2.5 bg-green-500 border-2 border-[#E3DBCE] rounded-full';
        } else {
            statusEl.textContent  = 'Offline';
            statusEl.className    = 'text-xs text-[#8d6945] italic font-medium';
            statusDot.className   = 'absolute bottom-0 right-0 w-2.5 h-2.5 bg-red-400 border-2 border-[#E3DBCE] rounded-full';
        }
    }

    @* Pesquisa de contatos *@
    document.getElementById('searchContacts').addEventListener('input', function() {
        const q = this.value.toLowerCase();
        document.querySelectorAll('.contact-item').forEach(item => {
            const name = item.querySelector('h5').textContent.toLowerCase();
            item.style.display = name.includes(q) ? '' : 'none';
        });
    });

    scrollBottom();

    // Função genérica para gerenciar dropdowns
    function setupDropdown(buttonId, dropdownId) {
        const btn = document.getElementById(buttonId);
        const menu = document.getElementById(dropdownId);

        btn.addEventListener('click', (e) => {
            e.stopPropagation();
            menu.classList.toggle('hidden');
            // Fecha o outro menu se estiver aberto
            const otherId = dropdownId === 'filterDropdown' ? 'actionDropdown' : 'filterDropdown';
            document.getElementById(otherId).classList.add('hidden');
        });
    }

    // Inicializa os menus
    setupDropdown('filterMenuBtn', 'filterDropdown');
    setupDropdown('actionMenuBtn', 'actionDropdown');

    // Fecha os menus se clicar fora deles
    document.addEventListener('click', () => {
        document.getElementById('filterDropdown').classList.add('hidden');
        document.getElementById('actionDropdown').classList.add('hidden');
    });
</script>
}
