        document.getElementById('mcNomeProjeto').value    = data.nomeProjeto  || '';
        document.getElementById('mcObservacoes').value    = data.observacoes  || '';
        document.getElementById('mcNovasInstrucoes').value = '';
        openModal('modalMudancaChat');
    } catch(e) {
        mostrarErroGeral('Erro ao carregar informações do serviço.');
    }
