@model MindSite.ViewModels.ChatViewModel
@{
    ViewData["Title"] = "Chat";
    Layout = "_LayoutClient";
    var pinadosIds = Model.ContatosPinados.Select(c => c.Id).ToHashSet();
}

@section Styles {
<style>
@@keyframes dotBounce { 0%,80%,100% { transform:scale(0); } 40% { transform:scale(1); } }
.dot-bounce span { display:inline-block; width:6px; height:6px; border-radius:50%; background:var(--brown); animation:dotBounce 1.2s infinite ease-in-out; }
.dot-bounce span:nth-child(1) { animation-delay:-0.24s; }
.dot-bounce span:nth-child(2) { animation-delay:-0.12s; }
.dot-bounce span:nth-child(3) { animation-delay:0s; }
#msgBox::-webkit-scrollbar, .sidebar-scroll::-webkit-scrollbar { width:4px; }
#msgBox::-webkit-scrollbar-thumb, .sidebar-scroll::-webkit-scrollbar-thumb { background:var(--chat-scrollbar); border-radius:4px; }
#msgBox::-webkit-scrollbar-track, .sidebar-scroll::-webkit-scrollbar-track { background:transparent; }
</style>
}

@* MODAL SOLICITAR MUDANÇA (chat) *@
<div id="modalMudancaChat" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-lg mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Solicitar Mudança</h3>
            <p class="text-xs mt-0.5" style="color:rgba(255,255,255,0.65)">Edite os campos desejados e descreva a mudança.</p>
        </div>
        <div class="px-6 py-5">
            <div id="erroMudancaChat" class="hidden rounded-xl px-4 py-3 text-sm mb-4" style="background:var(--error-bg);color:#ef4444"></div>
            <form id="formMudancaChat" class="flex flex-col gap-4">
                @Html.AntiForgeryToken()
                <input type="hidden" id="mcServicoId" name="servicoId"/>
                <input type="hidden" id="mcFornecedorId" name="fornecedorId"/>
                <div>
                    <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Nome do Projeto</label>
                    <input type="text" id="mcNomeProjeto" name="nomeProjeto" class="ms-input" maxlength="200" placeholder="Nome do projeto"/>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Observações</label>
                    <textarea id="mcObservacoes" name="observacoes" class="ms-textarea" rows="2" placeholder="Observações atuais do projeto..."></textarea>
                </div>
                <div>
                    <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Novas Instruções <span style="color:#ef4444">*</span></label>
                    <textarea id="mcNovasInstrucoes" name="novasInstrucoes" class="ms-textarea" rows="4" required placeholder="Descreva detalhadamente o que precisa ser mudado no projeto..."></textarea>
                </div>
                <div class="flex gap-3 mt-2">
                    <button type="button" onclick="closeModal('modalMudancaChat')" class="flex-1 py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Cancelar</button>
                    <button type="button" onclick="enviarMudancaChat()" class="flex-1 py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:var(--brown)">Salvar Alterações</button>
                </div>
            </form>
        </div>
    </div>
</div>

@* MODAL VISUALIZAR MUDANÇA (cliente vê o que enviou) *@
<div id="modalVerMudanca" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="relative w-full max-w-lg mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Visualizar Mudança</h3>
        </div>
        <div class="px-6 py-5">
            <div id="verMudancaConteudo" class="flex flex-col gap-3 text-sm" style="color:var(--text)"></div>
        </div>
        <div class="px-6 pb-6">
            <button onclick="closeModal('modalVerMudanca')" class="w-full py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Fechar</button>
        </div>
    </div>
</div>

@* Modal detalhes do fornecedor *@
<div id="modalContatoInfo" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalContatoInfo')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        @* Header *@
        <div class="px-6 py-5 flex items-center gap-4" style="background:var(--brown)">
            <div id="ciAvatar" class="w-12 h-12 rounded-full flex items-center justify-center text-base font-bold flex-shrink-0" style="background:rgba(255,255,255,0.18);color:#fff">?</div>
            <div class="flex-1 min-w-0">
                <h3 id="ciNome" class="font-bold text-white text-base leading-tight truncate">...</h3>
                <p id="ciStatus" class="text-xs mt-1 font-medium"></p>
            </div>
        </div>
        @* Avaliação *@
        <div class="px-6 pt-5 pb-3">
            <div class="rounded-2xl px-4 py-3 flex items-center justify-between gap-3" style="background:var(--brown-bg)">
                <div class="flex-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest mb-1.5" style="color:var(--text-muted)">Avaliação média</p>
                    <div class="flex items-center gap-2">
                        <span id="ciStars" class="text-xl leading-none tracking-tight" style="color:#f59e0b">☆☆☆☆☆</span>
                        <span id="ciMediaLabel" class="text-base font-bold" style="color:var(--text)">—</span>
                    </div>
                    <p id="ciTotalAval" class="text-xs mt-1" style="color:var(--text-muted)">Nenhuma avaliação ainda</p>
                </div>
                <svg class="w-9 h-9 opacity-15 flex-shrink-0" viewBox="0 0 24 24" fill="currentColor" style="color:var(--brown)"><path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01L12 2z"/></svg>
            </div>
        </div>
        @* Contadores *@
        <div class="px-6 pb-4 grid grid-cols-2 gap-3">
            <div class="rounded-2xl px-4 py-3 text-center" style="background:var(--brown-bg)">
                <p id="ciConcluidos" class="text-2xl font-bold leading-tight" style="color:var(--brown)">—</p>
                <p class="text-[11px] mt-1 font-medium" style="color:var(--text-muted)">Projetos concluídos</p>
            </div>
            <div class="rounded-2xl px-4 py-3 text-center" style="background:var(--brown-bg)">
                <p id="ciAtivos" class="text-2xl font-bold leading-tight" style="color:var(--brown)">—</p>
                <p class="text-[11px] mt-1 font-medium" style="color:var(--text-muted)">Em andamento</p>
            </div>
        </div>
        @* Sobre *@
        <div id="ciInfos" class="px-6 pb-3 flex flex-col gap-2 text-sm"></div>
        @* Footer *@
        <div class="px-6 pb-6">
            <button onclick="closeModal('modalContatoInfo')" class="w-full py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Fechar</button>
        </div>
    </div>
</div>

@* Modal detalhes do serviço *@
<div id="modalServicoInfo" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalServicoInfo')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:var(--brown)">
            <h3 class="font-bold text-white text-base">Detalhes do Serviço</h3>
        </div>
        <div class="px-6 py-5">
            <div id="siInfos" class="flex flex-col gap-3 text-sm" style="color:var(--text)"></div>
        </div>
        <div class="px-6 pb-6 flex flex-col gap-3">
            <div id="siAcoes" class="hidden flex gap-3">
                <button id="siBtnConcluir" onclick="concluirServico()" class="flex-1 py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:var(--brown)">Confirmar Entrega</button>
                <button id="siBtnCancelar" onclick="cancelarServicoConfirm()" class="flex-1 py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:#ef4444;color:#ef4444;background:transparent">Cancelar Projeto</button>
            </div>
            <button onclick="closeModal('modalServicoInfo')" class="w-full py-2.5 rounded-xl font-semibold border-2 transition hover:opacity-80" style="border-color:var(--brown);color:var(--brown);background:transparent">Fechar</button>
        </div>
    </div>
</div>

@* Modal confirmação genérica *@
<div id="modalConfirm" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalConfirm')"></div>
    <div class="modal-box relative ms-card p-6 w-full max-w-sm mx-4 z-10 text-center" style="background:var(--surface)">
        
        @* Ícone de Alerta Sutil (estilo padrão dos seus modais de confirmação) *@
        <div class="w-12 h-12 rounded-full mx-auto mb-3 flex items-center justify-center text-xl font-bold shadow-inner" style="background:rgba(107,71,47,0.1); color:var(--brown)">
            !
        </div>
        
        @* Título e Subtítulo dinâmicos adaptados ao Dark Mode *@
        <h3 id="confirmMsg" class="font-inria text-xl font-bold mb-2" style="color:var(--text)"></h3>
        <p id="confirmSub" class="text-xs mb-6 leading-relaxed" style="color:var(--text-muted)"></p>
        
        @* Botões de Ação Dinâmicos *@
        <div class="flex gap-3">
            <button onclick="closeModal('modalConfirm')" class="btn-ghost flex-1 py-2.5 text-xs">
                Cancelar
            </button>
            <button id="confirmBtn" class="btn-primary flex-1 py-2.5 text-xs font-bold">
                Confirmar
            </button>
        </div>
    </div>
</div>

@* Modal de sucesso e status da solicitação *@
<div id="modalSucessoMudanca" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="redirecionarParaServicos()"></div>
    <div class="modal-box relative ms-card p-8 w-full max-w-sm mx-4 z-10 text-center" style="background:var(--surface)">
        
        @* Ícone de Sucesso Sutil e Elegante *@
        <div class="w-12 h-12 rounded-full mx-auto mb-4 flex items-center justify-center text-xl font-bold shadow-inner" 
             style="background:var(--success-bg); color:#16a34a">
            ✓
        </div>
        
        <h3 class="font-inria text-2xl font-bold mb-2" style="color:var(--text)">Proposta Enviada!</h3>
        
        @* Mensagem Direta e Profissional baseada no seu pedido *@
        <p id="txtSucessoMudanca" class="text-xs mb-6 leading-relaxed" style="color:var(--text-muted)">
            Sua resposta foi registrada com sucesso. O serviço iniciará assim que o **pagamento inicial** for confirmado pelo cliente.
        </p>
        
        <div class="flex">
            <button onclick="redirecionarParaServicos()" class="btn-primary flex-1 py-2.5 text-xs font-bold">
                Ir para Meus Serviços
            </button>
        </div>
    </div>
</div>

@* Modal de erro de arquivo *@
<div id="modalErroArquivo" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalErroArquivo')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:#ef4444">
            <h3 class="font-bold text-white text-base flex items-center gap-2">
                ✕ Falha no Arquivo
            </h3>
        </div>
        <div class="px-6 py-6 text-center">
            <div class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center text-2xl font-bold shadow-inner" style="background:var(--error-bg); color:#ef4444">
                ✕
            </div>
            <p id="txtErroArquivo" class="text-sm font-medium" style="color:var(--text)">
                Erro ao processar ou enviar o arquivo selecionado.
            </p>
        </div>
        <div class="px-6 pb-6 flex">
            <button onclick="closeModal('modalErroArquivo')" class="flex-1 py-2.5 rounded-xl font-bold border-2 transition hover:opacity-80" style="border-color:#ef4444; color:#ef4444; background:transparent">
                Fechar
            </button>
        </div>
    </div>
</div>

@* Modal de erro geral/operações *@
<div id="modalErroGeral" class="hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm" onclick="closeModal('modalErroGeral')"></div>
    <div class="relative w-full max-w-md mx-4 z-10 rounded-2xl overflow-hidden shadow-2xl" style="background:var(--bg2)">
        <div class="px-6 py-4" style="background:#ef4444">
            <h3 class="font-bold text-white text-base flex items-center gap-2">
                ✕ Ops! Ocorreu um problema
            </h3>
        </div>
        <div class="px-6 py-6 text-center">
            <div class="w-16 h-16 rounded-full mx-auto mb-4 flex items-center justify-center text-2xl font-bold shadow-inner" style="background:var(--error-bg); color:#ef4444">
                ⚠
            </div>
            <p id="txtErroGeral" class="text-sm font-medium" style="color:var(--text)">
                Não foi possível completar a solicitação no momento.
            </p>
        </div>
        <div class="px-6 pb-6 flex">
            <button onclick="closeModal('modalErroGeral')" class="flex-1 py-2.5 rounded-xl font-bold text-white transition hover:opacity-90" style="background:var(--brown)">
                Fechar
            </button>
        </div>
    </div>
</div>

@* Modal ver contratos/termos *@
<div id="modalVerContratos" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm" onclick="closeModal('modalVerContratos')"></div>
    <div class="modal-box relative ms-card w-full max-w-2xl mx-4 z-10 flex flex-col" style="max-height:90vh">
        <div class="px-6 py-4 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div>
                <h3 class="font-inria font-bold text-lg" style="color:var(--text)">Contratos &amp; Termos</h3>
                <p class="text-xs mt-0.5" style="color:var(--text-muted)">Documentos assinados e termos da plataforma</p>
            </div>
            <button onclick="closeModal('modalVerContratos')" style="color:var(--text-muted)" aria-label="Fechar">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex border-b flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <button id="vcTabCliente" onclick="mudarAbaContrato('cliente')" class="flex-1 text-xs font-bold uppercase tracking-wider px-3 py-3 border-b-2 transition-colors" style="border-color:var(--brown);color:var(--brown)">Contrato Cliente</button>
            <button id="vcTabFornecedor" onclick="mudarAbaContrato('fornecedor')" class="flex-1 text-xs font-bold uppercase tracking-wider px-3 py-3 border-b-2 border-transparent transition-colors" style="color:var(--text-muted)">Contrato Fornecedor</button>
            <button id="vcTabTermos" onclick="mudarAbaContrato('termos')" class="flex-1 text-xs font-bold uppercase tracking-wider px-3 py-3 border-b-2 border-transparent transition-colors" style="color:var(--text-muted)">Termos da Plataforma</button>
        </div>
        <div class="flex-1 overflow-y-auto px-6 py-6 text-sm leading-relaxed" style="color:var(--text)">
            @{ /* Dados do cliente (usuário atual) e do fornecedor (contato) */ }
            @{
                string cliNome = Model.UsuarioAtual.NomeCompleto;
                string cliCPF  = Model.UsuarioAtual.CPF ?? "—";
                string cliData = Model.UsuarioAtual.AceitouContratoClienteEm?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—";
                string fornNome = Model.ContatoSelecionado?.NomeCompleto ?? "—";
                string fornCPF  = Model.ContatoSelecionado?.CPF ?? "—";
                string fornData = Model.ContatoSelecionado?.AceitouContratoFornecedorEm?.ToLocalTime().ToString("dd/MM/yyyy") ?? "—";
            }
            @* Aba contrato cliente *@
            <div id="vcAbaCliente">
                <p class="font-bold text-base mb-5" style="color:var(--brown)">CONTRATO CLIENTE</p>
                <div class="flex flex-col gap-4">
                    <div><p class="font-semibold mb-1">Responsabilidades</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>Enviar informações corretas;</span></li><li class="flex gap-2"><span>●</span><span>Fornecer materiais necessários;</span></li><li class="flex gap-2"><span>●</span><span>Responder solicitações no prazo;</span></li><li class="flex gap-2"><span>●</span><span>Realizar pagamentos conforme combinado.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Pagamento</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>30% no início do projeto;</span></li><li class="flex gap-2"><span>●</span><span>70% após aprovação final;</span></li><li class="flex gap-2"><span>●</span><span>Taxas bancárias podem ser aplicadas em estornos.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Não é permitido</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>Solicitar conteúdos ilegais;</span></li><li class="flex gap-2"><span>●</span><span>Tentar negociar fora da plataforma;</span></li><li class="flex gap-2"><span>●</span><span>Utilizar o sistema de forma abusiva;</span></li><li class="flex gap-2"><span>●</span><span>Praticar fraudes.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Cancelamento</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>Antes do início: poderá haver retenção de taxas;</span></li><li class="flex gap-2"><span>●</span><span>Após início: valores poderão ser proporcionais ao trabalho executado.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Mediação</p><p style="color:var(--text-muted)">A MindSite poderá analisar mensagens, arquivos e entregas em casos de disputa.</p></div>
                    <div class="border-t pt-4" style="border-color:var(--border)">
                        <p class="font-semibold mb-3">Assinatura de Consentimento</p>
                        <div class="flex flex-col gap-1" style="color:var(--text-muted)">
                            <p><span class="font-semibold" style="color:var(--text)">Nome:</span> @cliNome</p>
                            <p><span class="font-semibold" style="color:var(--text)">CPF/CNPJ:</span> @cliCPF</p>
                            <p><span class="font-semibold" style="color:var(--text)">Data:</span> @cliData</p>
                        </div>
                    </div>
                </div>
            </div>
            @* Aba contrato fornecedor *@
            <div id="vcAbaFornecedor" class="hidden">
                <p class="font-bold text-base mb-5" style="color:var(--brown)">CONTRATO FORNECEDOR</p>
                <div class="flex flex-col gap-4">
                    <div><p class="font-semibold mb-1">Responsabilidades</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>Cumprir prazos;</span></li><li class="flex gap-2"><span>●</span><span>Entregar conforme escopo;</span></li><li class="flex gap-2"><span>●</span><span>Manter comunicação profissional;</span></li><li class="flex gap-2"><span>●</span><span>Respeitar direitos autorais;</span></li><li class="flex gap-2"><span>●</span><span>Manter sigilo das informações.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Pagamento</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>Liberação parcial conforme política da plataforma;</span></li><li class="flex gap-2"><span>●</span><span>Pagamento final após aprovação do cliente;</span></li><li class="flex gap-2"><span>●</span><span>Taxas da plataforma poderão ser descontadas.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Não é permitido</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>Abandonar projetos;</span></li><li class="flex gap-2"><span>●</span><span>Solicitar pagamentos externos;</span></li><li class="flex gap-2"><span>●</span><span>Compartilhar dados confidenciais;</span></li><li class="flex gap-2"><span>●</span><span>Utilizar materiais ilegais.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Cancelamento</p><p class="mb-1" style="color:var(--text-muted)">O abandono injustificado poderá gerar:</p><ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)"><li class="flex gap-2"><span>●</span><span>bloqueio da conta;</span></li><li class="flex gap-2"><span>●</span><span>perda de valores;</span></li><li class="flex gap-2"><span>●</span><span>avaliações negativas;</span></li><li class="flex gap-2"><span>●</span><span>responsabilização judicial.</span></li></ul></div>
                    <div><p class="font-semibold mb-1">Direitos do Projeto</p><p style="color:var(--text-muted)">Os direitos autorais são transferidos ao cliente após pagamento integral.</p></div>
                    <div class="border-t pt-4" style="border-color:var(--border)">
                        <p class="font-semibold mb-3">Assinatura de Consentimento</p>
                        <div class="flex flex-col gap-1" style="color:var(--text-muted)">
                            <p><span class="font-semibold" style="color:var(--text)">Nome:</span> @fornNome</p>
                            <p><span class="font-semibold" style="color:var(--text)">CPF/CNPJ:</span> @fornCPF</p>
                            <p><span class="font-semibold" style="color:var(--text)">Data:</span> @fornData</p>
                        </div>
                    </div>
                </div>
            </div>
            @* Aba termos da plataforma *@
            <div id="vcAbaTermos" class="hidden">
                <p class="font-bold text-base mb-5" style="color:var(--brown)">TERMOS DA PLATAFORMA</p>
                <div class="flex flex-col gap-4">
                    <div>
                        <p class="font-semibold mb-2">A MindSite é responsável por</p>
                        <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                            <li class="flex gap-2"><span>●</span><span>intermediar projetos;</span></li>
                            <li class="flex gap-2"><span>●</span><span>organizar pagamentos;</span></li>
                            <li class="flex gap-2"><span>●</span><span>registrar comunicações;</span></li>
                            <li class="flex gap-2"><span>●</span><span>aplicar políticas antifraude;</span></li>
                            <li class="flex gap-2"><span>●</span><span>proteger dados conforme LGPD.</span></li>
                        </ul>
                    </div>
                    <div>
                        <p class="font-semibold mb-2">Segurança da Plataforma</p>
                        <p class="mb-2" style="color:var(--text-muted)">Contas poderão ser suspensas em casos de:</p>
                        <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                            <li class="flex gap-2"><span>●</span><span>fraude;</span></li>
                            <li class="flex gap-2"><span>●</span><span>inadimplência;</span></li>
                            <li class="flex gap-2"><span>●</span><span>abuso da plataforma;</span></li>
                            <li class="flex gap-2"><span>●</span><span>tentativa de burlar taxas;</span></li>
                            <li class="flex gap-2"><span>●</span><span>atividades ilegais.</span></li>
                        </ul>
                    </div>
                </div>
            </div>
        </div>
        <div class="px-6 py-4 border-t flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <button onclick="closeModal('modalVerContratos')" class="btn-ghost w-full">Fechar</button>
        </div>
    </div>
</div>

<div class="chat-outer-wrap flex ms-card gap-4 bg-[#F4F2ED] border-none overflow-hidden mx-4 md:mx-6 my-4" style="height:calc(100vh - 112px)">

    @* Lista de conversas *@
    <div class="chat-contacts-panel @((Model.ContatoSelecionado != null || Model.IsGrupoSuporte) ? "hidden md:flex md:w-80 md:min-w-[260px] bg-white rounded-2xl border border-[#6B462C]/15 shadow-sm overflow-hidden" : "flex w-full md:w-80") flex-col flex-shrink-0" style="border-right:1.5px solid color-mix(in srgb, var(--brown) 30%, transparent)">
        @{
            string cliMeIni = string.Join("", Model.UsuarioAtual.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
        }
        <div class="p-4 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div class="flex items-center gap-3 min-w-0">
                <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0" style="background:var(--brown);color:#fff">@cliMeIni.ToUpper()</div>
                <div class="min-w-0">
                    <p class="font-bold text-sm truncate" style="color:var(--text)">@Model.UsuarioAtual.NomeCompleto</p>
                    <p class="text-xs" style="color:var(--text-muted)">Minha conta</p>
                </div>
            </div>
            <div class="relative flex-shrink-0">
                <button id="filterMenuBtn" class="p-1.5 rounded-lg hover:opacity-70 transition-opacity" style="color:var(--text-muted)" aria-label="Filtrar">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 4a1 1 0 011-1h16a1 1 0 011 1v2a1 1 0 01-.293.707L13 13.414V19a1 1 0 01-.553.894l-4 2A1 1 0 017 21v-7.586L3.293 6.707A1 1 0 013 6V4z"/>
                    </svg>
                </button>
                <div id="filterDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:230px">
                    <div class="px-4 pt-3 pb-2">
                        <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Filtrar por</p>
                    </div>
                    <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70 transition-opacity" data-filter="nome" style="color:var(--text)">Nome do Fornecedor</button>
                    <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70 transition-opacity" data-filter="tipo" style="color:var(--text)">Tipo de Serviço</button>
                    <button class="filter-opt w-full text-left px-4 py-3 text-sm hover:opacity-70 transition-opacity" data-filter="recente" style="color:var(--text)">Conversas Recentes</button>
                </div>
            </div>
        </div>
        <div class="px-4 py-3 border-b flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <input type="text" placeholder="Pesquisar conversa..." oninput="filtrarContatos(this.value)"
                   class="ms-input text-sm w-full" style="border-radius:.75rem" aria-label="Buscar conversa"/>
        </div>

        <div class="flex-1 overflow-y-auto">

            @* Suporte MindSite — entrada única do grupo *@
            @{
                var pFornecs = Model.ContatosPinados.Where(c => c.Role != UserRole.Admin).ToList();
                var chatTipoNome = new Dictionary<MindSite.Enums.TipoServico, string> {
                    { MindSite.Enums.TipoServico.Ecommerce,         "E-commerce" },
                    { MindSite.Enums.TipoServico.Blog,              "Blog" },
                    { MindSite.Enums.TipoServico.Designing,         "Web Design" },
                    { MindSite.Enums.TipoServico.Marketing,         "Marketing" },
                    { MindSite.Enums.TipoServico.SiteInstitucional, "Sites Institucionais" },
                    { MindSite.Enums.TipoServico.LandingPage,       "Landing Pages" },
                    { MindSite.Enums.TipoServico.OnePage,           "One-Page Sites" },
                    { MindSite.Enums.TipoServico.Portfolio,         "Portfólios Digitais" },
                    { MindSite.Enums.TipoServico.BlogPortal,        "Blogs e Portais" },
                    { MindSite.Enums.TipoServico.PlataformaEAD,     "Plataformas EAD" },
                    { MindSite.Enums.TipoServico.LinkBio,           "Links para Bio" },
                    { MindSite.Enums.TipoServico.SistemaWeb,        "Sistemas Web" },
                    { MindSite.Enums.TipoServico.Agendamento,       "Agendamento" },
                    { MindSite.Enums.TipoServico.MultiIdioma,       "Multi-idiomas" },
                    { MindSite.Enums.TipoServico.Redesign,          "Redesign" },
                    { MindSite.Enums.TipoServico.Manutencao,        "Manutenção" },
                    { MindSite.Enums.TipoServico.SEO,               "SEO & Performance" },
                    { MindSite.Enums.TipoServico.Migracao,          "Migração" }
                };
            }
            <div class="px-4 pt-3 pb-1">
                <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Suporte MindSite</p>
            </div>
            <a href="?grupoSuporte=true"
               class="contact-item flex items-center gap-3 p-4 @(Model.IsGrupoSuporte ? "active" : "")"
               aria-label="Suporte MindSite">
                <div class="relative flex-shrink-0 w-10 h-10 rounded-full overflow-hidden flex items-center justify-center" class="ms-suporte-logo">
                    <img src="/img/logo_img.png" alt="MindSite" class="w-9 h-9 object-contain"/>
                </div>
                <div class="flex-1 min-w-0">
                    <div class="flex justify-between items-baseline gap-1">
                        <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">Suporte MindSite</span>
                        @if (Model.GrupoUltimaData.HasValue) {
                            <span class="text-[10px] flex-shrink-0" style="color:var(--text-muted)">
                                @(Model.GrupoUltimaData.Value.Date == DateTime.UtcNow.Date
                                    ? Model.GrupoUltimaData.Value.ToLocalTime().ToString("HH:mm")
                                    : Model.GrupoUltimaData.Value.ToLocalTime().ToString("dd/MM"))
                            </span>
                        }
                    </div>
                    <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">
                        @(Model.GrupoUltimaMensagem != "" ? Model.GrupoUltimaMensagem : "● Equipe de suporte")
                    </p>
                </div>
            </a>

            @* Meu Fornecedor *@
            @if (pFornecs.Any())
            {
                <div class="mx-4 my-1 border-t" style="border-color:var(--border)"></div>
                <div class="px-4 py-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Meu Fornecedor</p>
                </div>
                @foreach (var f in pFornecs)
                {
                    string ini  = string.Join("", f.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                    bool act    = f.Id == Model.ContatoSelecionadoId;
                    var cInfo   = Model.Conversas.FirstOrDefault(c => c.Contato.Id == f.Id);
                    var nl      = cInfo?.NaoLidas ?? 0;
                    var ult     = cInfo?.UltimaMensagem ?? "";
                    var qnd     = cInfo?.Quando;
                    var tipoSrv = cInfo?.TipoDoServico;
                    string tipoLabel = tipoSrv.HasValue ? chatTipoNome.GetValueOrDefault(tipoSrv.Value, tipoSrv.Value.ToString()) : "";
                    <a href="?contatoId=@f.Id"
                       data-tipo="@tipoLabel.ToLower()"
                       class="contact-item flex items-center gap-3 p-4 @(act ? "active" : "")"
                       aria-label="Fornecedor: @f.NomeCompleto">
                        <div class="relative flex-shrink-0">
                            <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold"
                                 style="background:var(--brown);color:#fff">@ini.ToUpper()</div>
                            @if (f.IsOnline) { <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2" style="background:#16a34a;border-color:var(--bg)"></span> }
                        </div>
                        <div class="flex-1 min-w-0">
                            <div class="flex justify-between items-baseline gap-1">
                                <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@f.NomeCompleto</span>
                                @if (qnd.HasValue) 
                                {
                                    string horaData = qnd.Value.Date == DateTime.UtcNow.Date 
                                        ? qnd.Value.ToLocalTime().ToString("HH:mm") 
                                        : qnd.Value.ToLocalTime().ToString("dd/MM");

                                    <span class="text-[10px] flex-shrink-0" style="color:var(--text-muted)">@horaData</span>
                                }
                            </div>
                            <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@ult</p>
                            @if (!string.IsNullOrEmpty(tipoLabel)) {
                                <span class="badge badge-brown text-[9px] mt-0.5">@tipoLabel</span>
                            }
                        </div>
                        @if (nl > 0) { <span class="w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center flex-shrink-0" style="background:var(--brown);color:#fff">@nl</span> }
                    </a>
                }
            }

            @* Outras Conversas *@
            @if (Model.Conversas.Any(cv => !pinadosIds.Contains(cv.Contato.Id)))
            {
                <div class="mx-4 my-1 border-t" style="border-color:var(--border)"></div>
                <div class="px-4 py-1">
                    <p class="text-[10px] font-bold uppercase tracking-widest" style="color:var(--text-muted)">Outras Conversas</p>
                </div>
            }
            @foreach (var c in Model.Conversas.Where(cv => !pinadosIds.Contains(cv.Contato.Id)))
            {
                string initials = string.Join("", c.Contato.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                bool isActive = c.Contato.Id == Model.ContatoSelecionadoId;
                <a href="?contatoId=@c.Contato.Id"
                   class="contact-item flex items-center gap-3 p-4 @(isActive ? "active" : "")"
                   aria-label="Conversa com @c.Contato.NomeCompleto">
                    <div class="relative flex-shrink-0">
                        <div class="w-10 h-10 rounded-full flex items-center justify-center text-sm font-bold"
                             style="background:var(--brown);color:#fff">@initials.ToUpper()</div>
                        @if (c.Contato.IsOnline) { <span class="absolute bottom-0 right-0 w-3 h-3 rounded-full border-2" style="background:#16a34a;border-color:var(--bg)"></span> }
                    </div>
                    <div class="flex-1 min-w-0">
                        <div class="flex justify-between items-baseline gap-1">
                            <span class="contact-name text-sm font-bold truncate" style="color:var(--text)">@c.Contato.NomeCompleto</span>
                            @if (c.Quando.HasValue) {
                                <span class="text-[10px] flex-shrink-0" style="color:var(--text-muted)">
                                    @(c.Quando.Value.Date == DateTime.UtcNow.Date ? c.Quando.Value.ToLocalTime().ToString("HH:mm") : c.Quando.Value.ToLocalTime().ToString("dd/MM"))
                                </span>
                            }
                        </div>
                        <p class="text-xs truncate mt-0.5" style="color:var(--text-muted)">@c.UltimaMensagem</p>
                    </div>
                    @if (c.NaoLidas > 0) {
                        <span class="w-5 h-5 rounded-full text-[10px] font-bold flex items-center justify-center flex-shrink-0"
                              style="background:var(--brown);color:#fff">@c.NaoLidas</span>
                    }
                </a>
            }

            @if (!Model.ContatosPinados.Any() && !Model.Conversas.Any())
            {
                <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma conversa ainda</p>
            }
        </div>
    </div>

    @* Área de mensagens *@
    <div class="chat-msg-panel @((Model.ContatoSelecionado != null || Model.IsGrupoSuporte) ? "flex" : "hidden md:flex") flex-1 flex flex-col rounded-2xl overflow-hidden border border-[#6B462C]/20 shadow-sm bg-white flex-1 flex-col min-w-0">
        @if (Model.ContatoSelecionado == null && !Model.IsGrupoSuporte)
        {
            <div class="flex-1 flex items-center justify-center flex-col gap-4" style="color:var(--text-muted)">
                <svg class="w-16 h-16 opacity-30" fill="none" viewBox="0 0 24 24" stroke="currentColor" aria-hidden="true">
                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"/>
                </svg>
                <p class="text-base font-medium">Selecione uma conversa</p>
            </div>
        }
        else if (Model.IsGrupoSuporte)
        {
            @* Grupo Suporte header *@
            <div class="px-5 py-3 border-b flex items-center gap-3 flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                <a href="/Client/Chat" class="md:hidden p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0" style="color:var(--brown)" aria-label="Voltar">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                <div class="relative flex-shrink-0 w-10 h-10 rounded-full overflow-hidden flex items-center justify-center" class="ms-suporte-logo">
                    <img src="/img/logo_img.png" alt="MindSite" class="w-9 h-9 object-contain"/>
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-bold text-sm leading-tight" style="color:var(--text)">Suporte MindSite <span class="badge badge-brown text-[9px] ml-1">Grupo</span></p>
                    <p class="text-xs" style="color:var(--text-muted)">Equipe de suporte disponível</p>
                </div>
            </div>

            @* Grupo messages area *@
            <div id="msgBox" class="flex-1 overflow-y-auto p-5 space-y-3" style="background:var(--bg)">
                @if (!Model.GrupoMensagens.Any())
                {
                    <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma mensagem. Envie uma mensagem para o suporte!</p>
                }
                @foreach (var gm in Model.GrupoMensagens)
                {
                    bool isMe = gm.RemetenteId == Model.UsuarioAtual.Id;
                    bool gmIsFile = gm.Conteudo.StartsWith("{\"_t\":\"F\"");
                    bool gmIsQ    = gm.Conteudo.StartsWith("{\"_t\":\"Q\"");
                    string gmUrl = "", gmNome = "", gmQRef = "", gmQMsg = "";
                    if (gmIsFile) {
                        try {
                            using var gdoc = System.Text.Json.JsonDocument.Parse(gm.Conteudo);
                            var gr = gdoc.RootElement;
                            gmUrl  = gr.TryGetProperty("url",  out var gu) ? (gu.GetString() ?? "") : "";
                            gmNome = gr.TryGetProperty("nome", out var gn) ? (gn.GetString() ?? "") : "";
                        } catch { gmIsFile = false; }
                    } else if (gmIsQ) {
                        try {
                            using var qdoc = System.Text.Json.JsonDocument.Parse(gm.Conteudo);
                            var qr = qdoc.RootElement;
                            gmQRef = qr.TryGetProperty("ref", out var qrf) ? (qrf.GetString() ?? "") : "";
                            gmQMsg = qr.TryGetProperty("msg", out var qmv) ? (qmv.GetString() ?? "") : "";
                        } catch { gmIsQ = false; }
                    }
                    string gmCtxData = gmIsFile ? "" : (gmIsQ ? gmQMsg : gm.Conteudo);
                    <div class="flex @(isMe ? "justify-end" : "justify-start") items-end gap-1 msg-animate msg-wrapper group"
                         data-msg-id="@gm.Id" data-is-me="@(isMe ? "true" : "false")"
                         data-conteudo="@gmCtxData" data-is-grupo="true">
                        @if (!isMe) {
                            <div class="relative flex-shrink-0 w-10 h-10 rounded-full overflow-hidden flex items-center justify-center" class="ms-suporte-logo">
                                <img src="/img/logo_img.png" alt="MindSite" class="w-9 h-9 object-contain"/>
                            </div>
                        }
                        @if (isMe) {
                            <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                            </button>
                        }
                        <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1 max-w-xs">
                            @if (!isMe) { <span class="msg-sender-name text-[10px] font-bold" style="color:var(--brown)">@gm.Remetente.NomeCompleto</span> }
                            @if (gmIsQ) {
                                <div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)">
                                    <span class="text-[10px] truncate block" style="color:var(--text-muted)">@Html.Raw(System.Net.WebUtility.HtmlEncode(gmQRef.Length > 80 ? gmQRef[..80] + "…" : gmQRef))</span>
                                </div>
                                <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(gmQMsg).Replace("\n","<br>"))</span>
                            } else if (gmIsFile) {
                                bool gmImg = new[] { ".png", ".jpg", ".jpeg" }.Contains(System.IO.Path.GetExtension(gmUrl).ToLowerInvariant());
                                @if (gmImg) {
                                    <img src="@gmUrl" alt="@gmNome" class="max-w-[200px] rounded-lg cursor-pointer" onclick="abrirFileViewer('@gmUrl','@gmNome',@(isMe ? "true" : "false"))" style="max-height:150px;object-fit:cover"/>
                                } else {
                                    <a href="#" onclick="abrirFileViewer('@gmUrl','@gmNome',@(isMe ? "true" : "false"));return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 @gmNome</a>
                                }
                            } else {
                                <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(gm.Conteudo).Replace("\n","<br>"))</span>
                            }
                            <span class="text-[10px] opacity-60 self-end">@gm.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                        </div>
                        @if (!isMe) {
                            <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                            </button>
                        }
                    </div>
                }
                <div id="typingIndicator" class="hidden justify-start">
                    <div class="bubble-recv dot-bounce py-3 px-4 flex items-center gap-1">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>

            @* Grupo input area *@
            <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0">
                <input type="file" id="fileInputGrupo" class="hidden" accept="image/png,image/jpeg,application/pdf,application/zip,.zip"/>
                <div id="replyPreview" class="hidden mb-2 flex items-center gap-2 rounded-xl px-3 py-1.5" style="background:var(--brown-subtle)">
                    <div class="w-0.5 self-stretch rounded-full flex-shrink-0" style="background:var(--brown)"></div>
                    <span id="replyText" class="text-xs flex-1 truncate" style="color:var(--text-muted)"></span>
                    <button type="button" onclick="cancelarReply()" class="flex-shrink-0 p-0.5" style="color:var(--text-muted)"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                </div>
                <form id="chatForm" class="chat-input-form flex items-center gap-3 bg-[#F4F3EE] rounded-2xl border border-[#6B462C]/20 px-2 py-1.5 focus-within:border-[#6B462C]/50 focus-within:ring-2 focus-within:ring-[#6B462C]/10 transition-all"
                      onsubmit="enviarGrupoMsg(event)">
                    <button type="button" onclick="document.getElementById('fileInputGrupo').click()"
                            class="chat-attach-btn text-[#8d6945] hover:text-[#4d392a] transition-colors flex-shrink-0 hover:scale-110 active:scale-95 p-2" title="Anexar arquivo">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9l-2 3H5a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                        </svg>
                    </button>
                    <textarea id="msgInput" rows="1" maxlength="4000"
                           class="chat-input-text flex-1 bg-transparent focus:outline-none text-sm text-[#4d392a] placeholder-[#8d6945]/60"
                           placeholder="Escreva sua mensagem..." autocomplete="off" aria-label="Mensagem para suporte"></textarea>
                    <button type="submit"
                            class="chat-send-btn bg-[#6B462C] text-white p-2 rounded-xl hover:bg-[#4d392a] transition-all hover:scale-105 active:scale-95 shadow-sm flex-shrink-0 m-1.5" title="Enviar">
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                            <path d="M2.01 21L23 12L2.01 3L2 10l15 2l-15 2z"/>
                        </svg>
                    </button>
                </form>
            </div>
        }
        else
        {
            @* Chat header *@
            <div class="px-5 py-3 border-b flex items-center gap-3 flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
                <a href="/Client/Chat" class="md:hidden p-1.5 rounded-lg hover:opacity-70 transition-opacity flex-shrink-0" style="color:var(--brown)" aria-label="Voltar">
                    <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 19l-7-7 7-7"/></svg>
                </a>
                @{
                    string ini2 = string.Join("", Model.ContatoSelecionado.NomeCompleto.Split(' ').Take(2).Select(p => p[0]));
                }
                <div class="w-9 h-9 rounded-full flex items-center justify-center text-sm font-bold flex-shrink-0"
                     style="background:@(Model.ContatoSelecionado.Role == UserRole.Admin ? "var(--admin-avatar)" : "var(--brown)");color:#fff">
                    @ini2.ToUpper()
                </div>
                <div class="flex-1 min-w-0">
                    <p class="font-bold text-sm leading-tight" style="color:var(--text)">
                        @Model.ContatoSelecionado.NomeCompleto
                        @if (Model.ContatoSelecionado.Role == UserRole.Admin)
                        {
                            <span class="badge badge-red text-[9px] ml-1">Suporte</span>
                        }
                    </p>
                    <p class="text-xs" style="@(Model.ContatoSelecionado.IsOnline ? "color:#16a34a" : "color:var(--text-muted)")">
                        @(Model.ContatoSelecionado.IsOnline ? "● Online" : "○ Offline")
                    </p>
                </div>
                @if (Model.ContatoSelecionado.Role != UserRole.Admin)
                {
                    <div class="relative flex-shrink-0">
                        <button id="actionMenuBtn" class="p-2 rounded-lg hover:opacity-70 transition-opacity"
                                style="color:var(--text-muted)" aria-label="Ações da conversa">
                            <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 6h16M4 12h16M4 18h16"/>
                            </svg>
                        </button>
                        <div id="actionDropdown" class="hidden absolute right-0 top-full mt-1 z-50 ms-card shadow-xl rounded-xl overflow-hidden" style="min-width:260px">
                            <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[var(--bg2)] flex items-center gap-2 border-b border-[#6B462C]/5"
                                    onclick="verContatoInfo()">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
                                Detalhes do Fornecedor
                            </button>
                            <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[var(--bg2)] flex items-center gap-2 border-b border-[#6B462C]/5"
                                    onclick="solicitarMudanca()">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 11l3 3L22 4M21 12v7a2 2 0 01-2 2H5a2 2 0 01-2-2V5a2 2 0 012-2h11"/></svg>
                                Solicitar Mudança
                            </button>
                            <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[var(--bg2)] flex items-center gap-2 border-b border-[#6B462C]/5"
                                    onclick="verServicoInfo()">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M13 10V3L4 14h7v7l9-11h-7z"/></svg>
                                Detalhes do Serviço
                            </button>
                            <button class="w-full text-left px-4 py-2 text-sm text-green-700 hover:bg-green-100 flex items-center gap-2 border-b border-[#6B462C]/5"
                                    onclick="concluirServicoConfirm()">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                Concluir o Serviço
                            </button>
                            <button class="w-full text-left px-4 py-2 text-sm text-red-600 hover:bg-red-100 flex items-center gap-2 border-b border-[#6B462C]/5"
                                    onclick="cancelarServicoConfirm()">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 14l2-2m0 0l2-2m-2 2l-2-2m2 2l2 2m7-2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                                Cancelar Serviço
                            </button>
                            <button class="w-full text-left px-4 py-2 text-sm text-[#4d392a] hover:bg-[var(--bg2)] flex items-center gap-2"
                                    onclick="verContratosTermos()">
                                <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/></svg>
                                Ver contratos/termos
                            </button>
                        </div>
                    </div>
                }
            </div>

            @* Message area *@
            <div id="msgBox" class="flex-1 overflow-y-auto p-5 space-y-3" style="background:var(--bg)">
                @if (!Model.Mensagens.Any())
                {
                    <p class="text-center text-sm py-8" style="color:var(--text-muted)">Nenhuma mensagem. Diga olá!</p>
                }
                @{ DateTime? lastCliDate = null; }
                @foreach (var m in Model.Mensagens)
                {
                    var cDate = m.EnviadaEm.ToLocalTime().Date;
                    if (lastCliDate == null || lastCliDate.Value != cDate) {
                        lastCliDate = cDate;
                        string cLabel = cDate == DateTime.Now.Date ? "Hoje" : cDate == DateTime.Now.Date.AddDays(-1) ? "Ontem" : cDate.ToString("dd/MM/yyyy");
                        <div class="flex items-center justify-center my-2">
                            <span class="text-[11px] px-3 py-1 rounded-full" style="background:var(--bg2);color:var(--text-muted)">@cLabel</span>
                        </div>
                    }
                    bool isMe = m.RemetenteId == Model.UsuarioAtual.Id;
                    bool isSpecial = m.Conteudo.StartsWith("{\"_t\":\"");
                    string mType = "", mId = "", mR = "", mJ = "", mV = "", mUrl = "", mNome = "", mQRef = "", mQMsg = "";
                    if (isSpecial)
                    {
                        try
                        {
                            using var doc = System.Text.Json.JsonDocument.Parse(m.Conteudo);
                            var root = doc.RootElement;
                            mType = root.TryGetProperty("_t",   out var t)   ? (t.GetString()   ?? "") : "";
                            mId   = root.TryGetProperty("id",   out var mid) ? mid.GetInt32().ToString() : "";
                            mR    = root.TryGetProperty("r",    out var r)   ? (r.GetString()   ?? "") : "";
                            mJ    = root.TryGetProperty("j",    out var j)   ? (j.GetString()   ?? "") : "";
                            mV    = root.TryGetProperty("v",    out var v)   ? (v.GetString()   ?? "") : "";
                            mUrl  = root.TryGetProperty("url",  out var mu)  ? (mu.GetString()  ?? "") : "";
                            mNome = root.TryGetProperty("nome", out var mn)  ? (mn.GetString()  ?? "") : "";
                            mQRef = root.TryGetProperty("ref",  out var qrf) ? (qrf.GetString() ?? "") : "";
                            mQMsg = root.TryGetProperty("msg",  out var qmv) ? (qmv.GetString() ?? "") : "";
                        }
                        catch { isSpecial = false; }
                    }
                    string mCtxData = isSpecial && mType == "F" ? "" : (isSpecial && mType == "Q" ? mQMsg : (!isSpecial ? m.Conteudo : ""));
                    bool mHasMenu = !isSpecial || mType == "F" || mType == "Q";
                    <div class="flex @(isMe ? "justify-end" : "justify-start") items-end gap-1 msg-animate msg-wrapper group"
                         data-msg-id="@m.Id" data-is-me="@(isMe ? "true" : "false")"
                         data-conteudo="@mCtxData" data-is-grupo="false">
                        @if (isMe && mHasMenu) {
                            <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                            </button>
                        }
                        @if (isSpecial && mType == "M") {
                            <div class="msg-card msg-card-mudanca flex flex-col gap-2">
                                <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--brown)">Solicitação de Mudança</p>
                                <p class="text-sm" style="color:var(--text)">@mR</p>
                                <button onclick="abrirVerMudanca('@mId')" class="btn-secondary text-xs px-3 py-1.5 self-start">Visualizar Mudança</button>
                                <span class="text-[10px] opacity-60 self-end">@m.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                        } else if (isSpecial && mType == "R") {
                            <div class="msg-card msg-card-rejeicao flex flex-col gap-2">
                                <p class="text-xs font-bold uppercase tracking-wider" style="color:#ef4444">@mR</p>
                                @if (!string.IsNullOrEmpty(mJ)) { <p class="text-sm" style="color:var(--text)">@mJ</p> }
                                <span class="text-[10px] opacity-60 self-end">@m.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                        } else if (isSpecial && mType == "V") {
                            <div class="msg-card msg-card-valor flex flex-col gap-2">
                                <p class="text-xs font-bold uppercase tracking-wider" style="color:#16a34a">Atualização do Projeto</p>
                                <p class="text-sm" style="color:var(--text)">@mR</p>
                                @if (!string.IsNullOrEmpty(mV) && decimal.TryParse(mV, out var vDec) && vDec > 0) { <p class="text-sm font-bold" style="color:#16a34a">+ R$ @mV</p> }
                                <span class="text-[10px] opacity-60 self-end">@m.EnviadaEm.ToLocalTime().ToString("HH:mm")</span>
                            </div>
                        } else if (isSpecial && mType == "F") {
                            bool mIsImg = new[] { ".png", ".jpg", ".jpeg" }.Contains(System.IO.Path.GetExtension(mUrl).ToLowerInvariant());
                            <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1">
                                @if (mIsImg) {
                                    <img src="@mUrl" alt="@mNome" class="max-w-[220px] rounded-lg cursor-pointer" onclick="abrirFileViewer('@mUrl','@mNome',@(isMe ? "true" : "false"))" style="max-height:160px;object-fit:cover"/>
                                } else {
                                    <a href="#" onclick="abrirFileViewer('@mUrl','@mNome',@(isMe ? "true" : "false"));return false;" style="word-break:break-all;color:inherit" class="flex items-center gap-1 text-sm underline">📄 @mNome</a>
                                }
                                <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                                    @m.EnviadaEm.ToLocalTime().ToString("HH:mm")
                                    @if (isMe) { <span class="msg-receipt font-bold" style="color:@(m.Lida ? "#16a34a" : "inherit")">@(m.Lida ? "✓✓" : "✓")</span> }
                                </span>
                            </div>
                        } else if (isSpecial && mType == "Q") {
                            <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1">
                                <div class="rounded-lg px-2 py-1 mb-0.5 border-l-2" style="background:var(--shadow);border-color:var(--brown)">
                                    <span class="text-[10px] truncate block" style="color:var(--text-muted)">@Html.Raw(System.Net.WebUtility.HtmlEncode(mQRef.Length > 80 ? mQRef[..80] + "…" : mQRef))</span>
                                </div>
                                <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(mQMsg).Replace("\n","<br>"))</span>
                                <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                                    @m.EnviadaEm.ToLocalTime().ToString("HH:mm")
                                    @if (isMe) { <span class="msg-receipt font-bold" style="color:@(m.Lida ? "#16a34a" : "inherit")">@(m.Lida ? "✓✓" : "✓")</span> }
                                </span>
                            </div>
                        } else {
                            <div class="@(isMe ? "bubble-sent" : "bubble-recv") flex flex-col gap-1">
                                <span class="msg-conteudo">@Html.Raw(System.Net.WebUtility.HtmlEncode(m.Conteudo).Replace("\n","<br>"))</span>
                                <span class="text-[10px] opacity-60 self-end flex items-center gap-1">
                                    @m.EnviadaEm.ToLocalTime().ToString("HH:mm")
                                    @if (isMe) { <span class="msg-receipt font-bold" style="color:@(m.Lida ? "#16a34a" : "inherit")">@(m.Lida ? "✓✓" : "✓")</span> }
                                </span>
                            </div>
                        }
                        @if (!isMe && mHasMenu) {
                            <button type="button" onclick="openMsgMenu(event,this)" class="opacity-0 group-hover:opacity-100 transition-opacity flex-shrink-0 p-1 rounded" style="color:var(--text-muted)" aria-label="Opções">
                                <svg class="w-4 h-4" fill="currentColor" viewBox="0 0 24 24"><circle cx="12" cy="5" r="1.5"/><circle cx="12" cy="12" r="1.5"/><circle cx="12" cy="19" r="1.5"/></svg>
                            </button>
                        }
                    </div>
                }
                <div id="typingIndicator" class="hidden justify-start">
                    <div class="bubble-recv dot-bounce py-3 px-4 flex items-center gap-1">
                        <span></span><span></span><span></span>
                    </div>
                </div>
            </div>

            @* Input area *@
            @if (Model.ChatBloqueado)
            {
                <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0 flex items-center justify-center gap-2" style="background:var(--bg2)">
                    <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--text-muted)"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/></svg>
                    <p class="text-sm font-medium" style="color:var(--text-muted)">Esta conversa foi encerrada</p>
                </div>
            }
            else
            {
                <div class="px-5 py-4 border-t border-[#6B462C]/10 flex-shrink-0">
                    <input type="file" id="fileInput" class="hidden" accept="image/png,image/jpeg,application/pdf,application/zip,.zip"/>
                    <div id="replyPreview" class="hidden mb-2 flex items-center gap-2 rounded-xl px-3 py-1.5" style="background:var(--brown-subtle)">
                        <div class="w-0.5 self-stretch rounded-full flex-shrink-0" style="background:var(--brown)"></div>
                        <span id="replyText" class="text-xs flex-1 truncate" style="color:var(--text-muted)"></span>
                        <button type="button" onclick="cancelarReply()" class="flex-shrink-0 p-0.5" style="color:var(--text-muted)"><svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2.5"><path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/></svg></button>
                    </div>
                    <form id="chatForm" class="chat-input-form flex items-center gap-3 bg-[#F4F3EE] rounded-2xl border border-[#6B462C]/20 px-2 py-1.5 focus-within:border-[#6B462C]/50 focus-within:ring-2 focus-within:ring-[#6B462C]/10 transition-all"
                          onsubmit="enviarMsg(event)">
                        <button type="button" onclick="document.getElementById('fileInput').click()"
                                class="chat-attach-btn text-[#8d6945] hover:text-[#4d392a] transition-colors flex-shrink-0 hover:scale-110 active:scale-95 p-2" title="Anexar arquivo">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-6 w-6" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M5 19a2 2 0 01-2-2V7a2 2 0 012-2h4l2 2h4a2 2 0 012 2v1M5 19h14a2 2 0 002-2v-5a2 2 0 00-2-2H9l-2 3H5a2 2 0 00-2 2v2a2 2 0 002 2z"/>
                            </svg>
                        </button>
                        <textarea id="msgInput" rows="1" maxlength="4000"
                               class="chat-input-text flex-1 bg-transparent focus:outline-none text-sm text-[#4d392a] placeholder-[#8d6945]/60"
                               placeholder="Escreva sua mensagem..." autocomplete="off" aria-label="Digite uma mensagem"></textarea>
                        <button type="submit"
                                class="chat-send-btn bg-[#6B462C] text-white p-2 rounded-xl hover:bg-[#4d392a] transition-all hover:scale-105 active:scale-95 shadow-sm flex-shrink-0 m-1.5" title="Enviar">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M2.01 21L23 12L2.01 3L2 10l15 2l-15 2z"/>
                            </svg>
                        </button>
                    </form>
                </div>
            }
        }
    </div>
</div>

@* Modal visualizador de arquivo *@
<div id="modalFileViewer" class="hidden fixed inset-0 z-[200] flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/85 backdrop-blur-sm" onclick="closeModal('modalFileViewer')"></div>
    <div class="relative z-10 flex flex-col items-center gap-4 w-full max-w-3xl mx-4">
        <div class="flex items-center justify-between w-full px-2">
            <p id="fileViewerNome" class="text-white text-sm font-medium truncate max-w-[70%]"></p>
            <div class="flex items-center gap-3">
                <a id="fileViewerDownload" href="#" download class="hidden text-white text-sm flex items-center gap-1.5 bg-white/20 hover:bg-white/30 px-3 py-1.5 rounded-lg transition-colors">
                    <svg class="w-4 h-4" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M4 16v1a3 3 0 003 3h10a3 3 0 003-3v-1m-4-4l-4 4m0 0l-4-4m4 4V4"/></svg>
                    Baixar
                </a>
                <button onclick="closeModal('modalFileViewer')" class="text-white hover:text-gray-300 transition-colors" aria-label="Fechar">
                    <svg class="w-6 h-6" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
                </button>
            </div>
        </div>
        <div id="fileViewerBody" class="w-full flex items-center justify-center"></div>
    </div>
</div>

@* Context menu mensagem *@
<div id="msgContextMenu" class="hidden fixed z-[400] ms-card shadow-xl rounded-xl overflow-hidden py-1" style="min-width:180px">
    <button id="mcCopy" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2.5 transition-opacity" style="color:var(--text)">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M8 16H6a2 2 0 01-2-2V6a2 2 0 012-2h8a2 2 0 012 2v2m-6 12h8a2 2 0 002-2v-8a2 2 0 00-2-2h-8a2 2 0 00-2 2v8a2 2 0 002 2z"/></svg>
        Copiar
    </button>
    <button id="mcReply" class="w-full text-left px-4 py-2.5 text-sm hover:opacity-70 flex items-center gap-2.5 transition-opacity" style="color:var(--text)">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2"><path stroke-linecap="round" stroke-linejoin="round" d="M3 10h10a8 8 0 018 8v2M3 10l6 6m-6-6l6-6"/></svg>
        Responder
    </button>
</div>

@section Scripts {
<script src="https://cdnjs.cloudflare.com/ajax/libs/microsoft-signalr/8.0.0/signalr.min.js"></script>
<script>
const ME         = @Model.UsuarioAtual.Id;
const CONTATO_ID = @(Model.ContatoSelecionadoId?.ToString() ?? "0");
const IS_GRUPO   = @(Model.IsGrupoSuporte ? "true" : "false");
const msgBox     = document.getElementById('msgBox');
const msgInput   = document.getElementById('msgInput');
let pendingFile  = null;

function openModal(id)  { document.getElementById(id)?.classList.remove('hidden'); }
function closeModal(id) { document.getElementById(id)?.classList.add('hidden'); }

// Inicializa dropdowns de menu do chat
function setupDropdown(btnId, dropId) {
    const btn  = document.getElementById(btnId);
    const drop = document.getElementById(dropId);
    if (!btn || !drop) return;
    btn.addEventListener('click', e => { e.stopPropagation(); drop.classList.toggle('hidden'); });
    document.addEventListener('click', () => drop.classList.add('hidden'));
}
setupDropdown('filterMenuBtn', 'filterDropdown');
setupDropdown('actionMenuBtn', 'actionDropdown');

// Modo de filtro ativo para a lista de contatos
let filterMode = 'nome';
const searchInput = document.querySelector('input[aria-label="Buscar conversa"]');

const filterPlaceholders = {
    nome:    'Buscar por nome...',
    tipo:    'Ex: E-commerce, Landing Pages, SEO...',
    recente: 'Pesquisar conversa...'
};

document.querySelectorAll('.filter-opt').forEach(btn => {
    btn.addEventListener('click', () => {
        const f = btn.dataset.filter;
        filterMode = f;

        // Highlight active filter
        document.querySelectorAll('.filter-opt').forEach(b => {
            b.style.fontWeight = '';
            b.style.color = 'var(--text)';
        });
        btn.style.fontWeight = 'bold';
        btn.style.color = 'var(--brown)';

        document.getElementById('filterDropdown')?.classList.add('hidden');

        if (f === 'recente') {
            if (searchInput) { searchInput.value = ''; searchInput.placeholder = filterPlaceholders.recente; }
            filtrarContatos('');
        } else {
            if (searchInput) { searchInput.value = ''; searchInput.placeholder = filterPlaceholders[f] || ''; searchInput.focus(); }
            filtrarContatos('');
        }
    });
});

// Filtra a lista de contatos pelo texto digitado e pelo modo de filtro ativo
function filtrarContatos(q) {
    const lq = q.toLowerCase().trim();
    document.querySelectorAll('.contact-item').forEach(el => {
        if (!lq) { el.style.display = ''; return; }
        let match = false;
        if (filterMode === 'tipo') {
            const tipo = (el.dataset.tipo || '').toLowerCase();
            match = tipo.includes(lq);
        } else {
            const nome = (el.querySelector('.contact-name')?.textContent || '').toLowerCase();
            match = nome.includes(lq);
        }
        el.style.display = match ? '' : 'none';
    });
}

