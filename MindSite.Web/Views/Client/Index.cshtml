// Exibe o painel de requisitos do tipo selecionado e atualiza os placeholders
function selecionarTipo(t) {
    [0,1,2,3].forEach(i => document.getElementById(`reqs-${i}`)?.classList.add('hidden'));
    document.getElementById('reqs-generic')?.classList.add('hidden');
    if (OLD_TIPOS.includes(t)) {
        document.getElementById(`reqs-${t}`)?.classList.remove('hidden');
    } else if (!isNaN(t) && t !== '') {
        document.getElementById('reqs-generic')?.classList.remove('hidden');
    }

    // Placeholders dinâmicos
    const det = document.querySelector('#reqs-generic [data-group="Detalhes"]');
    if (det) det.placeholder = PH_DETALHES[t] ?? 'Descreva qualquer requisito específico do projeto...';
    const obs = document.getElementById('obsGeral');
    if (obs) obs.placeholder = PH_OBS[t] ?? 'Conte mais sobre o projeto, referências, restrições...';
}

// Exibe mensagem de erro com lista de pendências no formulário de serviço
function mostrarErroServico(linhas) {
    let el = document.getElementById('erroServico');
    if (!el) {
        el = document.createElement('div');
        el.id = 'erroServico';
        el.className = 'rounded-xl px-4 py-3 text-sm font-medium';
        el.style.cssText = 'background:rgba(239,68,68,.12);color:#ef4444;';
        const btnRow = document.querySelector('#formServico .flex.gap-3:last-child');
        if (btnRow) btnRow.before(el);
    }
    el.innerHTML = linhas.map(l => `• ${l}`).join('<br>');
    el.scrollIntoView({ behavior:'smooth', block:'nearest' });
}

// Mostra ou oculta o campo de data específica conforme a opção de prazo escolhida
function onPrazoChange(radio) {
    document.getElementById('divDataPrazo').classList.toggle('hidden', radio.value !== 'DataEspecifica');
    if (radio.value !== 'DataEspecifica') document.getElementById('inputDataPrazo').value = '';
}

// Mostra ou oculta o campo de valor do orçamento conforme a opção selecionada
function onOrcamentoChange(radio) {
    const div = document.getElementById('divOrcamentoValor');
    if (radio.value === 'definido') {
        div.classList.remove('hidden');
        document.getElementById('inputOrcamento').focus();
    } else {
        div.classList.add('hidden');
        document.getElementById('inputOrcamento').value = '';
    }
}

// Valida o formulário de serviço, monta os requisitos e submete ou exibe erros
function submeterServico() {
    const erros = [];
    const sel = document.getElementById('selectTipo');
    if (!sel || sel.value === '') { MsVal.erro(sel, 'Selecione o tipo de serviço'); return; }
    MsVal.ok(sel);
    const tipo = parseInt(sel.value);
    const panelId = OLD_TIPOS.includes(tipo) ? `reqs-${tipo}` : 'reqs-generic';

    const nomeEl = document.querySelector('input[name="NomeProjeto"]');
    if (!nomeEl?.value.trim()) { MsVal.erro(nomeEl, 'Informe o nome do projeto'); return; }
    MsVal.ok(nomeEl);

    const totalChecked = document.querySelectorAll(`#${panelId} input[type="checkbox"]:checked`).length;
    if (totalChecked === 0) erros.push('Selecione ao menos uma opção desejada');

    const radiosObrig = { 0:['ecom-qtd','Quantidade de produtos'], 1:['blog-freq','Frequência de publicação'], 3:['mkt-obj','Objetivo principal'] };
    if (radiosObrig[tipo]) {
        const [name, label] = radiosObrig[tipo];
        if (!document.querySelector(`input[name="${name}"]:checked`)) erros.push(`Selecione: ${label}`);
    }

    const prazoEl = document.querySelector('input[name="prazoOpcao"]:checked');
    if (!prazoEl) {
        erros.push('Selecione o prazo esperado');
    } else if (prazoEl.value === 'DataEspecifica') {
        if (!document.getElementById('inputDataPrazo')?.value) erros.push('Selecione a data de entrega');
    }

    const orcOpcao = document.querySelector('input[name="orcamentoOpcao"]:checked');
    if (!orcOpcao) {
        erros.push('Selecione uma opção de orçamento');
    } else if (orcOpcao.value === 'definido') {
        const v = parseFloat(document.getElementById('inputOrcamento').value);
        if (isNaN(v) || v <= 0) erros.push('Informe o valor do orçamento');
    }

    if (erros.length > 0) { mostrarErroServico(erros); return; }
    const erroDiv = document.getElementById('erroServico');
    if (erroDiv) erroDiv.remove();

    let reqs = `Tipo: ${TIPO_NOMES[tipo]}\n`;
    const checks = [...document.querySelectorAll(`#${panelId} input[type="checkbox"]:checked`)].map(cb => `• ${cb.dataset.label}`).join('\n');
    if (checks) reqs += `\nFuncionalidades:\n${checks}\n`;
    document.querySelectorAll(`#${panelId} input[type="radio"]:checked`).forEach(r => { if (r.dataset.group) reqs += `\n${r.dataset.group}: ${r.value}`; });
    document.querySelectorAll(`#${panelId} [data-group]`).forEach(el => {
        if (el.tagName === 'TEXTAREA' || (el.tagName === 'INPUT' && el.type === 'text')) {
            const v = el.value.trim();
            if (v) reqs += `\n${el.dataset.group}: ${v}`;
        }
    });

    const prazoLabels = { Meses1a3:'1 a 3 meses', Ate6Meses:'Até 6 meses', Ate1Ano:'Até 1 ano', MaisDeUmAno:'Mais de 1 ano', NaoSei:'Não sei', DataEspecifica:'Data específica' };
    const prazo = document.querySelector('input[name="prazoOpcao"]:checked');
    if (prazo) {
        reqs += `\n\nPrazo: ${prazoLabels[prazo.value] || prazo.value}`;
        document.getElementById('hidPrazoCliente').value = prazo.value;
        if (prazo.value === 'DataEspecifica') {
            const d = document.getElementById('inputDataPrazo').value;
            document.getElementById('hidDataPrazo').value = d;
            if (d) reqs += ` (${new Date(d + 'T00:00:00').toLocaleDateString('pt-BR')})`;
        } else {
            document.getElementById('hidDataPrazo').value = '';
        }
    }

    const obs = document.getElementById('obsGeral').value.trim();
    if (obs) reqs += `\n\nInformações adicionais: ${obs}`;

    const orcOpcao2 = document.querySelector('input[name="orcamentoOpcao"]:checked');
    if (orcOpcao2?.value === 'definido') {
        const val = parseFloat(document.getElementById('inputOrcamento').value);
        document.getElementById('hidOrcamento').value = val;
        reqs += `\n\nOrçamento do cliente: R$ ${val.toLocaleString('pt-BR', {minimumFractionDigits:2, maximumFractionDigits:2})}`;
    } else {
        document.getElementById('hidOrcamento').value = '';
    }

    document.getElementById('hidRequisitos').value = reqs.trim();

    document.getElementById('checkContratoCliente').checked = false;
    const cliDataField = document.getElementById('contratoClienteData');
    const hoje = new Date().toISOString().split('T')[0];
    if (cliDataField) { cliDataField.value = hoje; }
    const cliCpfField = document.getElementById('contratoClienteCPF');
    if (cliCpfField && cliCpfField.value) mascararCpfCnpj(cliCpfField);
    verificarCamposContratoCliente();
    openModal('modalContratoCliente');
}

// Remove caracteres inválidos do campo de nome no contrato
function filtrarNome(el) {
    const pos = el.selectionStart;
    const cleaned = el.value.replace(/[^a-zA-ZÀ-ÿ\s''-]/g, '');
    if (cleaned !== el.value) { el.value = cleaned; el.setSelectionRange(pos - 1, pos - 1); }
}

// Aplica máscara de CPF ao campo durante digitação
function mascararCpfCnpj(el) {
    const d = el.value.replace(/\D/g, '').slice(0, 11);
    const n = d.length;
    let m = '';
    if      (n <= 3)  m = d;
    else if (n <= 6)  m = d.slice(0,3) + '.' + d.slice(3);
    else if (n <= 9)  m = d.slice(0,3) + '.' + d.slice(3,6) + '.' + d.slice(6);
    else              m = d.slice(0,3) + '.' + d.slice(3,6) + '.' + d.slice(6,9) + '-' + d.slice(9);
    el.value = m;
}

// Habilita o botão de aceitar contrato quando CPF está preenchido e checkbox marcado
function verificarCamposContratoCliente() {
    const cpf   = document.getElementById('contratoClienteCPF')?.value.trim();
    const check = document.getElementById('checkContratoCliente')?.checked;
    const digits    = cpf ? cpf.replace(/\D/g, '') : '';
    const cpfValido = digits.length === 11;
    document.getElementById('btnAceitarContratoCliente').disabled = !(cpfValido && check);
}

// Cancela o fluxo do contrato e fecha o modal
function cancelarContratoCliente()  { closeModal('modalContratoCliente'); }
// Fecha o modal do contrato e submete o formulário de solicitação
function confirmarContratoCliente() { closeModal('modalContratoCliente'); closeModal('modalServico'); document.getElementById('formServico').submit(); }

@if (ViewBag.AbrirFormulario == true)
{
    <text>document.addEventListener('DOMContentLoaded', () => abrirModalServico());</text>
}
</script>
}
