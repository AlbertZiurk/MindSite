// Alterna a exibição dos cards de serviço extras
function toggleSvcExtra() {
    const el   = document.getElementById('svc-extra');
    const txt  = document.getElementById('svc-ver-mais-txt');
    const icon = document.getElementById('svc-ver-mais-icon');
    const isHidden = el.style.display === 'none';
    el.style.display = isHidden ? '' : 'none';
    txt.textContent  = isHidden ? 'Ver menos' : 'Ver mais serviços';
    icon.style.transform = isHidden ? 'rotate(180deg)' : '';
}

// Abre o modal de solicitação de serviço e pré-seleciona o tipo se informado
function abrirModalServico(tipo) {
    document.getElementById('formServico').reset();
    [0,1,2,3].forEach(i => document.getElementById(`reqs-${i}`)?.classList.add('hidden'));
    document.getElementById('reqs-generic')?.classList.add('hidden');
    const erroDiv = document.getElementById('erroServico');
    if (erroDiv) erroDiv.remove();
    if (tipo !== undefined) {
        const sel = document.getElementById('selectTipo');
        if (sel) { sel.value = tipo; selecionarTipo(tipo); }
    }
    openModal('modalServico');
}

const PH_DETALHES = {
    4:  'Ex: Quero um site com 5 páginas (Home, Sobre, Serviços, Blog, Contato). A empresa é um escritório de advocacia. Precisamos de formulário de contato e mapa do Google integrado.',
