const PH_OBS = {
    0:  'Ex: Referências de lojas que gosto: site1.com, site2.com. Prefiro visual minimalista. Estoque no ERP Bling. Preciso de integração com API dos Correios para cálculo de frete.',
    1:  'Ex: Tenho 50 artigos no Blogger para importar. Estilo visual parecido com o Medium. Quero compatibilidade com Google AdSense para monetização futura.',
    2:  'Ex: Paleta definida: azul-marinho (#0A1628) e dourado (#C9A84C). Referências de estilo: Awwwards.com. Tenho todas as imagens e textos prontos para envio.',
    3:  'Ex: Concorrente principal: empresa XYZ. Já temos conta no Google Ads pausada. Público-alvo: mulheres 25–45 interessadas em bem-estar. Foco em conversão, não só cliques.',
