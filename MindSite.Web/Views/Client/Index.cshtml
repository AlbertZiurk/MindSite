@{
    ViewData["Title"] = "Início";
    Layout = "_LayoutClient";
}

<style>
    /* Section backgrounds */
    #home, #fornecedor { background: #F4F3EE; }
    #servicos          { background: #F9F8F3; }

    [data-theme="dark"]          #home,
    [data-theme="dark"]          #fornecedor { background: var(--bg);  }
    [data-theme="dark"]          #servicos   { background: var(--bg2); }
    [data-theme="dark"]          .ms-svc-card { background: #1A1410; }

    [data-access="alto-contraste"] #home,
    [data-access="alto-contraste"] #fornecedor,
    [data-access="alto-contraste"] #servicos   { background: var(--bg); }

    /* Floating card (Hero & Fornecedor) */
    .ms-float-wrap {
        position: relative;
        display: flex;
        align-items: center;
        justify-content: center;
        width: 100%;
    }
    .ms-float-blob { display: none; }
    .ms-float-card {
        background: var(--surface);
        border-radius: 30px;
        box-shadow: 0 20px 60px var(--shadow);
        padding: 1.5rem;
        display: flex;
        flex-direction: column;
        gap: 1.25rem;
        width: 100%;
        max-width: 360px;
        position: relative;
        z-index: 1;
    }
    .ms-float-img {
        width: 100%;
        height: 200px;
        border-radius: 25px;
        overflow: hidden;
        box-shadow: inset 0 2px 8px rgba(0,0,0,.12);
    }
    @@media (min-width: 768px) {
        .ms-float-wrap  { width: 520px; min-height: 540px; }
        .ms-float-blob  {
            display: block;
            position: absolute;
            width: 480px; height: 280px;
            background: var(--brown);
            border-radius: 30px;
            box-shadow: 0 10px 30px var(--shadow);
            top: 50%; left: 50%;
            transform: translate(-50%, 5%);
        }
        .ms-float-card  {
            position: absolute;
            width: 400px; height: 500px;
            top: 50%; left: 50%;
            transform: translate(-50%, -60%);
            padding: 2rem;
            gap: 1.5rem;
            max-width: none;
        }
        .ms-float-img   { height: 280px; }
    }

    /* Service cards (horizontal) */
    .ms-svc-card {
        background: var(--bg2);
        transition: transform .2s, box-shadow .2s;
        box-shadow: 0 2px 10px rgba(0,0,0,.06);
    }
    .ms-svc-card:hover {
        transform: translateY(-2px);
        box-shadow: 0 8px 28px rgba(0,0,0,.1);
    }
    [data-theme="dark"] .ms-svc-card { background: #1A1410; }
    .ms-svc-icon {
        background: color-mix(in srgb, var(--brown) 12%, transparent);
    }
    .ms-svc-btn {
        background: var(--brown); color: #fff; cursor: pointer; border: none;
        transition: background .2s, transform .1s;
    }
    .ms-svc-btn:hover  { background: var(--brown-dark); }
    .ms-svc-btn:active { transform: scale(.95); }
    .ms-ver-mais-btn {
        display: flex; align-items: center; gap: .5rem;
        padding: .7rem 2rem; border-radius: 10px;
        font-weight: 700; font-size: .875rem;
        border: 1.5px solid var(--brown);
        color: var(--brown); background: transparent;
        cursor: pointer; transition: background .2s, color .2s;
    }
    .ms-ver-mais-btn:hover { background: var(--brown); color: #fff; }
    #svc-ver-mais-icon { transition: transform .3s; }

    /* Index buttons */
    .ms-idx-primary {
        display: block; width: 100%; text-align: center;
        background: var(--brown); color: #fff;
        font-weight: 700; border-radius: .5rem;
        padding: .75rem 1rem;
        transition: background .2s, transform .1s;
    }
    .ms-idx-primary:hover  { background: var(--brown-dark); }
    .ms-idx-primary:active { transform: scale(.98); }

    .ms-idx-secondary {
        display: block; width: 100%; text-align: center;
        background: var(--bg2); color: var(--text);
        font-weight: 700; border-radius: .5rem;
        padding: .75rem 1rem;
        transition: filter .2s;
    }
    .ms-idx-secondary:hover { filter: brightness(.95); }

    /* Benefício check */
    .ms-check { background: var(--brown-dark); }
    [data-theme="dark"] .ms-check svg,
    [data-access="alto-contraste"] .ms-check svg { color: #1A1410; }

    /* Modal input */
    .ms-req-input {
        width: 100%;
        border: 2px solid color-mix(in srgb, var(--brown-dark) 40%, transparent);
        border-radius: 20px;
        padding: .625rem 1rem;
        font-size: .875rem;
        color: var(--text);
        background: color-mix(in srgb, var(--bg2) 30%, var(--bg));
        outline: none;
        font-family: inherit;
        transition: border-color .2s, background .3s;
    }
    .ms-req-input::placeholder { color: var(--text-muted); opacity: .7; }
    .ms-req-input:focus  { border-color: var(--brown-dark); }
    .ms-req-input option { background: var(--bg); color: var(--text); }
</style>

@* Modal contrato do cliente *@
<div id="modalContratoCliente" class="modal-overlay hidden fixed inset-0 z-[60] flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/60 backdrop-blur-sm"></div>
    <div class="modal-box relative ms-card w-full max-w-2xl mx-4 z-10 flex flex-col" style="max-height:90vh">
        <div class="px-6 md:px-8 py-5 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div>
                <h3 class="font-inria font-bold text-xl" style="color:var(--text)">Termo de Compromisso</h3>
                <p class="text-xs mt-0.5" style="color:var(--text-muted)">Leia com atenção antes de prosseguir</p>
            </div>
            <svg class="w-7 h-7 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor" style="color:var(--brown)" aria-hidden="true">
                <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 12h6m-6 4h6m2 5H7a2 2 0 01-2-2V5a2 2 0 012-2h5.586a1 1 0 01.707.293l5.414 5.414a1 1 0 01.293.707V19a2 2 0 01-2 2z"/>
            </svg>
        </div>
        <div class="flex-1 overflow-y-auto px-6 md:px-8 py-6 text-sm leading-relaxed" style="color:var(--text)">
            <p class="font-bold text-base mb-5" style="color:var(--brown)">CONTRATO CLIENTE</p>
            <div class="flex flex-col gap-5">
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Responsabilidades</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>Enviar informações corretas;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Fornecer materiais necessários;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Responder solicitações no prazo;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Realizar pagamentos conforme combinado.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Pagamento</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>30% no início do projeto;</span></li>
                        <li class="flex gap-2"><span>●</span><span>70% após aprovação final;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Taxas bancárias podem ser aplicadas em estornos.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Não é permitido</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>Solicitar conteúdos ilegais;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Tentar negociar fora da plataforma;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Utilizar o sistema de forma abusiva;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Praticar fraudes.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Cancelamento</p>
                    <ul class="flex flex-col gap-1 pl-1" style="color:var(--text-muted)">
                        <li class="flex gap-2"><span>●</span><span>Antes do início: poderá haver retenção de taxas;</span></li>
                        <li class="flex gap-2"><span>●</span><span>Após início: valores poderão ser proporcionais ao trabalho executado.</span></li>
                    </ul>
                </div>
                <div>
                    <p class="font-semibold mb-2" style="color:var(--text)">Mediação</p>
                    <p style="color:var(--text-muted)">A MindSite poderá analisar mensagens, arquivos e entregas em casos de disputa.</p>
                </div>
                <div class="border-t pt-4" style="border-color:var(--border)">
                    <p class="font-semibold mb-3" style="color:var(--text)">Assinatura de Consentimento</p>
                    <div class="flex flex-col gap-3">
                        <div>
                            <label class="text-xs font-bold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Nome</label>
                            <input type="text" id="contratoClienteNome" class="ms-req-input" readonly
                                   value="@(ViewBag.NomeCompleto ?? "")" maxlength="100"
                                   style="opacity:0.7;cursor:default"/>
                        </div>
                        <div>
                            <label class="text-xs font-bold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">CPF</label>
                            <input type="text" id="contratoClienteCPF" class="ms-req-input" placeholder="000.000.000-00"
                                   value="@(ViewBag.CPF ?? "")" inputmode="numeric" maxlength="14"
                                   oninput="mascararCpfCnpj(this);verificarCamposContratoCliente()"/>
                        </div>
                        <div>
                            <label class="text-xs font-bold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Data</label>
                            <input type="date" id="contratoClienteData" class="ms-req-input" readonly
                                   style="opacity:0.7;cursor:default"/>
                        </div>
                        <label class="flex items-start gap-3 cursor-pointer pt-3 mt-1 border-t" style="border-color:var(--border)">
                            <input type="checkbox" id="checkContratoCliente" class="w-5 h-5 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]"
                                   onchange="verificarCamposContratoCliente()"/>
                            <span class="text-sm" style="color:var(--text)">Li e concordo com todos os termos e autorizo a MindSite a processar minha solicitação.</span>
                        </label>
                    </div>
                </div>
            </div>
        </div>
        <div class="px-6 md:px-8 py-5 border-t flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div class="flex gap-3">
                <button type="button" onclick="cancelarContratoCliente()" class="btn-ghost flex-1">Cancelar</button>
                <button type="button" id="btnAceitarContratoCliente" disabled onclick="confirmarContratoCliente()"
                        class="btn-primary flex-1 disabled:opacity-40 disabled:cursor-not-allowed">Aceitar Contrato</button>
            </div>
        </div>
    </div>
</div>

@* Modal solicitar serviço *@
<div id="modalServico" class="modal-overlay hidden fixed inset-0 z-50 flex items-center justify-center" aria-modal="true" role="dialog">
    <div class="absolute inset-0 bg-black/50 backdrop-blur-sm"></div>
    <div class="modal-box relative ms-card w-full max-w-2xl mx-4 z-10 flex flex-col" style="max-height:92vh">
        <div class="px-6 md:px-8 py-5 border-b flex items-center justify-between flex-shrink-0" style="border-color:var(--border);background:var(--bg2)">
            <div>
                <h3 class="font-inria font-bold text-xl" style="color:var(--text)">Novo Projeto</h3>
                <p class="text-xs mt-0.5" style="color:var(--text-muted)">Preencha os detalhes da sua solicitação</p>
            </div>
            <button onclick="closeModal('modalServico')" style="color:var(--text-muted)" aria-label="Fechar">
                <svg class="w-5 h-5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M6 18L18 6M6 6l12 12"/></svg>
            </button>
        </div>
        <div class="flex-1 overflow-y-auto">
            <form id="formServico" asp-controller="Client" asp-action="SolicitarServico" method="post" class="p-6 md:p-8 flex flex-col gap-6 md:gap-8">
                @Html.AntiForgeryToken()
                <input type="hidden" id="hidRequisitos"   name="Requisitos"       value=""/>
                <input type="hidden" id="hidPrazoCliente" name="PrazoCliente"     value=""/>
                <input type="hidden" id="hidDataPrazo"    name="DataPrazoCliente" value=""/>
                <input type="hidden" id="hidOrcamento"    name="OrcamentoCliente" value=""/>

                <div>
                    <label class="text-xs font-bold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Tipo de serviço *</label>
                    <select name="Tipo" id="selectTipo" class="ms-req-input" onchange="selecionarTipo(parseInt(this.value))">
                        <option value="">— Selecione o tipo de serviço —</option>
                        <option value="4">Sites Institucionais</option>
                        <option value="5">Landing Pages</option>
                        <option value="6">One-Page Sites</option>
                        <option value="7">Portfólios Digitais</option>
                        <option value="8">Blogs e Portais</option>
                        <option value="0">E-commerce</option>
                        <option value="9">Plataformas EAD</option>
                        <option value="10">Links para Bio</option>
                        <option value="11">Sistemas Web</option>
                        <option value="12">Agendamento Online</option>
                        <option value="13">Multi-idiomas</option>
                        <option value="14">Redesign de Site</option>
                        <option value="15">Manutenção</option>
                        <option value="16">SEO & Performance</option>
                        <option value="17">Migração de Site</option>
                    </select>
                </div>

                <div>
                    <label class="text-xs font-bold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Nome do projeto *</label>
                    <input type="text" name="NomeProjeto" class="ms-input" required maxlength="200" placeholder="Ex: Loja da Maria, Blog Tech Insights..."/>
                </div>

                <div id="reqs-0" class="hidden flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-muted)">Funcionalidades desejadas</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        @foreach (var item in new[]{ "Integração com meios de pagamento", "Catálogo de produtos com busca e filtros", "Área do cliente (login e cadastro)", "Painel administrativo para gestão", "Versão mobile otimizada", "Integração com sistema de estoque", "Chat/suporte ao cliente no site" })
                        {
                            <label class="flex items-start gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                <input type="checkbox" class="w-4 h-4 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]" data-label="@item"/> @item
                            </label>
                        }
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--text-muted)">Quantidade de produtos</p>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var opt in new[]{ "Até 50", "51–200", "201–1.000", "Mais de 1.000" })
                            {
                                <label class="flex items-center gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                    <input type="radio" name="ecom-qtd" value="@opt" class="accent-[color:var(--brown)]" data-group="Quantidade de produtos"/> @opt
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <div id="reqs-1" class="hidden flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-muted)">Funcionalidades desejadas</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        @foreach (var item in new[]{ "Design personalizado", "Sistema de comentários", "Newsletter / e-mail marketing", "Área de membros / assinantes", "Otimização para SEO", "Integração com redes sociais", "Busca interna" })
                        {
                            <label class="flex items-start gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                <input type="checkbox" class="w-4 h-4 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]" data-label="@item"/> @item
                            </label>
                        }
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--text-muted)">Frequência de publicação</p>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var opt in new[]{ "Diária", "Semanal", "Mensal", "Indefinida" })
                            {
                                <label class="flex items-center gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                    <input type="radio" name="blog-freq" value="@opt" class="accent-[color:var(--brown)]" data-group="Frequência de publicação"/> @opt
                                </label>
                            }
                        </div>
                    </div>
                </div>

                <div id="reqs-2" class="hidden flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-muted)">O que você precisa?</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        @foreach (var item in new[]{ "Landing Page", "Site institucional", "Redesign de site existente", "Identidade visual / branding", "Capas para redes sociais", "Wireframes e protótipos (Figma)" })
                        {
                            <label class="flex items-start gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                <input type="checkbox" class="w-4 h-4 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]" data-label="@item"/> @item
                            </label>
                        }
                    </div>
                    <div>
                        <label class="text-xs font-bold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Referências de design (sites, links)</label>
                        <textarea class="ms-textarea w-full" rows="3" data-group="Referências" placeholder="Cole links ou descreva referências que você gosta..."></textarea>
                    </div>
                </div>

                <div id="reqs-3" class="hidden flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-muted)">O que você precisa?</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        @foreach (var item in new[]{ "Landing Page de captação", "Gerenciamento de Google Ads", "Gerenciamento de Meta Ads", "E-mail marketing", "Relatórios e análises de performance", "Estratégia de conteúdo orgânico" })
                        {
                            <label class="flex items-start gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                <input type="checkbox" class="w-4 h-4 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]" data-label="@item"/> @item
                            </label>
                        }
                    </div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--text-muted)">Objetivo principal</p>
                        <div class="flex flex-wrap gap-3">
                            @foreach (var opt in new[]{ "Gerar leads", "Aumentar vendas", "Lançamento de produto", "Fortalecer a marca" })
                            {
                                <label class="flex items-center gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                    <input type="radio" name="mkt-obj" value="@opt" class="accent-[color:var(--brown)]" data-group="Objetivo"/> @opt
                                </label>
                            }
                        </div>
                    </div>
                    <div>
                        <label class="text-xs font-bold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Orçamento mensal estimado para mídia</label>
                        <input type="text" class="ms-input" data-group="Orçamento para mídia" placeholder="Ex: R$ 500/mês, ainda não definido..."/>
                    </div>
                </div>

                @* Painel genérico para os novos tipos de serviço *@
                <div id="reqs-generic" class="hidden flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <p class="text-xs font-bold uppercase tracking-wider" style="color:var(--text-muted)">O que você precisa?</p>
                    <div class="grid grid-cols-1 sm:grid-cols-2 gap-2">
                        @foreach (var item in new[]{ "Versão mobile responsiva", "Painel de gerenciamento", "Formulário de contato", "Integração com redes sociais", "Otimização para SEO", "Integração com sistema existente", "Suporte pós-entrega", "Treinamento de uso da plataforma" })
                        {
                            <label class="flex items-start gap-2 cursor-pointer text-sm" style="color:var(--text)">
                                <input type="checkbox" class="w-4 h-4 mt-0.5 flex-shrink-0 accent-[color:var(--brown)]" data-label="@item"/> @item
                            </label>
                        }
                    </div>
                    <div>
                        <label class="text-xs font-bold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Detalhes específicos</label>
                        <textarea class="ms-textarea w-full" rows="3" data-group="Detalhes" placeholder="Descreva qualquer requisito específico do projeto..."></textarea>
                    </div>
                </div>

                <div class="flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--text-muted)">Prazo esperado *</p>
                        <div class="flex flex-col gap-2">
                            @foreach (var opt in new[]{ new{Val="Meses1a3",Label="1 a 3 meses"}, new{Val="Ate6Meses",Label="Até 6 meses"}, new{Val="Ate1Ano",Label="Até 1 ano"}, new{Val="MaisDeUmAno",Label="Mais de 1 ano"}, new{Val="NaoSei",Label="Não sei (o fornecedor definirá o prazo)"}, new{Val="DataEspecifica",Label="Definir uma data"} })
                            {
                                <label class="flex items-center gap-2 cursor-pointer text-sm select-none" style="color:var(--text)">
                                    <input type="radio" name="prazoOpcao" value="@opt.Val" class="accent-[color:var(--brown)]" onchange="onPrazoChange(this)"/> @opt.Label
                                </label>
                            }
                        </div>
                        <div id="divDataPrazo" class="hidden mt-3">
                            <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Data de entrega</label>
                            <input type="date" id="inputDataPrazo" class="ms-input" min="@DateTime.Today.AddDays(1).ToString("yyyy-MM-dd")"/>
                        </div>
                    </div>
                    <div>
                        <label class="text-xs font-bold uppercase tracking-wider mb-2 block" style="color:var(--text-muted)">Informações adicionais</label>
                        <textarea id="obsGeral" class="ms-textarea w-full" rows="3" placeholder="Conte mais sobre o projeto, referências, restrições..."></textarea>
                    </div>
                </div>

                <div class="flex flex-col gap-5">
                    <div class="w-full h-px" style="background:var(--border)"></div>
                    <div>
                        <p class="text-xs font-bold uppercase tracking-wider mb-2" style="color:var(--text-muted)">Orçamento *</p>
                        <div class="flex flex-col gap-2">
