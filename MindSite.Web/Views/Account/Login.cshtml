@{
    ViewData["Title"] = "Login";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MindSite</title>
    <link rel="apple-touch-icon" sizes="180x180" href="favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="favicons/favicon-16x16.png">
    <link rel="manifest" href="favicons/site.webmanifest">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=Inria+Serif:wght@400;700&display=swap" rel="stylesheet">
    <script src="https://cdn.tailwindcss.com"></script>

    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'inria': ['"Inria Serif"', 'serif']
                    }
                }
            }
        }
    </script>
</head>
<body class="min-h-screen font-sans bg-[#F4F3EE]">

    <div class="flex flex-row w-full h-screen">
        
        <div class="flex-1 flex flex-col p-12 relative overflow-hidden">

            <div class="absolute inset-0 flex items-center justify-center z-0">
                <img src="~/img/opacity_img.png" alt="Marca d'Água Globo" class="w-[65%] h-auto object-contain" />
            </div>
            
        </div>

        <div class="w-[45%] bg-[#E3DBCE] flex items-center rounded-l-[50px] justify-center p-10 shadow-2xl">
            
            <form action="/Home/Index" method="post" class="w-full max-w-sm flex flex-col gap-6">
                
                <h1 class="font-serif flex flex-row items-center justify-center text-[#6b462c] text-[50px] font-inria text-center mb-8 leading-tight">
                    L
                    <img src="~/img/logo_img.png" alt="Logo_MindSite" class="h-6 w-6 mt-2 ml-[2.5px]"/>
                    gin
                </h1>

                <div>
                    <input type="email" name="email" required 
                           placeholder="E-mail"
                           class="w-full bg-white text-[#4d392a] placeholder-[#8d735f] px-6 py-4 rounded-xl shadow-inner outline-none transition focus:ring-2 focus:ring-[#623f25]">
                </div>

                <div>
                    <input type="password" name="password" required 
                           placeholder="Senha"
                           class="w-full bg-white text-[#4d392a] placeholder-[#8d735f] px-6 py-4 rounded-xl shadow-inner outline-none transition focus:ring-2 focus:ring-[#623f25]">
                </div>

                <div class="text-right -mt-6">
                    <a href="#" class="text-sm italic text-[#623f25] hover:text-[#623f25] hover:underline transition-colors">
                        Esqueci minha senha.......
                    </a>
                </div>

                <div class="flex flex-row justify-between gap-4 mt-6 mx-[25px]">
                    <button type="submit" 
                            class="w-[150px] bg-[#6A462C] text-[#fafafa] py-3 rounded-2xl hover:bg-[#4d392a] transition-all font-semibold text-lg shadow-md">
                        Entrar
                    </button>

                    <a asp-controller="Account" asp-action="Cadastro"
                            class="w-[150px] bg-[#926A44] text-[#fafafa] text-center py-3 rounded-xl hover:bg-[#623f25] transition-all font-semibold text-lg shadow-md">
                        Cadastrar
                    </a>
                </div>

            </form>
            
        </div>

    </div>

</body>
</html>

@* font-thin = font-weight: 100;
font-extralight = font-weight: 200;
font-light = font-weight: 300;
font-normal = font-weight: 400;
font-medium = font-weight: 500;
font-semibold = font-weight: 600;
font-bold = font-weight: 700;
font-extrabold = font-weight: 800;
font-black = font-weight: 900;
font-(<custom-property>) = font-weight: var(<custom-property>);
font-[<value>] = font-weight: <value> *@