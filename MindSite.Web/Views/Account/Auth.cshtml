@{
    ViewData["Title"] = "LogAuth";
    Layout = null;
}

<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MindSite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="apple-touch-icon" sizes="180x180" href="../wwwroot/favicons/apple-touch-icon.png">
    <link rel="icon" type="image/png" sizes="32x32" href="../wwwroot/favicons/favicon-32x32.png">
    <link rel="icon" type="image/png" sizes="16x16" href="../wwwroot/favicons/favicon-16x16.png">
    <link rel="manifest" href="/favicons/site.webmanifest">
    <link href="https://fonts.googleapis.com/css2?family=Inria+Serif:wght@400;700&display=swap" rel="stylesheet">
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,800" rel="stylesheet">
</head>
<body class="flex items-center justify-center min-h-screen m-0 p-0 overflow-hidden">

    <div id="container" class="group relative w-screen h-screen bg-[#F4F3EE] shadow-[0_14px_28px_rgba(0,0,0,0.25),0_10px_10px_rgba(0,0,0,0.22)] overflow-hidden">
        
        <div class="absolute top-0 left-0 w-[40%] h-full bg-[#E3DBCE] z-[50] flex items-center justify-center transition-all duration-1000 ease-in-out 
                    rounded-tr-[50px] rounded-br-[50px] rounded-tl-0 rounded-bl-0
                    group-[.right-panel-active]:translate-x-[150%] 
                    group-[.right-panel-active]:rounded-tr-[0px] group-[.right-panel-active]:rounded-br-[0px] 
                    group-[.right-panel-active]:rounded-tl-[50px] group-[.right-panel-active]:rounded-bl-[50px]">
            
            <div class="absolute top-0 left-0 w-full h-full px-10 flex flex-col items-center justify-center transition-all duration-1000 ease-in-out opacity-0 z-[1] translate-x-[500%]
                        group-[.right-panel-active]:opacity-100 group-[.right-panel-active]:z-[2] group-[.right-panel-active]:translate-x-0">
                
                <form asp-controller="Account" asp-action="Cadastro" method="post" class="w-full max-w-sm flex flex-col gap-4">
                    <h1 class="font-['Inria_Serif'] text-5xl text-[#6b462c] text-center mb-6 flex flex-row items-center justify-center">
                        Cadastr
                        <img src="~/img/logo_img.png" alt="Logo" class="h-6 w-6 mt-[19px] ml-[2.5px]"/>
                    </h1>
                    <input type="text" name="nome" placeholder="Nome Completo" required class="w-full bg-white px-6 py-4 rounded-xl shadow-inner outline-none focus:ring-2 focus:ring-[#623f25]">
                    <input type="email" name="email" placeholder="E-mail" required class="w-full bg-white px-6 py-4 rounded-xl shadow-inner outline-none focus:ring-2 focus:ring-[#623f25]">
                    <input type="password" name="senha" placeholder="Senha" required class="w-full bg-white px-6 py-4 rounded-xl shadow-inner outline-none focus:ring-2 focus:ring-[#623f25]">
                    <input type="password" name="confirmarSenha" placeholder="Confirmar Senha" required class="w-full bg-white px-6 py-4 rounded-xl shadow-inner outline-none focus:ring-2 focus:ring-[#623f25]">
                        
                    <div class="flex flex-row justify-between gap-4 mt-6 mx-[25px]">
                        <button type="submit" class="w-[150px] bg-[#6A462C] text-white py-3 rounded-2xl hover:bg-[#4d392a] font-bold text-center">Cadastrar</button>
                        <button type="button" id="signEntra" class="w-[150px] bg-[#926A44] text-white py-3 rounded-2xl hover:bg-[#623f25] font-bold text-center">Voltar</button>
                    </div>
                </form>
            </div>

            <div class="absolute top-0 left-0 w-full h-full px-10 flex flex-col items-center justify-center transition-all duration-1000 ease-in-out opacity-100 z-[2] translate-x-0
                        group-[.right-panel-active]:opacity-0 group-[.right-panel-active]:z-[1] group-[.right-panel-active]:translate-x-[-500%]">
                
                <form asp-controller="Account" asp-action="Login" method="post" class="w-full max-w-sm flex flex-col gap-6">
                    <h1 class="font-['Inria_Serif'] flex flex-row items-center justify-center text-[#6b462c] text-[50px] text-center mb-8 leading-tight">
                        L<img src="~/img/logo_img.png" alt="Logo" class="h-6 w-6 mt-2 ml-[2.5px]"/>gin
                    </h1>
                    <input type="email" name="email" required placeholder="E-mail" class="w-full bg-white text-[#4d392a] placeholder-[#8d735f] px-6 py-4 rounded-xl shadow-inner outline-none transition focus:ring-2 focus:ring-[#623f25]">
                    <input type="password" name="password" required placeholder="Senha" class="w-full bg-white text-[#4d392a] placeholder-[#8d735f] px-6 py-4 rounded-xl shadow-inner outline-none transition focus:ring-2 focus:ring-[#623f25]">

                    <div class="text-right -mt-6">
                        <a href="#" class="text-sm italic text-[#623f25] hover:underline transition-colors">Esqueci minha senha.......</a>
                    </div>
                    <div class="flex flex-row justify-between gap-4 mt-6 mx-[25px]">
                        <button type="submit" class="w-[150px] bg-[#6A462C] text-[#fafafa] py-3 rounded-2xl hover:bg-[#4d392a] transition-all font-semibold text-lg shadow-md">Entrar</button>
                        <button type="button" id="signUp" class="w-[150px] bg-[#926A44] text-[#fafafa] text-center py-3 rounded-xl hover:bg-[#623f25] transition-all font-semibold text-lg shadow-md">Cadastrar</button>
                    </div>    
                </form>
            </div>
        </div>

        <div class="absolute top-0 left-[40%] w-[60%] h-full overflow-hidden transition-transform duration-1000 ease-in-out z-[1]
                    group-[.right-panel-active]:-translate-x-[67%]">
            <div class="h-full w-full flex items-center justify-center">
                <img src="~/img/opacity_img.png" alt="Marca d'Água" class="w-[70%] opacity-50 pointer-events-none" />
            </div>
        </div>
    </div>

    <script>
        const signUpButton = document.getElementById('signUp');
        const signEntraButton = document.getElementById('signEntra');
        const container = document.getElementById('container');

        signUpButton.addEventListener('click', () => {
            container.classList.add("right-panel-active");
        });

        signEntraButton.addEventListener('click', () => {
            container.classList.remove("right-panel-active");
        });
    </script>
</body>
</html>