    <script src="~/js/site.js"></script>
    <script>
        // Inicialização do tema salvo no localStorage
        const temaSalvo = localStorage.getItem('ms-theme') || 'light';
        document.documentElement.setAttribute('data-theme', temaSalvo);

        // Controle do painel deslizante no desktop
        const signUpButton = document.getElementById('signUp');
        const signEntraButton = document.getElementById('signEntra');
        const container = document.getElementById('container');

        if (signUpButton) signUpButton.addEventListener('click', () => container.classList.add("right-panel-active"));
        if (signEntraButton) signEntraButton.addEventListener('click', () => container.classList.remove("right-panel-active"));

        // Alternância entre abas de login e cadastro no mobile
        function mShowLogin() {
            document.getElementById('mLoginCard').classList.remove('hidden');
            document.getElementById('mCadCard').classList.add('hidden');
            document.getElementById('mTabLogin').style.cssText = 'background:var(--brown);color:#fff';
            document.getElementById('mTabCad').style.cssText = 'background:transparent;color:var(--text-muted)';
        }
        function mShowCad() {
            document.getElementById('mCadCard').classList.remove('hidden');
            document.getElementById('mLoginCard').classList.add('hidden');
            document.getElementById('mTabCad').style.cssText = 'background:var(--brown);color:#fff';
            document.getElementById('mTabLogin').style.cssText = 'background:transparent;color:var(--text-muted)';
        }

        // Abre direto no painel de cadastro se a URL contiver ?modo=cadastro
        if (new URLSearchParams(location.search).get('modo') === 'cadastro') {
            if (container) container.classList.add("right-panel-active");
            mShowCad();
        }

        // Validação dos formulários no desktop
        document.getElementById('formCadastro')?.addEventListener('submit', function(e) {
            let ok = MsVal.form(this);
            ok = MsVal.senhas('cSenha', 'cConfirma') && ok;
            const check = this.querySelector('[name="AceitouContrato"]');
            if (check && !check.checked) { MsVal.erro(check.nextElementSibling || check, 'Você deve aceitar os termos'); ok = false; }
            if (!ok) e.preventDefault();
        });
        document.getElementById('formLogin')?.addEventListener('submit', function(e) {
            if (!MsVal.form(this)) e.preventDefault();
        });
        document.getElementById('cConfirma')?.addEventListener('input', function() {
            if (this.value && this.value !== document.getElementById('cSenha').value) MsVal.erro(this, 'Senhas não conferem');
            else if (this.value) MsVal.ok(this);
        });

        // Validação dos formulários no mobile
        document.getElementById('mFormCadastro')?.addEventListener('submit', function(e) {
            let ok = MsVal.form(this);
            ok = MsVal.senhas('mCSenha', 'mCConfirma') && ok;
            const check = this.querySelector('[name="AceitouContrato"]');
            if (check && !check.checked) { MsVal.erro(check.nextElementSibling || check, 'Você deve aceitar os termos'); ok = false; }
            if (!ok) e.preventDefault();
        });
        document.getElementById('mFormLogin')?.addEventListener('submit', function(e) {
            if (!MsVal.form(this)) e.preventDefault();
        });
        document.getElementById('mCConfirma')?.addEventListener('input', function() {
            if (this.value && this.value !== document.getElementById('mCSenha').value) MsVal.erro(this, 'Senhas não conferem');
            else if (this.value) MsVal.ok(this);
        });

        // Toast notifications from server
        @if (TempData["Erro"] != null)
        {
            @:showToast(@Json.Serialize(TempData["Erro"]!.ToString()), 'erro');
        }
        @if (TempData["Success"] != null)
        {
            @:showToast(@Json.Serialize(TempData["Success"]!.ToString()), 'success');
        }
        @if (TempData["ErroCadastro"] != null)
        {
            @:showToast(@Json.Serialize(TempData["ErroCadastro"]!.ToString()), 'erro');
        }

        // Alterna visibilidade do campo de senha
        function toggleSenha(id, btn) {
            const inp = document.getElementById(id);
            if (!inp) return;
            const isHidden = inp.type === 'password';
            inp.type = isHidden ? 'text' : 'password';
            btn.querySelector('.eye-off').classList.toggle('hidden', isHidden);
            btn.querySelector('.eye-on').classList.toggle('hidden', !isHidden);
        }
    </script>
</body>
</html>
