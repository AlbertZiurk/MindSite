@{
    ViewData["Title"] = "UserProfile";
    Layout = null;
}
<!DOCTYPE html>
<html lang="pt-br">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - MindSite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inria+Serif:wght@400;700&display=swap" rel="stylesheet">
    <script>
        tailwind.config = {
            theme: {
                extend: {
                    fontFamily: {
                        'inria': ['"Inria Serif"', 'serif']
                    }
                }
            }
        }
    </script>
    <style>
        /* Toggle switch custom styles */
        .toggle-checkbox:checked + .toggle-label {
            background-color: #6B462C;
        }
        .toggle-checkbox:checked + .toggle-label .toggle-dot {
            transform: translateX(100%);
        }
        .toggle-label .toggle-text-on {
            display: none;
        }
        .toggle-checkbox:checked + .toggle-label .toggle-text-on {
            display: block;
        }
        .toggle-checkbox:checked + .toggle-label .toggle-text-off {
            display: none;
        }
    </style>
</head>
<body class="min-h-screen bg-[#F4F3EE] font-inria">

    <!-- ==================== HEADER ==================== -->
    <header class="flex w-full h-24 bg-[#e3dbce] items-center justify-between px-6 md:px-10 shadow-sm">

        <!-- Logo -->
        <div class="flex items-center">
            <a class="flex items-center gap-1 text-3xl md:text-4xl font-inria font-bold text-[#6B462C] hover:opacity-80 transition-opacity" asp-controller="Home" asp-action="Index">
                Mind<img src="~/img/logo_img.png" alt="Logo_MindSite" class="h-12 md:h-14 w-auto" />Site
            </a>
        </div>

        <!-- Nav Links + Right Icons grouped together -->
        <div class="hidden md:flex items-center gap-8">
            <nav class="flex items-end">
                <ul class="flex space-x-8 text-[#4d392a] font-semibold text-lg mt-2">
                    <li><a class="hover:text-[#6B462C] transition-colors" asp-controller="Home" asp-action="Index">Home</a></li>
                    <li><a class="hover:text-[#6B462C] transition-colors" asp-controller="Home" asp-action="SobreNos">Usuários</a></li>
                    <li><a class="hover:text-[#6B462C] transition-colors" asp-controller="Home" asp-action="Servicos">Serviços</a></li>
                </ul>
            </nav>

            <!-- Right Icons -->
            <div class="flex items-center gap-5">
                <!-- Notification Bell -->
                <button class="text-[#6B462C] hover:text-[#4d392a] transition-colors relative">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-8 w-8" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M15 17h5l-1.405-1.405A2.032 2.032 0 0118 14.158V11a6.002 6.002 0 00-4-5.659V5a2 2 0 10-4 0v.341C7.67 6.165 6 8.388 6 11v3.159c0 .538-.214 1.055-.595 1.436L4 17h5m6 0v1a3 3 0 11-6 0v-1m6 0H9" />
                    </svg>
                </button>
                <!-- Profile -->
                <a asp-controller="Account" asp-action="UserProfile" class="flex flex-col items-center text-[#6B462C] hover:text-[#4d392a] transition-colors">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm0 3c1.66 0 3 1.34 3 3s-1.34 3-3 3-3-1.34-3-3 1.34-3 3-3zm0 14.2c-2.5 0-4.71-1.28-6-3.22.03-1.99 4-3.08 6-3.08 1.99 0 5.97 1.09 6 3.08-1.29 1.94-3.5 3.22-6 3.22z"/>
                    </svg>
                </a>
            </div>
        </div>

    </header>

    <!-- ==================== MAIN CONTENT ==================== -->
    <main class="flex px-6 md:px-12 lg:px-16 py-8 ">

            <!-- Top section: avatar + name (left), dark mode toggle (right) -->
        <div class="w-full h-full pb-14">
            <div class="flex items-center justify-start mb-10">

                <!-- Left: Profile avatar + name -->
                <div class="flex items-center gap-5">
                    <div class="relative">
                        <!-- Avatar circle -->
                        <div class="w-24 h-24 md:w-28 md:h-28 rounded-full bg-[#6B462C] flex items-center justify-center overflow-hidden shadow-lg">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-16 w-16 md:h-20 md:w-20 text-[#d4b896]" fill="currentColor" viewBox="0 0 24 24">
                                <path d="M12 12c2.21 0 4-1.79 4-4s-1.79-4-4-4-4 1.79-4 4 1.79 4 4 4zm0 2c-2.67 0-8 1.34-8 4v2h16v-2c0-2.66-5.33-4-8-4z"/>
                            </svg>
                        </div>
                        <!-- Camera icon overlay -->
                    @* <button class="absolute -bottom-1 -right-1 bg-[#6B462C] text-white rounded-full p-1.5 shadow-md hover:bg-[#4d392a] transition-colors">
                            <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                <path stroke-linecap="round" stroke-linejoin="round" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z" />
                                <path stroke-linecap="round" stroke-linejoin="round" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z" />
                            </svg>
                        </button>*@
                    </div>
                    <h1 id="nomeUser" class="text-2xl md:text-3xl font-bold text-[#6B462C] font-inria">Severo Snape</h1>
                </div>

        



            </div>


            @* ==================== CARDS SECTION ==================== *@

            <div id="modalDeCards" class="grid grid-cols-1 md:grid-cols-3 gap-6 lg:gap-8">

                @* ---- Card: Troca de Senha ---- *@
                <div class="bg-white rounded-2xl border-2 border-[#8B6F47] p-6 shadow-sm hover:shadow-md transition-shadow">
                    <h4 class="text-xl font-bold text-[#6B462C] text-center mb-6">Troca de Senha</h4>

                    <!-- Senha Atual -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-[#4d392a] mb-1">Senha Atual:</label>
                        <div class="relative">
                            <input type="password" value="senhaatualexemplo"
                                class="w-full border border-[#c4b19a] rounded-lg px-3 py-2 pr-10 text-sm text-[#4d392a] bg-[#faf9f6] focus:outline-none focus:ring-2 focus:ring-[#8B6F47] focus:border-transparent transition" />
                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8B6F47] hover:text-[#6B462C] transition-colors toggle-password">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Alterar Senha -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-[#4d392a] mb-1">Alterar Senha:</label>
                        <div class="relative">
                            <input type="password" value="novasenha1234"
                                class="w-full border border-[#c4b19a] rounded-lg px-3 py-2 pr-10 text-sm text-[#4d392a] bg-[#faf9f6] focus:outline-none focus:ring-2 focus:ring-[#8B6F47] focus:border-transparent transition" />
                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8B6F47] hover:text-[#6B462C] transition-colors toggle-password">
                                <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Confirmar Senha -->
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-[#4d392a] mb-1">Confirmar Senha:</label>
                        <div class="relative">
                            <input type="password" value="novasenha1234"
                                class="w-full border border-[#c4b19a] rounded-lg px-3 py-2 pr-10 text-sm text-[#4d392a] bg-[#faf9f6] focus:outline-none focus:ring-2 focus:ring-[#8B6F47] focus:border-transparent transition" />
                            <button type="button" class="absolute right-3 top-1/2 -translate-y-1/2 text-[#8B6F47] hover:text-[#6B462C] transition-colors toggle-password">
                                <svg class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                                    <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                                </svg>
                            </button>
                        </div>
                    </div>

                    <!-- Botão Salvar -->
                    <div class="flex justify-center">
                        <button class="bg-[#6B462C] text-white font-semibold text-sm px-8 py-2 rounded-full hover:bg-[#4d392a] active:scale-95 transition-all shadow-md">
                            Salvar
                        </button>
                    </div>

                    
                </div>


                @* ---- Card: Dados Pessoais ---- *@
                <div class="bg-white rounded-2xl border-2 border-[#8B6F47] p-6 shadow-sm hover:shadow-md transition-shadow">
                    <h4 class="text-xl font-bold text-[#6B462C] text-center mb-6">Dados Pessoais</h4>

                    <!-- Nome Completo -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-[#4d392a] mb-1">Nome Completo:</label>
                        <input type="text" value="Severo Caxias Snape"
                            class="w-full border border-[#c4b19a] rounded-lg px-3 py-2 text-sm text-[#4d392a] bg-[#faf9f6] focus:outline-none focus:ring-2 focus:ring-[#8B6F47] focus:border-transparent transition" />
                    </div>

                    <!-- Email -->
                    <div class="mb-4">
                        <label class="block text-sm font-semibold text-[#4d392a] mb-1">Email:</label>
                        <input type="email" value="severiope@gmail.com"
                            class="w-full border border-[#c4b19a] rounded-lg px-3 py-2 text-sm text-[#4d392a] bg-[#faf9f6] focus:outline-none focus:ring-2 focus:ring-[#8B6F47] focus:border-transparent transition" />
                    </div>

                    <!-- Telefone -->
                    <div class="mb-6">
                        <label class="block text-sm font-semibold text-[#4d392a] mb-1">Telefone:</label>
                        <input type="tel" value="(11) 91651-2134"
                            class="w-full border border-[#c4b19a] rounded-lg px-3 py-2 text-sm text-[#4d392a] bg-[#faf9f6] focus:outline-none focus:ring-2 focus:ring-[#8B6F47] focus:border-transparent transition" />
                    </div>

                    <!-- Botão Salvar -->
                    <div class="flex justify-center">
                        <button class="bg-[#6B462C] text-white font-semibold text-sm px-8 py-2 rounded-full hover:bg-[#4d392a] active:scale-95 transition-all shadow-md">
                            Salvar
                        </button>
                    </div>
                </div>


                @* ---- Card: Outras Informações ---- *@
                <div class="bg-white rounded-2xl border-2 border-[#8B6F47] p-6 shadow-sm hover:shadow-md transition-shadow">
                    <h4 class="text-xl font-bold text-[#6B462C] text-center mb-6">Outras Informações</h4>

                    <!-- Conta Criada em -->
                    <div class="mb-4">
                        <h5 class="text-sm font-semibold text-[#4d392a] mb-0.5">Conta Criada em:</h5>
                        <p id="dataCriacao" class="text-base text-[#6B462C] font-medium ml-1">10/03/2026</p>
                    </div>

                    <!-- Status do Usuário -->
                    <div class="mb-6">
                        <h5 class="text-sm font-semibold text-[#4d392a] mb-0.5">Status do Usuário:</h5>
                        <p id="status" class="text-base text-[#6B462C] font-medium ml-1">ATIVO</p>
                    </div>

                    <!-- Preferências -->
                    <div>
                        <h4 class="text-lg font-bold text-[#6B462C] mb-4">Preferência:</h4>

                        <!-- Toggle: Notificações por Email -->
                        <div class="flex items-center justify-between mb-4">
                            <span class="text-sm font-semibold text-[#4d392a]">Notificações por Email:</span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" checked class="sr-only peer" />
                                <div class="w-14 h-7 bg-gray-300 peer-focus:ring-2 peer-focus:ring-[#8B6F47] rounded-full peer peer-checked:bg-[#6B462C] transition-colors duration-300"></div>
                                <div class="absolute left-1 top-1 bg-white w-5 h-5 rounded-full shadow-md peer-checked:translate-x-7 transition-transform duration-300"></div>
                                <span class="absolute left-2 text-[10px] font-bold text-white peer-checked:opacity-100 opacity-0 transition-opacity duration-300 select-none">ON</span>
                            </label>
                        </div>

                        <!-- Toggle: Notificações de Chat -->
                        <div class="flex items-center justify-between">
                            <span class="text-sm font-semibold text-[#4d392a]">Notificação de Chat:</span>
                            <label class="relative inline-flex items-center cursor-pointer">
                                <input type="checkbox" checked class="sr-only peer" />
                                <div class="w-14 h-7 bg-gray-300 peer-focus:ring-2 peer-focus:ring-[#8B6F47] rounded-full peer peer-checked:bg-[#6B462C] transition-colors duration-300"></div>
                                <div class="absolute left-1 top-1 bg-white w-5 h-5 rounded-full shadow-md peer-checked:translate-x-7 transition-transform duration-300"></div>
                                <span class="absolute left-2 text-[10px] font-bold text-white peer-checked:opacity-100 opacity-0 transition-opacity duration-300 select-none">ON</span>
                            </label>
                        </div>
                    </div>
                </div>

            </div>

        </div>

                <!-- Right: Dark mode toggle -->
            <div class="flex flex-col justify-between">
                <button id="btnToggleTheme" class="text-[#6B462C] hover:text-[#4d392a] transition-colors p-2">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9" fill="currentColor" viewBox="0 0 24 24">
                        <path d="M21 12.79A9 9 0 1111.21 3 7 7 0 0021 12.79z"/>
                    </svg>
                </button>
            


                <!-- Delete icon below cards, right-aligned -->
            
                <button class="text-[#6B462C] hover:text-red-700 transition-colors p-2" title="Excluir conta">
                    <svg xmlns="http://www.w3.org/2000/svg" class="h-9 w-9" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                        <path stroke-linecap="round" stroke-linejoin="round" d="M19 7l-.867 12.142A2 2 0 0116.138 21H7.862a2 2 0 01-1.995-1.858L5 7m5 4v6m4-6v6m1-10V4a1 1 0 00-1-1h-4a1 1 0 00-1 1v3M4 7h16" />
                    </svg>
                </button>
            </div>
            @* ==================== END CARDS ==================== *@

    </main>

    <!-- ==================== SCRIPTS ==================== -->
    <script>
        // Toggle password visibility
            document.querySelectorAll('.toggle-password').forEach(btn => {
            btn.addEventListener('click', () => {
                const input = btn.parentElement.querySelector('input');
                if (input.type === 'password') {
                    input.type = 'text';
                    btn.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M13.875 18.825A10.05 10.05 0 0112 19c-4.478 0-8.268-2.943-9.543-7a9.97 9.97 0 011.563-3.029m5.858.908a3 3 0 114.243 4.243M9.878 9.878l4.242 4.242M9.878 9.878L6.59 6.59m7.532 7.532l3.29 3.29M3 3l3.59 3.59m0 0A9.953 9.953 0 0112 5c4.478 0 8.268 2.943 9.543 7a10.025 10.025 0 01-4.132 5.411m0 0L21 21" />
                        </svg>`;
                } else {
                    input.type = 'password';
                    btn.innerHTML = `
                        <svg xmlns="http://www.w3.org/2000/svg" class="h-5 w-5" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
                            <path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 11-6 0 3 3 0 016 0z" />
                            <path stroke-linecap="round" stroke-linejoin="round" d="M2.458 12C3.732 7.943 7.523 5 12 5c4.478 0 8.268 2.943 9.542 7-1.274 4.057-5.064 7-9.542 7-4.477 0-8.268-2.943-9.542-7z" />
                        </svg>`;
                }
            });
        });
    </script>

</body>
</html>