@{
    ViewData["Title"] = "Redefinir Senha";
    Layout = null;
    var token = ViewBag.Token as string ?? "";
}
<!DOCTYPE html>
<html lang="pt-BR" class="scroll-smooth">
<head>
    <meta charset="utf-8"/>
    <meta name="viewport" content="width=device-width, initial-scale=1.0"/>
    <title>Redefinir Senha — MindSite</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link href="https://fonts.googleapis.com/css2?family=Inria+Serif:wght@400;700&family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <link rel="stylesheet" href="~/css/site.css"/>
    <script>tailwind.config={theme:{extend:{fontFamily:{inria:['"Inria Serif"','serif'],sans:['Poppins','sans-serif']}}}}</script>
</head>
<body class="min-h-screen flex items-center justify-center px-4" style="background:var(--bg)">

<div class="w-full max-w-md">

    <div class="text-center mb-8">
        <a href="/" class="inline-flex items-center gap-1 text-3xl font-inria" style="color:var(--brown)">
            Mind
            <svg width="32" height="32" viewBox="0 0 36 36" fill="none" aria-hidden="true">
                <circle cx="18" cy="18" r="15" stroke="currentColor" stroke-width="2.2" fill="none"/>
                <ellipse cx="18" cy="18" rx="6" ry="15" stroke="currentColor" stroke-width="2.2" fill="none"/>
                <line x1="3" y1="18" x2="33" y2="18" stroke="currentColor" stroke-width="2.2"/>
                <line x1="6" y1="11" x2="30" y2="11" stroke="currentColor" stroke-width="1.4"/>
                <line x1="6" y1="25" x2="30" y2="25" stroke="currentColor" stroke-width="1.4"/>
            </svg>
            Site
        </a>
        <p class="text-sm mt-1" style="color:var(--text-muted)">Redefinir senha</p>
    </div>

    @* Cartão de redefinição de nova senha *@
    <div class="ms-card p-8">

        <h1 class="font-inria text-2xl font-bold mb-2" style="color:var(--text)">Nova senha</h1>
        <p class="text-sm mb-6" style="color:var(--text-muted)">Escolha uma nova senha segura para sua conta.</p>

        @* Formulário de redefinição de senha *@
        <form id="formRedefinir" asp-controller="Account" asp-action="RedefinirSenha" method="post" class="flex flex-col gap-4">
            @Html.AntiForgeryToken()
            <input type="hidden" name="token" value="@token"/>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Nova senha <span class="normal-case font-normal">(mín. 6 caracteres)</span></label>
                <input id="rSenha" type="password" name="novaSenha" required minlength="6" placeholder="••••••••"
                       class="ms-input"/>
            </div>

            <div>
                <label class="text-xs font-semibold uppercase tracking-wider mb-1 block" style="color:var(--text-muted)">Confirmar senha</label>
                <input id="rConfirma" type="password" name="confirmarSenha" required minlength="6" placeholder="••••••••"
                       class="ms-input"/>
            </div>

            <button type="submit" class="btn-primary w-full py-3">
                Redefinir senha
            </button>
        </form>

        <div class="mt-6 text-center">
            <a asp-controller="Account" asp-action="Login" class="text-sm hover:underline" style="color:var(--text-muted)">
                ← Voltar para o login
            </a>
        </div>
    </div>
</div>

<script src="~/js/site.js"></script>
<script>
// Validação e comparação das senhas antes do envio
document.getElementById('formRedefinir')?.addEventListener('submit', function(e) {
    let ok = MsVal.form(this);
    ok = MsVal.senhas('rSenha', 'rConfirma') && ok;
    if (!ok) e.preventDefault();
});
document.getElementById('rConfirma')?.addEventListener('input', function() {
    if (this.value && this.value !== document.getElementById('rSenha').value)
        MsVal.erro(this, 'Senhas não conferem');
    else if (this.value)
        MsVal.ok(this);
});
const t = localStorage.getItem('ms-theme') || 'light';
document.documentElement.setAttribute('data-theme', t);

@if (TempData["Erro"] != null)
{
    @:showToast(@Json.Serialize(TempData["Erro"]!.ToString()), 'erro');
}
</script>
</body>
</html>
